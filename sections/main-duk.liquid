{{ 'section-duk.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}
<!-- ──────────── BREADCRUMBS ──────────── -->
{%- assign crumb_parent = section.settings.crumb_parent | default: 'Pagalba' -%}
{%- assign crumb_current = section.settings.crumb_current | default: 'Dažniausi klausimai' -%}
{% render 'breadcrumbs', parent_label: crumb_parent, parent_url: page.url, current: crumb_current %}

<!-- ──────────── PAGE HEAD ──────────── -->
<section class="phead">
  <div>
    <h1 class="phead__title">
      <span class="light">{{ section.settings.title_light | default: 'Dažniausi' }}</span>
      {{ section.settings.title | default: 'klausimai.' }}
    </h1>
  </div>
  <div class="phead__aside">
    <p class="phead__intro">{{ section.settings.intro | default: 'Viskas apie užsakymus, pristatymą, grąžinimus ir apmokėjimą — surinkta iš laiškų, kuriuos gauname dažniausiai. Neradote? <b>Saulius atsako asmeniškai</b> per dieną.' }}</p>
  </div>
</section>

<!-- ──────────── SEARCH ──────────── -->
<section class="faqsearch">
  <div class="faqsearch__field">
    <svg viewBox="0 0 20 20" aria-hidden="true"><circle cx="9" cy="9" r="6.5"/><path d="M14 14l4 4"/></svg>
    <input type="search" id="faq-q" placeholder="{{ section.settings.search_placeholder | default: 'Ieškokite klausimo, pvz. grąžinimas' | escape }}" aria-label="{{ 'accessibility.faq_search' | t }}" autocomplete="off">
    <span class="kbd" aria-hidden="true"><span>⌘</span><span>K</span></span>
  </div>
  <p class="faqsearch__hint" id="faq-stat" role="status" aria-live="polite"></p>
</section>

<!-- ──────────── SHELL ──────────── -->
<div class="shell">
{%- if section.blocks.size > 0 -%}

  <!-- category rail (block-driven) — scroll-spy Custom Element highlights the
       active category as you scroll (shared with grąžinimai/avalynės) -->
  <scroll-spy class="rail" role="complementary" aria-label="{{ 'accessibility.categories' | t }}" data-spy-links='a[href^="#"]' data-spy-margin="-20% 0px -70% 0px">
    {%- for block in section.blocks -%}
      {%- if block.type == 'group' -%}
        {%- assign cnt = 0 -%}
        {%- for b in section.blocks offset: forloop.index -%}
          {%- if b.type == 'group' -%}{%- break -%}{%- endif -%}
          {%- assign cnt = cnt | plus: 1 -%}
        {%- endfor -%}
        <a href="#{{ block.settings.anchor | default: block.id }}"{% if forloop.first %} aria-current="true"{% endif %}>{{ block.settings.title }} <span class="n">{% if cnt < 10 %}0{% endif %}{{ cnt }}</span></a>
      {%- endif -%}
    {%- endfor -%}
    <div class="rail__divider"></div>
    <div class="rail__help">
      <p>{{ section.settings.rail_help | default: 'Neradote atsakymo? Parašykite — atsakome per dieną.' }}</p>
      <a href="{{ pages.kontaktai.url | default: routes.root_url }}" class="lnk">{{ section.settings.rail_help_label | default: 'Susisiekti →' }}</a>
    </div>
  </scroll-spy>

  <!-- accordion column (block-driven) -->
  <div class="qcol">
    {%- assign gi = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'group' -%}
        {%- assign gi = gi | plus: 1 -%}
        {%- assign cnt = 0 -%}
        {%- for b in section.blocks offset: forloop.index -%}
          {%- if b.type == 'group' -%}{%- break -%}{%- endif -%}
          {%- assign cnt = cnt | plus: 1 -%}
        {%- endfor -%}
    <section class="group" id="{{ block.settings.anchor | default: block.id }}" data-cat="{{ block.settings.title | escape }}" {{ block.shopify_attributes }}>
      <div class="group__head">
        <span class="gi">{% if gi < 10 %}0{% endif %}{{ gi }}</span>
        <h2>{{ block.settings.title }}</h2>
        <span class="count">{% if cnt < 10 %}0{% endif %}{{ cnt }} {{ 'faq.group_questions' | t }}</span>
      </div>
      {%- for b in section.blocks offset: forloop.index -%}
        {%- if b.type == 'group' -%}{%- break -%}{%- endif -%}
        {%- if b.type == 'accordion_item' -%}
      {% render 'accordion-item', question: b.settings.question, answer: b.settings.answer, open: b.settings.open, attrs: b.shopify_attributes %}
        {%- endif -%}
      {%- endfor -%}
    </section>
      {%- endif -%}
    {%- endfor -%}

    <!-- no results -->
    <div class="noresults" id="noresults">
      <p>{{ section.settings.nr_prefix | default: 'Pagal' }} <b id="nr-term"></b> {{ section.settings.nr_suffix | default: 'nieko neradome. Pabandykite kitą žodį arba' }} <a href="{{ pages.kontaktai.url | default: routes.root_url }}" class="uline">{{ section.settings.nr_link_label | default: 'parašykite mums' }}</a>.</p>
    </div>
  </div>

{%- else -%}
  {% render 'faq-fallback' %}
{%- endif -%}
</div>

<!-- ──────────── CONTACT STRIP ──────────── -->
<section class="contactstrip">
  <div class="contactstrip__wrap">
    <div>
      <h2><span class="light">{{ section.settings.strip_title_light | default: 'Neradote' }}</span> {{ section.settings.strip_title | default: 'to, ko ieškojote?' }}</h2>
      <p>{{ section.settings.strip_text | default: 'Parašykite ar paskambinkite — Saulius ir Aistė atsako asmeniškai per darbo dieną. Jokių botų, jokių tikietų sistemos.' }}</p>
    </div>
    <div class="contactstrip__actions">
      {% render 'button', label: section.settings.strip_cta_label | default: 'Susisiekti', href: section.settings.strip_cta_link | default: pages.kontaktai.url | default: '/pages/kontaktai', style: 'orange', arrow: true %}
      {% render 'button', label: section.settings.strip_visit_label | default: 'Aplankyti ateljė · Trakų g. 16', href: section.settings.strip_visit_link | default: 'https://maps.google.com/?q=Trak%C5%B3+g.+16,+Vilnius', style: 'secondary', target: '_blank' %}
    </div>
  </div>
</section>
<script src="{{ 'component-scroll-spy.js' | asset_url }}" defer></script>
<script src="{{ 'duk.js' | asset_url }}" defer></script>
{% schema %}
{
  "name": "DUK",
  "settings": [
    { "type": "header", "content": "Breadcrumb" },
    { "type": "text", "id": "crumb_parent", "label": "Breadcrumb parent", "default": "Pagalba" },
    { "type": "text", "id": "crumb_current", "label": "Breadcrumb current", "default": "Dažniausi klausimai" },
    { "type": "header", "content": "Head" },
    { "type": "text", "id": "title_light", "label": "Title (light part)", "default": "Dažniausi" },
    { "type": "text", "id": "title", "label": "Title (bold part)", "default": "klausimai." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Viskas apie užsakymus, pristatymą, grąžinimus ir apmokėjimą — surinkta iš laiškų, kuriuos gauname dažniausiai. Neradote? <b>Saulius atsako asmeniškai</b> per dieną." },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Ieškokite klausimo, pvz. grąžinimas" },
    { "type": "header", "content": "Rail help" },
    { "type": "text", "id": "rail_help", "label": "Help text", "default": "Neradote atsakymo? Parašykite — atsakome per dieną." },
    { "type": "text", "id": "rail_help_label", "label": "Help link label", "default": "Susisiekti →" },
    { "type": "header", "content": "No results" },
    { "type": "text", "id": "nr_prefix", "label": "Prefix (before the search term)", "default": "Pagal" },
    { "type": "text", "id": "nr_suffix", "label": "Suffix (after the search term)", "default": "nieko neradome. Pabandykite kitą žodį arba" },
    { "type": "text", "id": "nr_link_label", "label": "Link label", "default": "parašykite mums" },
    { "type": "header", "content": "Contact strip" },
    { "type": "text", "id": "strip_title_light", "label": "Title (light part)", "default": "Neradote" },
    { "type": "text", "id": "strip_title", "label": "Title (bold part)", "default": "to, ko ieškojote?" },
    { "type": "textarea", "id": "strip_text", "label": "Text", "default": "Parašykite ar paskambinkite — Saulius ir Aistė atsako asmeniškai per darbo dieną. Jokių botų, jokių tikietų sistemos." },
    { "type": "text", "id": "strip_cta_label", "label": "Primary button label", "default": "Susisiekti" },
    { "type": "url", "id": "strip_cta_link", "label": "Primary button link" },
    { "type": "text", "id": "strip_visit_label", "label": "Secondary button label", "default": "Aplankyti ateljė · Trakų g. 16" },
    { "type": "url", "id": "strip_visit_link", "label": "Secondary button link", "info": "Leave empty for the built-in Google Maps link." },
    { "type": "header", "content": "Text size & colour" },
    { "type": "range", "id": "title_scale", "label": "Heading size", "min": 60, "max": 130, "step": 5, "unit": "%", "default": 100 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "FAQ group",
      "settings": [
        { "type": "text", "id": "title", "label": "Group title" },
        { "type": "text", "id": "anchor", "label": "Anchor id (latin, no spaces)" }
      ]
    },
    {
      "type": "accordion_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ]
}
{% endschema %}
