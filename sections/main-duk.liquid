{{ 'section-duk.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}
<!-- ──────────── BREADCRUMBS ──────────── -->
<nav class="crumbs" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Pradžia</a>
  <span class="sep">/</span>
  <a href="{{ page.url | default: routes.root_url }}">Pagalba</a>
  <span class="sep">/</span>
  <b>Dažniausi klausimai</b>
</nav>

<!-- ──────────── PAGE HEAD ──────────── -->
<section class="phead">
  <div>
    <h1 class="phead__title">
      <span class="light">{{ section.settings.title_light | default: 'Dažniausi' }}</span>
      {{ section.settings.title | default: 'klausimai.' }}
    </h1>
  </div>
  <div class="phead__aside">
    <p class="phead__intro">{{ section.settings.intro | default: 'Viskas apie užsakymus, pristatymą, grąžinimus ir apmokėjimą — surinkta iš laiškų, kuriuos gauname dažniausiai. Neradote? <b>Saulius atsako asmeniškai</b> per dieną.' }}</p>
  </div>
</section>

<!-- ──────────── SEARCH ──────────── -->
<section class="faqsearch">
  <div class="faqsearch__field">
    <svg viewBox="0 0 20 20" aria-hidden="true"><circle cx="9" cy="9" r="6.5"/><path d="M14 14l4 4"/></svg>
    <input type="search" id="faq-q" placeholder="{{ section.settings.search_placeholder | default: 'Ieškokite klausimo, pvz. grąžinimas' | escape }}" aria-label="Ieškoti dažniausių klausimų" autocomplete="off">
    <span class="kbd" aria-hidden="true"><span>⌘</span><span>K</span></span>
  </div>
  <p class="faqsearch__hint" id="faq-stat" role="status" aria-live="polite"></p>
</section>

<!-- ──────────── SHELL ──────────── -->
<div class="shell">
{%- if section.blocks.size > 0 -%}

  <!-- category rail (block-driven) -->
  <aside class="rail" aria-label="Kategorijos">
    {%- for block in section.blocks -%}
      {%- if block.type == 'group' -%}
        {%- assign cnt = 0 -%}
        {%- for b in section.blocks offset: forloop.index -%}
          {%- if b.type == 'group' -%}{%- break -%}{%- endif -%}
          {%- assign cnt = cnt | plus: 1 -%}
        {%- endfor -%}
        <a href="#{{ block.settings.anchor | default: block.id }}"{% if forloop.first %} aria-current="true"{% endif %}>{{ block.settings.title }} <span class="n">{% if cnt < 10 %}0{% endif %}{{ cnt }}</span></a>
      {%- endif -%}
    {%- endfor -%}
    <div class="rail__divider"></div>
    <div class="rail__help">
      <p>{{ section.settings.rail_help | default: 'Neradote atsakymo? Parašykite — atsakome per dieną.' }}</p>
      <a href="{{ pages.kontaktai.url | default: routes.root_url }}" class="lnk">{{ section.settings.rail_help_label | default: 'Susisiekti →' }}</a>
    </div>
  </aside>

  <!-- accordion column (block-driven) -->
  <div class="qcol">
    {%- assign gi = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'group' -%}
        {%- assign gi = gi | plus: 1 -%}
        {%- assign cnt = 0 -%}
        {%- for b in section.blocks offset: forloop.index -%}
          {%- if b.type == 'group' -%}{%- break -%}{%- endif -%}
          {%- assign cnt = cnt | plus: 1 -%}
        {%- endfor -%}
    <section class="group" id="{{ block.settings.anchor | default: block.id }}" data-cat="{{ block.settings.title | escape }}" {{ block.shopify_attributes }}>
      <div class="group__head">
        <span class="gi">{% if gi < 10 %}0{% endif %}{{ gi }}</span>
        <h2>{{ block.settings.title }}</h2>
        <span class="count">{% if cnt < 10 %}0{% endif %}{{ cnt }} klausimai</span>
      </div>
      {%- for b in section.blocks offset: forloop.index -%}
        {%- if b.type == 'group' -%}{%- break -%}{%- endif -%}
        {%- if b.type == 'qa' -%}
      <details class="qa"{% if b.settings.open %} open{% endif %} {{ b.shopify_attributes }}>
        <summary><span class="q">{{ b.settings.question }}</span><span class="plus">+</span></summary>
        <div class="qa__body">{{ b.settings.answer }}</div>
      </details>
        {%- endif -%}
      {%- endfor -%}
    </section>
      {%- endif -%}
    {%- endfor -%}

    <!-- no results -->
    <div class="noresults" id="noresults">
      <p>{{ section.settings.nr_prefix | default: 'Pagal' }} <b id="nr-term"></b> {{ section.settings.nr_suffix | default: 'nieko neradome. Pabandykite kitą žodį arba' }} <a href="{{ pages.kontaktai.url | default: routes.root_url }}" class="uline">{{ section.settings.nr_link_label | default: 'parašykite mums' }}</a>.</p>
    </div>
  </div>

{%- else -%}

  <!-- category rail -->
  <aside class="rail" aria-label="Kategorijos">
    <a href="#dydziai" aria-current="true">Dydžiai ir tinkamumas <span class="n">06</span></a>
    <a href="#oda">Oda ir priežiūra <span class="n">05</span></a>
    <a href="#uzsakymas">Užsakymas ir pristatymas <span class="n">06</span></a>
    <a href="#grazinimai">Grąžinimai <span class="n">04</span></a>
    <a href="#taisymas">Taisymas ir garantija <span class="n">04</span></a>
    <a href="#atelje">Ateljė ir partijos <span class="n">03</span></a>
    <div class="rail__divider"></div>
    <div class="rail__help">
      <p>Neradote atsakymo? Parašykite — atsakome per dieną.</p>
      <a href="/pages/kontaktai" class="lnk">Susisiekti →</a>
    </div>
  </aside>

  <!-- accordion column -->
  <div class="qcol">

    <!-- ── DYDŽIAI ── -->
    <section class="group" id="dydziai" data-cat="Dydžiai ir tinkamumas">
      <div class="group__head">
        <span class="gi">01</span>
        <h2>Dydžiai ir tinkamumas</h2>
        <span class="count">06 klausimai</span>
      </div>

      <details class="qa" open>
        <summary><span class="q">Kaip pasirinkti dydį — ar imti įprastą, ar puse dydžio mažesnį?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Mūsų kurpaliai sukurti pagal Europos vidutinį pločio standartą. <b>Daugumai žmonių tinka įprastas EU dydis.</b> Mokasinės (de Boxe) išsitempia po 2–3 nešiojimų, todėl jei esate tarp dydžių — imkite mažesnį. Sportbačiai (de Course) ir tarnybiniai (le Service) — imkite įprastą.</p>
          <p>Abejojate? Atsiųskite mums savo pėdos ilgį centimetrais (matuokite vakare, stovint) — pasakysime tiksliai.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Ar yra platesnio pločio variantų?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Standartiškai gaminame vidutinį (F) plotį. Plataus (G) pločio porą galime pagaminti pagal individualų užsakymą iš tos pačios partijos odos — pridedame <b>2–3 savaites</b> gamybos ir €40. Parašykite prieš užsakydami.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Pirmą kartą perku — kaip žinoti, kad pora prigludo?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Pirštams turi likti maždaug nykščio pločio tarpas priekyje. Kulnas neturi slysti aukštyn vaikštant — bet pirmą savaitę nedidelis slydimas yra normalu, oda dar nesusiformavusi. Per platų jausmą šono srityje pataiso plonesnė kojinė arba mūsų odinis vidpadis.</p>
          <ul>
            <li>Matuokitės vakare — pėda per dieną išsiplečia</li>
            <li>Su ta kojine, su kuria nešiosite</li>
            <li>Pavaikščiokite namie ant švarios dangos 10–15 min</li>
          </ul>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Skiriasi kairė ir dešinė — ar tai defektas?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Ne. Kiekvieną porą sukerpame iš tos pačios odos, bet natūrali oda turi šiek tiek skirtingą tekstūrą skirtingose vietose — todėl ir gausite porą, kurioje matosi, kad ji ranka padaryta. Forma, dydis ir konstrukcija identiški. Jei jaučiate realų dydžio skirtumą — tai jau grąžinimo priežastis.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Ar galiu užsisakyti skirtingo dydžio kairę ir dešinę?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Taip — tai dažna ir mums įprasta. Pažymėkite užsakymo komentare arba parašykite po užsakymo. Tokia pora tampa individualiu užsakymu, todėl jai negalioja standartinis grąžinimas, bet padų keitimas ir garantija lieka.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Turiu siaurą / aukštą pakulnį — ar tinka jūsų avalynė?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Mūsų le Service ir de Boxe modeliai turi reguliuojamą uždarymą, todėl gerai prisitaiko prie įvairaus pakulnio. de Course žemo aulo modeliai — universaliausi. Geriausia užsukti į ateljė ir pasimatuoti — tam ji ir yra.</p>
        </div>
      </details>
    </section>

    <!-- ── ODA ── -->
    <section class="group" id="oda" data-cat="Oda ir priežiūra">
      <div class="group__head">
        <span class="gi">02</span>
        <h2>Oda ir priežiūra</h2>
        <span class="count">05 klausimų</span>
      </div>

      <details class="qa">
        <summary><span class="q">Kokią odą naudojate?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Pilnagrūdę veršio odą, augaliniu būdu raugintą <b>Tärnsjö rauginykloje Švedijoje</b> ir <i>Conceria Walpier</i> Toskanoje. Augalinis rauginimas reiškia, kad oda sensta gražiai — įgauna patiną, o ne lūžinėja. Zomšą imame iš Charles F. Stead Anglijoje.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Kaip prižiūrėti — kuo tepti ir kaip dažnai?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Naujai porai — bespalvis kremas kartą per mėnesį užtenka. Prieš pirmą nešiojimą rekomenduojame įtrinti plonu sluoksniu vandens atstūmimo balzamo. Lietui — natūralus vaškas. Zomšai — tik šepetėlis ir trintukas, jokio kremo.</p>
          <p>Su kiekviena pora atsiunčiame mažą priežiūros kortelę su konkrečiomis instrukcijomis tai odai.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Oda subraižyta iškart po gavimo — kodėl?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Pilnagrūdė oda turi natūralių žymių — randų, raukšlių, skirtingo poringumo — nes tai tikra oda, ne plastiku padengta. Tai ne defektas, o požymis, kad oda nebuvo per daug šlifuota. Gilus įpjovimas ar plyšys — kita kalba, tokiu atveju keičiame.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Ar oda atspari vandeniui?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Atspari, bet ne neperšlampama. Augaliniu būdu rauginta oda gerai pakelia lietų, jei prieš tai įtrynėte vašku. Po lietaus išdžiovinkite kambario temperatūroje su popieriumi viduje — niekada prie radiatoriaus.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Patamsėjo / pakeitė spalvą — ką daryti?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Augalinė oda natūraliai tamsėja nuo saulės ir nešiojimo — tai patina, ne defektas, ir daugumai tai gražiausia odos savybė. Norite vienodesnės spalvos — neeksponuokite vienos poros saulei ilgiau nei kitos ir tepkite kremą tolygiai.</p>
        </div>
      </details>
    </section>

    <!-- ── UŽSAKYMAS ── -->
    <section class="group" id="uzsakymas" data-cat="Užsakymas ir pristatymas">
      <div class="group__head">
        <span class="gi">03</span>
        <h2>Užsakymas ir pristatymas</h2>
        <span class="count">06 klausimų</span>
      </div>

      <details class="qa">
        <summary><span class="q">Per kiek laiko gausiu užsakymą?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Sandėlyje esančios poros išsiunčiamos kitą darbo dieną. Lietuvoje gausite per <b>1–2 dienas</b>, ES — <b>3–6 dienas</b>. Pre-order poros išsiunčiamos partijos gamybos pabaigoje — data nurodyta prie produkto.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Kiek kainuoja pristatymas?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Lietuvoje — nemokamas nuo €100, kitaip €4. Baltijos šalys — €6. Likusi ES — €12. UK ir už ES ribų — €18 plius galimi muitai gavėjui. Virš €300 užsakymas — nemokamas pristatymas bet kur Europoje.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Ar siunčiate už Europos ribų?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Taip — į JAV, Kanadą, Japoniją, Pietų Korėją, Australiją per DHL Express (3–6 d.). Muito ir importo mokesčiai krenta gavėjui ir priklauso nuo šalies. Japonijoje ir Pietų Korėjoje turime ir vietinius pardavėjus — gali būti paprasčiau.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Galiu pakeisti ar atšaukti užsakymą?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Jei dar neišsiuntėme — taip, parašykite kuo greičiau ir pakeisime dydį, adresą ar atšauksime. Pre-order užsakymą galima keisti bet kada iki gamybos pabaigos. Po išsiuntimo — jau per grąžinimo procesą.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Ar galiu sekti siuntą?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Žinoma. Išsiuntę atsiunčiame sekimo numerį el. paštu. LP EXPRESS ir DHL siuntas galite sekti realiu laiku. Negaunate laiškų — patikrinkite šlamšto aplanką arba parašykite mums.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Ar pakuojate dovanoms?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Visos poros keliauja mūsų standartinėje dėžėje su lino aplankalu — jau gražu be papildomos pakuotės. Pridedame ranka rašytą kortelę, jei pažymėsite užsakymo komentare. Dovanų užsakymams galioja prailgintas grąžinimas iki sausio 8 d.</p>
        </div>
      </details>
    </section>

    <!-- ── GRĄŽINIMAI ── -->
    <section class="group" id="grazinimai" data-cat="Grąžinimai">
      <div class="group__head">
        <span class="gi">04</span>
        <h2>Grąžinimai</h2>
        <span class="count">04 klausimai</span>
      </div>

      <details class="qa">
        <summary><span class="q">Koks grąžinimo laikotarpis?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p><b>14 dienų</b> nuo poros gavimo. Pora turi būti nenešiota lauke, su originalia dėže ir priedais. Lietuvoje grąžinimas nemokamas, ES — fiksuotas €6–€18 mokestis. Pilnas aprašymas — <a href="/pages/grazinimai" class="uline">grąžinimų puslapyje</a>.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Kaip greitai gausiu pinigus?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Per 5 darbo dienas nuo poros gavimo ateljėje. Pinigai grįžta tuo pačiu būdu, kuriuo mokėjote. Pasirinkę dovanų kuponą vietoj pinigų — pridedame +5% premiją.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Galiu keisti dydį nemokamai?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Taip — dydžio keitimas to paties modelio ir spalvos ribose Lietuvoje nemokamas. Naują dydį išsiunčiame nelaukdami, kol grįš senas. ES — €6 logistikos mokestis.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Ką daryti su dovana, kuri neprigludo?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Gavėjas gali keisti dydį ar modelį tiesiogiai su mumis, be pirkėjo įsitraukimo ir nematant kainos. Reikės tik užsakymo numerio iš dovanos kortelės arba pirkėjo el. pašto.</p>
        </div>
      </details>
    </section>

    <!-- ── TAISYMAS ── -->
    <section class="group" id="taisymas" data-cat="Taisymas ir garantija">
      <div class="group__head">
        <span class="gi">05</span>
        <h2>Taisymas ir garantija</h2>
        <span class="count">04 klausimai</span>
      </div>

      <details class="qa">
        <summary><span class="q">Kiek kainuoja padų keitimas?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Fiksuota kaina <b>€85</b> bet kuriai mūsų porai — net iš 2019-ųjų. Apima naują padą, kulną ir bendrą atnaujinimą. Vilniuje — užsukite į ateljė; kitur — atsiųskite porą, atgal grąžiname per 2–3 savaites.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Kokia garantija gamybiniam defektui?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Be termino. Jei dygsnis išsiskleidė, padas atsiskyrė ar oda įtrūko ne nešiojimo vietoje — taisome arba keičiame nemokamai. Tai apima konstrukciją, ne natūralų odos nusidėvėjimą.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Galite taisyti ne padų defektą — pvz., įplyšusią odą?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Taip. Mūsų batsiuvys gali perdygsniuoti, užlopyti ar perdažyti odą. Kainą įvertiname pagal nuotrauką — daugeliu atveju €30–€90. Atsiųskite nuotraukas į <b>taisymas@supersymmetry.lt</b>.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Ar taisote kitų gamintojų avalynę?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Ateljėje Vilniuje — taip, kokybiškos rantinės (Goodyear/Blake) konstrukcijos avalynei. Parašykite ar užsukite su pora — pasakysime, ar verta ir kiek kainuos.</p>
        </div>
      </details>
    </section>

    <!-- ── ATELJĖ ── -->
    <section class="group" id="atelje" data-cat="Ateljė ir partijos">
      <div class="group__head">
        <span class="gi">06</span>
        <h2>Ateljė ir partijos</h2>
        <span class="count">03 klausimai</span>
      </div>

      <details class="qa">
        <summary><span class="q">Kodėl tik 500 porų partijoje?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Tiek galime padaryti gerai per sezoną, neperduodami darbo fabrikui. Kai partija baigiasi, modelio nebeatkartojame — kitas sezonas reiškia kitą kurpalį, kitą odą. Tai mūsų vienintelės „naujienos“.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Galiu aplankyti ateljė ir pamatyti gamybą?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Taip — Trakų g. 16, Vilniaus senamiestyje. Darbo dienomis galite užsukti pasimatuoti, šeštadieniais kartais rengiame atvirų durų popietes su gamybos demonstracija. Sekite mūsų laišką arba <a href="/pages/kontaktai" class="uline">ateljės puslapį</a>{% comment %} atelier page — pointed at contact for now {% endcomment %}.</p>
        </div>
      </details>

      <details class="qa">
        <summary><span class="q">Kaip sužinoti apie naują partiją pirma?</span><span class="plus">+</span></summary>
        <div class="qa__body">
          <p>Užsiprenumeruokite mūsų mėnesinį laišką — prenumeratoriai gauna pre-order prieigą 48 valandomis anksčiau. Populiariausios spalvos dažnai išparduodamos dar pre-order metu.</p>
        </div>
      </details>
    </section>

    <!-- no results -->
    <div class="noresults" id="noresults">
      <p>Pagal <b id="nr-term"></b> nieko neradome. Pabandykite kitą žodį arba <a href="/pages/kontaktai" class="uline">parašykite mums</a>.</p>
    </div>

  </div>
{%- endif -%}
</div>

<!-- ──────────── CONTACT STRIP ──────────── -->
<section class="contactstrip">
  <div class="contactstrip__wrap">
    <div>
      <h2><span class="light">{{ section.settings.strip_title_light | default: 'Neradote' }}</span> {{ section.settings.strip_title | default: 'to, ko ieškojote?' }}</h2>
      <p>{{ section.settings.strip_text | default: 'Parašykite ar paskambinkite — Saulius ir Aistė atsako asmeniškai per darbo dieną. Jokių botų, jokių tikietų sistemos.' }}</p>
    </div>
    <div class="contactstrip__actions">
      <a href="{{ section.settings.strip_cta_link | default: pages.kontaktai.url | default: '/pages/kontaktai' }}" class="btn btn--orange">
        {{ section.settings.strip_cta_label | default: 'Susisiekti' }}
        <span class="btn__arrow">→</span>
      </a>
      <a href="{{ section.settings.strip_visit_link | default: 'https://maps.google.com/?q=Trak%C5%B3+g.+16,+Vilnius' }}" class="btn btn--secondary" target="_blank" rel="noopener">{{ section.settings.strip_visit_label | default: 'Aplankyti ateljė · Trakų g. 16' }}</a>
    </div>
  </div>
</section>
<script src="{{ 'duk.js' | asset_url }}" defer></script>
