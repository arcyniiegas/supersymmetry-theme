<main class="lock">

  <!-- top -->
  <div class="lock__top">
    <div class="lock__brand">{{ settings.brand_name | default: 'Supersymmetry' }}<span class="brand-dot" aria-hidden="true"></span></div>
    <div class="lock__stamp">
      <span>{{ section.settings.stamp_1 | default: 'Pavasaris/Vasara <b>2026</b>' }}</span>
      <span>{{ section.settings.stamp_2 | default: 'Partija <b>04</b>' }}</span>
      <span>{{ section.settings.stamp_3 | default: 'Vilnius · <b>LT</b>' }}</span>
    </div>
  </div>

  <!-- center -->
  <div class="lock__center">
    <div>
      <div class="eyebrow-rule lock__eyebrow">{{ section.settings.eyebrow | default: 'Netrukus atidarome · <b>parduotuvė užrakinta</b>' }}</div>
      <h1 class="lock__headline"><b>{{ section.settings.headline_bold | default: 'Pagaminta' }}</b><br /><span class="mute">{{ section.settings.headline_mute | default: 'vieną' }}</span> {{ section.settings.headline_rest | default: 'kartą.' }}</h1>
      <p class="lock__sub">{{ section.settings.sub | default: 'Ribota partija odinių porų, siūtų ranka Vilniuje. Palik el. paštą — pranešime pirmiausia.' }}</p>
    </div>

    <div class="lock__panel">
      <!-- countdown — only rendered when a real launch date is set -->
      {%- if section.settings.launch_datetime != blank -%}
      <div class="count" id="count" aria-label="{{ 'accessibility.time_to_open' | t }}" data-target="{{ section.settings.launch_datetime | escape }}">
        <div class="count__cell"><div class="count__n" id="cd">—</div><div class="count__l">d.</div></div>
        <div class="count__cell"><div class="count__n" id="ch">—</div><div class="count__l">val.</div></div>
        <div class="count__cell"><div class="count__n" id="cm">—</div><div class="count__l">min.</div></div>
        <div class="count__cell"><div class="count__n" id="cs">—</div><div class="count__l">sek.</div></div>
      </div>
      {%- endif -%}

      <!-- newsletter capture -->
      <div class="lock__newsletter">
        <p>{{ section.settings.newsletter_text | default: 'Pranešime, kai atidarysime — vienas laiškas, jokio marketingo.' }}</p>
        {% form 'customer', class: 'lock__form', id: 'signup' %}
          <input type="hidden" name="contact[tags]" value="prospect, password page">
          <div class="lock__field">
            <input type="email" name="contact[email]" placeholder="{{ section.settings.newsletter_placeholder | default: 'Jūsų el. paštas' | escape }}" aria-label="{{ 'accessibility.email' | t }}" required />
            <button type="submit">{{ section.settings.newsletter_button | default: 'Pranešti man' }} <span aria-hidden="true">→</span></button>
          </div>
          <div class="lock__hint"></div>
        {% endform %}
      </div>
    </div>
  </div>

  <!-- bottom -->
  <div class="lock__bottom">
    <span>{{ section.settings.legal | default: '© Supersymmetry UAB · 2026 · Vilnius' }}</span>
    <div class="lock__social">
      <a href="{{ settings.social_instagram | default: '#' }}" class="uline">Instagram</a>
      <a href="/blogs/zurnalas" class="uline">Žurnalas</a>
      <a href="/pages/kontaktai" class="uline">Kontaktai</a>
    </div>
    <details class="lock__staff">
      <summary>{{ section.settings.staff_label | default: 'Personalui — įeiti su slaptažodžiu' }}</summary>
      {% form 'storefront_password', class: 'lock__form', id: 'staff', style: 'margin-top:16px;max-width:380px' %}
        <div class="lock__formlabel">{{ section.settings.staff_form_label | default: 'Parduotuvės slaptažodis' }}</div>
        <div class="lock__field">
          <input type="password" name="password" placeholder="••••••" aria-label="{{ 'accessibility.password' | t }}" />
          <button type="submit">{{ section.settings.staff_button | default: 'Įeiti' }}</button>
        </div>
        <div class="lock__error" id="staffErr"></div>
        {%- if section.settings.staff_hint != blank -%}
        <div class="lock__hint" style="opacity:.6">{{ section.settings.staff_hint }}</div>
        {%- endif -%}
      {% endform %}
    </details>
  </div>
</main>
{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "header", "content": "Stamp" },
    { "type": "text", "id": "stamp_1", "label": "Stamp 1", "default": "Pavasaris/Vasara <b>2026</b>" },
    { "type": "text", "id": "stamp_2", "label": "Stamp 2", "default": "Partija <b>04</b>" },
    { "type": "text", "id": "stamp_3", "label": "Stamp 3", "default": "Vilnius · <b>LT</b>" },
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Netrukus atidarome · <b>parduotuvė užrakinta</b>" },
    { "type": "text", "id": "headline_bold", "label": "Headline (bold)", "default": "Pagaminta" },
    { "type": "text", "id": "headline_mute", "label": "Headline (muted)", "default": "vieną" },
    { "type": "text", "id": "headline_rest", "label": "Headline (rest)", "default": "kartą." },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "Ribota partija odinių porų, siūtų ranka Vilniuje. Palik el. paštą — pranešime pirmiausia." },
    { "type": "text", "id": "launch_datetime", "label": "Launch date & time", "info": "Format: 2026-08-01T10:00 (local time). Drives the countdown; leave empty to hide it. Past dates also hide it." },
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "newsletter_text", "label": "Text", "default": "Pranešime, kai atidarysime — vienas laiškas, jokio marketingo." },
    { "type": "text", "id": "newsletter_placeholder", "label": "Placeholder", "default": "Jūsų el. paštas" },
    { "type": "text", "id": "newsletter_button", "label": "Button", "default": "Pranešti man" },
    { "type": "header", "content": "Bottom" },
    { "type": "text", "id": "legal", "label": "Legal line", "default": "© Supersymmetry UAB · 2026 · Vilnius" },
    { "type": "text", "id": "staff_label", "label": "Staff toggle label", "default": "Personalui — įeiti su slaptažodžiu" },
    { "type": "text", "id": "staff_form_label", "label": "Staff form label", "default": "Parduotuvės slaptažodis" },
    { "type": "text", "id": "staff_button", "label": "Staff button", "default": "Įeiti" },
    { "type": "text", "id": "staff_hint", "label": "Staff hint", "info": "Shown under the staff password form. NEVER put the real password here. Empty hides it." }
  ]
}
{% endschema %}
