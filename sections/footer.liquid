<footer class="foot">
{%- if section.settings.tagline != blank -%}
  <div class="foot__head">
    <div class="foot__tag">{{ section.settings.tagline }}</div>
  </div>
{%- endif -%}
  <div class="foot__cols">
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        <div class="foot__col" {{ block.shopify_attributes }}>
          <h2>{{ block.settings.heading }}</h2>
          <ul>
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="foot__legal">
    <span>{{ section.settings.legal_left }}<span class="u-desktop"> · {{ section.settings.legal_left_desktop }}</span></span>
    <span class="foot__policies">
      {%- assign privacy_url = shop.privacy_policy.url -%}
      {%- assign terms_url = shop.terms_of_service.url -%}
      {%- if privacy_url != blank -%}<a href="{{ privacy_url }}">{{ section.settings.legal_privacy | default: 'Privatumas' }}</a>{%- else -%}{{ section.settings.legal_privacy | default: 'Privatumas' }}{%- endif -%}
      {{- ' · ' -}}
      {%- if terms_url != blank -%}<a href="{{ terms_url }}">{{ section.settings.legal_terms | default: 'Sąlygos' }}</a>{%- else -%}{{ section.settings.legal_terms | default: 'Sąlygos' }}{%- endif -%}
      {{- ' · ' -}}
      {%- if section.settings.requisites_url != blank -%}<a href="{{ section.settings.requisites_url }}">{{ section.settings.legal_requisites | default: 'Rekvizitai' }}</a>{%- else -%}{{ section.settings.legal_requisites | default: 'Rekvizitai' }}{%- endif -%}
    </span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Maža ateljė Vilniuje, gaminanti po vieną sportbatį, vieną batą, vieną krepšį — nuo 2019 metų."
    },
    { "type": "header", "content": "Legal" },
    {
      "type": "text",
      "id": "legal_left",
      "label": "Legal left",
      "default": "© Supersymmetry UAB · 2026"
    },
    {
      "type": "text",
      "id": "legal_left_desktop",
      "label": "Legal left (desktop suffix)",
      "default": "PVM LT100012345678"
    },
    { "type": "text", "id": "legal_privacy", "label": "Privacy label", "default": "Privatumas" },
    { "type": "text", "id": "legal_terms", "label": "Terms label", "default": "Sąlygos" },
    { "type": "text", "id": "legal_requisites", "label": "Requisites label", "default": "Rekvizitai" },
    { "type": "url", "id": "requisites_url", "label": "Requisites page", "info": "Privacy & Terms link to your Shopify policies automatically once published (Settings → Policies)." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Pirkti" } },
        { "type": "menu", "settings": { "heading": "Paslaugos" } },
        { "type": "menu", "settings": { "heading": "Apie ateljė" } }
      ]
    }
  ]
}
{% endschema %}
