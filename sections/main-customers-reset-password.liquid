{{ 'section-customers.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}

<div class="acct acct--narrow">
  <div class="acct__head">
    <div class="eyebrow-rule">{{ section.settings.eyebrow | default: 'Paskyra · <b>naujas slaptažodis</b>' }}</div>
    <h1 class="acct__title"><span class="light">{{ section.settings.title_light | default: 'Naujas' }}</span> {{ section.settings.title | default: 'slaptažodis.' }}</h1>
    <p class="acct__sub">{{ section.settings.sub | default: 'Sukurk naują slaptažodį paskyrai' }} {%- if email %} <b>{{ email }}</b>{%- endif -%}.</p>
  </div>

  {% form 'reset_customer_password', class: 'form' %}
    {%- if form.errors -%}
    <div class="acct-errors" role="alert">{{ form.errors | default_errors }}</div>
    {%- endif -%}
    <div class="field">
      <label for="resetPassword">{{ 'customer.password_new' | t }}</label>
      <input id="resetPassword" type="password" name="customer[password]" autocomplete="new-password" placeholder="{{ 'customer.password_min' | t }}" minlength="5" required />
    </div>
    <div class="field">
      <label for="resetPasswordConfirm">{{ 'customer.password_repeat' | t }}</label>
      <input id="resetPasswordConfirm" type="password" name="customer[password_confirmation]" autocomplete="new-password" placeholder="••••••••" minlength="5" required />
    </div>
    <button class="btn btn--primary btn--lg" type="submit">{{ section.settings.submit_label | default: 'Išsaugoti slaptažodį' }} <span class="btn__arrow">→</span></button>
  {% endform %}
</div>

{% schema %}
{
  "name": "Reset password",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Paskyra · <b>naujas slaptažodis</b>" },
    { "type": "text", "id": "title_light", "label": "Title (light part)", "default": "Naujas" },
    { "type": "text", "id": "title", "label": "Title (bold part)", "default": "slaptažodis." },
    { "type": "text", "id": "sub", "label": "Sub (the account email is appended)", "default": "Sukurk naują slaptažodį paskyrai" },
    { "type": "text", "id": "submit_label", "label": "Submit button", "default": "Išsaugoti slaptažodį" },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ]
}
{% endschema %}
