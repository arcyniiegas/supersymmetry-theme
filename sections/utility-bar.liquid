<div class="utility">
  <div class="utility__left">
    <span><span class="utility__dot"></span>{{ section.settings.left_text }}<span class="u-desktop"> · {{ section.settings.left_text_desktop }}</span></span>
  </div>
  <div class="utility__right">
    <span class="u-mobile">{{ section.settings.right_text_mobile }}</span>
    <span class="u-desktop">{{ section.settings.right_text_desktop }}</span>
  </div>
</div>

{% schema %}
{
  "name": "Utility bar",
  "settings": [
    {
      "type": "text",
      "id": "left_text",
      "label": "Left text",
      "default": "Parduotuvė atidaryta"
    },
    {
      "type": "text",
      "id": "left_text_desktop",
      "label": "Left text (desktop suffix)",
      "default": "siunčiame iš Vilniaus"
    },
    {
      "type": "text",
      "id": "right_text_mobile",
      "label": "Right text (mobile)",
      "default": "Pristatymas nuo <b>100€</b>"
    },
    {
      "type": "text",
      "id": "right_text_desktop",
      "label": "Right text (desktop)",
      "default": "LT · EN"
    }
  ]
}
{% endschema %}
