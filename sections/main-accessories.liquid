{{ 'section-accessories.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}
<!-- ──────────── BREADCRUMBS ──────────── -->
<nav class="crumbs" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Pradžia</a>
  <span class="sep">/</span>
  <b>{{ collection.title | default: 'Aksesuarai' }}</b>
</nav>

<!-- ──────────── PAGE HEAD ──────────── -->
<section class="phead">
  <div>
    <h1 class="phead__title">
      <span class="light">{{ section.settings.title_light }}</span>
      {{ section.settings.title }}
    </h1>
  </div>
</section>

<!-- ──────────── TRUST STRIP ──────────── -->
<div class="assure" aria-label="Pirkimo sąlygos">
  <span>{{ section.settings.assure_1_prefix | default: 'Nemokamas pristatymas nuo' }} <b>{{ settings.free_shipping_threshold | default: 100 }} €</b></span>
  <span class="sep" aria-hidden="true"></span>
  <span>{{ section.settings.assure_2 | default: '<b>14 dienų</b> grąžinimas' }}</span>
  <span class="sep" aria-hidden="true"></span>
  <span>{{ section.settings.assure_3 }}</span>
</div>

<!-- ──────────── CATEGORY CHIPS ──────────── -->
{%- if section.blocks.size > 0 -%}
<div class="cats" role="group" aria-label="Kategorijos">
  <button class="cat is-active" type="button" data-cat="all">Viskas <span class="n">{{ collection.products.size }}</span></button>
  {%- for block in section.blocks -%}
    {%- liquid
      assign tagcount = 0
      for p in collection.products
        if p.tags contains block.settings.tag
          assign tagcount = tagcount | plus: 1
        endif
      endfor
    -%}
    <button class="cat" type="button" data-cat="{{ block.settings.tag }}"{% if tagcount == 0 %} disabled data-disabled="true" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.label }} <span class="n">{{ tagcount }}</span></button>
  {%- endfor -%}
</div>
{%- endif -%}

<!-- ──────────── GRID ──────────── -->
<section class="acc-grid" id="accGrid" aria-label="Aksesuarai">
{% if collection.products.size > 0 %}
{% for product in collection.products %}
  {%- assign cat = '' -%}
  {%- for block in section.blocks -%}
    {%- if product.tags contains block.settings.tag -%}{%- assign cat = block.settings.tag -%}{%- break -%}{%- endif -%}
  {%- endfor -%}
  <div class="card" data-cat="{{ cat }}">
    <div class="card__media">
      {% if product.featured_image %}<img src="{{ product.featured_image | image_url: width: 800 }}" srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w" sizes="(max-width: 460px) 100vw, (max-width: 760px) 50vw, (max-width: 1100px) 33vw, 25vw" width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" />{% endif %}
      {% if product.tags contains 'Perkamiausia' %}<span class="card__tag card__tag--ink">Perkamiausia</span>{% endif %}
      <div class="qadd">
        {% if product.variants.size > 1 %}
        <button class="qadd__btn" type="button" data-add>Į krepšelį · {{ product.price | money | remove: '€' | remove: ',00' }}</button>
        <div class="qadd__sizes" role="group" aria-label="Dydis" style="grid-template-columns: repeat({{ product.variants.size }}, 1fr)">
          {% for variant in product.variants %}
          <button class="qadd__size" type="button" data-variant-id="{{ variant.id }}"{% unless variant.available %} disabled{% endunless %}>{{ variant.title }}</button>
          {% endfor %}
        </div>
        {% else %}
        <button class="qadd__btn" type="button" data-add data-variant-id="{{ product.variants.first.id }}">Į krepšelį · {{ product.price | money | remove: '€' | remove: ',00' }}</button>
        {% endif %}
      </div>
    </div>
    <div class="card__body">
      {% unless product.available %}<span class="stock stock--low">Išparduota</span>{% endunless %}
      <span class="card__price">{{ product.price | money | remove: '€' | remove: ',00' }}</span>
    </div>
  </div>
{% endfor %}
{% else %}
  <div class="card" data-cat="">
    <div class="card__body">
      <div>
        <div class="card__name">{{ section.settings.empty_title }}</div>
        <span class="card__sub">{{ section.settings.empty_text }}</span>
      </div>
    </div>
  </div>
{% endif %}
</section>

<!-- ──────────── SIZE REASSURANCE ──────────── -->
<section class="sizehint">
  <div class="sizehint__row">
    <span>{{ section.settings.sizehint }}</span>
    <a class="uline" href="{{ pages['dydziu-lentele'].url | default: routes.root_url }}">{{ section.settings.sizehint_link_label }}</a>
  </div>
</section>

<!-- ──────────── NOTE ──────────── -->
<section class="acc-note">
  <div class="acc-note__plate">
    <div>
      <h2><span style="font-weight:300">{{ section.settings.note_title_light }}</span> <b>{{ section.settings.note_title }}</b></h2>
      <p>{{ section.settings.note_text }}</p>
    </div>
    <a href="{{ pages['apie-mus'].url | default: routes.root_url }}" class="btn btn--secondary" style="background:#FFFFFF;">{{ section.settings.note_cta }}</a>
  </div>
</section>
<script src="{{ 'accessories.js' | asset_url }}" defer></script>
{% schema %}
{
  "name": "Accessories",
  "settings": [
    { "type": "text", "id": "title_light", "label": "Title (light part)", "default": "Prie porų —" },
    { "type": "text", "id": "title", "label": "Title", "default": "aksesuarai." },
    { "type": "text", "id": "assure_1_prefix", "label": "Trust line 1 prefix", "info": "The free-shipping threshold from Theme settings is appended.", "default": "Nemokamas pristatymas nuo" },
    { "type": "text", "id": "assure_2", "label": "Trust line 2", "default": "<b>14 dienų</b> grąžinimas" },
    { "type": "text", "id": "assure_3", "label": "Trust line 3", "default": "Išsiunčiame per <b>1—2 d. d.</b> iš Vilniaus" },
    { "type": "text", "id": "empty_title", "label": "Empty state title", "default": "Kolekcija ruošiama" },
    { "type": "text", "id": "empty_text", "label": "Empty state text", "default": "Aksesuarai grįžta netrukus — užsukite po kelių dienų." },
    { "type": "text", "id": "sizehint", "label": "Size hint", "default": "Nežinote pirštinių ar kepurės dydžio? <b>Išmatuokite per minutę</b> — arba parašykite, parinksime." },
    { "type": "text", "id": "sizehint_link_label", "label": "Size hint link label", "default": "Dydžių gidas" },
    { "type": "text", "id": "note_title_light", "label": "Note title (light)", "default": "Ta pati oda," },
    { "type": "text", "id": "note_title", "label": "Note title (bold)", "default": "tos pačios rankos." },
    { "type": "textarea", "id": "note_text", "label": "Note text", "default": "Odiniai aksesuarai kerpami iš tų pačių partijų kaip ir avalynė — likučiai neišmetami, o tampa pirštinėmis ir rankinėmis. Vilna ir acetatas — iš tų pačių Europos tiekėjų, pas kuriuos važiuojame patys." },
    { "type": "text", "id": "note_cta", "label": "Note button label", "default": "Apie ateljė" },
    { "type": "header", "content": "Text" },
    { "type": "range", "id": "title_scale", "label": "Heading size", "min": 60, "max": 130, "step": 5, "unit": "%", "default": 100 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Category chip",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "tag", "label": "Product tag to match" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Accessories",
      "blocks": [
        { "type": "chip", "settings": { "label": "Akiniai nuo saulės", "tag": "akiniai" } },
        { "type": "chip", "settings": { "label": "Kepurės", "tag": "kepures" } },
        { "type": "chip", "settings": { "label": "Šalikai", "tag": "salikai" } },
        { "type": "chip", "settings": { "label": "Pirštinės", "tag": "pirstines" } },
        { "type": "chip", "settings": { "label": "Rankinės", "tag": "rankines" } }
      ]
    }
  ]
}
{% endschema %}
