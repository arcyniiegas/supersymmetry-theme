{{ 'section-dydziu-lentele.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}
<!-- ──────────── BREADCRUMBS ──────────── -->
{%- assign crumb_parent = section.settings.crumb_parent | default: 'Paslaugos' -%}
{%- assign crumb_current = section.settings.crumb_current | default: 'Dydžių lentelė' -%}
{% render 'breadcrumbs', parent_label: crumb_parent, parent_url: pages.duk.url, current: crumb_current %}

<!-- ──────────── PAGE HEAD ──────────── -->
{%- assign stat_blocks = section.blocks | where: 'type', 'stat' -%}
{%- assign has_aside = false -%}
{%- if section.settings.intro != blank or stat_blocks.size > 0 -%}{%- assign has_aside = true -%}{%- endif -%}
<section class="phead{% unless has_aside %} phead--solo{% endunless %}">
  <div>
    <h1 class="phead__title">
      <span class="light">{{ section.settings.title_light | default: 'Dydžių' }}</span>
      {{ section.settings.title | default: 'lentelė.' }}
    </h1>
  </div>
  {%- if has_aside -%}
  <div class="phead__aside">
    {%- if section.settings.intro != blank -%}
    <p class="phead__intro">{{ section.settings.intro }}</p>
    {%- endif -%}
    {%- if stat_blocks.size > 0 -%}
    <div class="phead__stats">
      {%- for block in stat_blocks -%}
      {% render 'stat', k: block.settings.label, v: block.settings.value, tabular: block.settings.tabular, attrs: block.shopify_attributes %}
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>
  {%- endif -%}
</section>

<!-- ──────────── SIZES ──────────── -->
<section class="sizes">

  <div class="sizetable">
    <table>
      <thead>
        <tr>
          <th scope="col">{{ section.settings.th_1 | default: 'EU' }}</th>
          <th scope="col">{{ section.settings.th_2 | default: 'Pėdos ilgis' }}</th>
        </tr>
      </thead>
      <tbody>
        {%- assign row_blocks = section.blocks | where: 'type', 'row' -%}
        {%- if row_blocks.size > 0 -%}
          {%- for block in row_blocks -%}
        <tr {{ block.shopify_attributes }}><td class="eu">{{ block.settings.eu }}</td><td>{{ block.settings.cm }}</td></tr>
          {%- endfor -%}
        {%- else -%}
        <tr><td class="eu">36</td><td>22,8 cm</td></tr>
        <tr><td class="eu">37</td><td>23,5 cm</td></tr>
        <tr><td class="eu">38</td><td>24,1 cm</td></tr>
        <tr><td class="eu">39</td><td>24,8 cm</td></tr>
        <tr><td class="eu">40</td><td>25,4 cm</td></tr>
        <tr><td class="eu">41</td><td>26,0 cm</td></tr>
        <tr><td class="eu">42</td><td>26,7 cm</td></tr>
        <tr><td class="eu">43</td><td>27,3 cm</td></tr>
        {%- endif -%}
      </tbody>
    </table>
    <p class="sizetable__note">{{ section.settings.table_note | default: 'Jei jūsų matmuo tarp dviejų dydžių — rinkitės didesnį: oda prisitaikys per plotį, bet ne per ilgį.' }}</p>
  </div>

  <div class="measure">
    <div class="measure__panel">
      <div class="eyebrow-rule">{{ section.settings.measure_eyebrow | default: 'Kaip išmatuoti pėdą' }}</div>
      {%- assign mstep_blocks = section.blocks | where: 'type', 'step' -%}
      {%- if mstep_blocks.size > 0 -%}
        {%- for block in mstep_blocks -%}
      {% render 'step', num: block.settings.num, title: block.settings.title, body: block.settings.body, attrs: block.shopify_attributes %}
        {%- endfor -%}
      {%- else -%}
      <div class="step">
        <span class="step__num">01</span>
        <div class="step__body">
          <h3>Matuokite vakare</h3>
          <p>Pėda dienos pabaigoje būna ilgiausia. Atsistokite ant popieriaus lapo prie sienos, kulnas — prie pat sienos.</p>
        </div>
      </div>
      <div class="step">
        <span class="step__num">02</span>
        <div class="step__body">
          <h3>Apibrėžkite pėdą</h3>
          <p>Pieštuką laikykite vertikaliai ir pažymėkite ilgiausio piršto tašką. Kartokite su kita pėda — jos beveik visada skiriasi.</p>
        </div>
      </div>
      <div class="step">
        <span class="step__num">03</span>
        <div class="step__body">
          <h3>Išmatuokite ilgį</h3>
          <p>Atstumas nuo lapo krašto iki žymos — jūsų pėdos ilgis. Lentelėje rinkitės pagal ilgesnę pėdą.</p>
        </div>
      </div>
      {%- endif -%}
    </div>

    <div class="measure__tip">
      <span class="k">{{ section.settings.tip_k | default: 'Nesate tikra?' }}</span>
      <p>{{ section.settings.tip_b | default: 'Parašykite mums pėdos ilgį centimetrais — atsakysime, kuris dydis tiks konkrečiam modeliui.' }}</p>
    </div>
  </div>

</section>
{% schema %}
{
  "name": "Dydžių lentelė",
  "settings": [
    { "type": "header", "content": "Head" },
    { "type": "text", "id": "crumb_parent", "label": "Breadcrumb parent", "default": "Paslaugos" },
    { "type": "text", "id": "crumb_current", "label": "Breadcrumb current", "default": "Dydžių lentelė" },
    { "type": "text", "id": "title_light", "label": "Title (light part)", "default": "Dydžių" },
    { "type": "text", "id": "title", "label": "Title (bold part)", "default": "lentelė." },
    { "type": "textarea", "id": "intro", "label": "Intro", "info": "Optional lead paragraph beside the title. Leave empty to hide." },
    { "type": "header", "content": "Table" },
    { "type": "text", "id": "th_1", "label": "Column 1 header", "default": "EU" },
    { "type": "text", "id": "th_2", "label": "Column 2 header", "default": "Pėdos ilgis" },
    { "type": "textarea", "id": "table_note", "label": "Table note", "default": "Jei jūsų matmuo tarp dviejų dydžių — rinkitės didesnį: oda prisitaikys per plotį, bet ne per ilgį." },
    { "type": "header", "content": "Measuring" },
    { "type": "text", "id": "measure_eyebrow", "label": "Eyebrow", "default": "Kaip išmatuoti pėdą" },
    { "type": "text", "id": "tip_k", "label": "Tip kicker", "default": "Nesate tikra?" },
    { "type": "textarea", "id": "tip_b", "label": "Tip body", "default": "Parašykite mums pėdos ilgį centimetrais — atsakysime, kuris dydis tiks konkrečiam modeliui." },
    { "type": "header", "content": "Text size & colour" },
    { "type": "range", "id": "title_scale", "label": "Heading size", "min": 60, "max": 130, "step": 5, "unit": "%", "default": 100 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Head stat",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "value", "label": "Value" },
        { "type": "checkbox", "id": "tabular", "label": "Tabular numerals", "default": false }
      ]
    },
    {
      "type": "row",
      "name": "Size row",
      "settings": [
        { "type": "text", "id": "eu", "label": "EU" },
        { "type": "text", "id": "cm", "label": "Pėdos ilgis" }
      ]
    },
    {
      "type": "step",
      "name": "Measuring step",
      "settings": [
        { "type": "text", "id": "num", "label": "Number" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [{ "name": "Dydžių lentelė" }]
}
{% endschema %}
