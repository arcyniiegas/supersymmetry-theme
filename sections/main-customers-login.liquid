{{ 'section-customers.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}

<div class="acct acct--narrow">

  <!-- ──────────── LOGIN ──────────── -->
  <div id="loginPane">
    <div class="acct__head">
      <div class="eyebrow-rule">{{ section.settings.eyebrow | default: 'Paskyra · <b>prisijungimas</b>' }}</div>
      <h1 class="acct__title"><span class="light">{{ section.settings.title_light | default: 'Sveiki' }}</span> {{ section.settings.title | default: 'sugrįžę.' }}</h1>
      <p class="acct__sub">{{ section.settings.sub | default: 'Prisijunk, kad matytum užsakymus, adresus ir greitesnį atsiskaitymą.' }}</p>
    </div>

    {% form 'customer_login', class: 'form' %}
      {%- if form.errors -%}
      <div class="acct-errors" role="alert">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="field">
        <label for="loginEmail">El. paštas</label>
        <input id="loginEmail" type="email" name="customer[email]" autocomplete="email" placeholder="vardas@pavarde.lt" required />
      </div>
      <div class="field">
        <label for="loginPassword">Slaptažodis</label>
        <input id="loginPassword" type="password" name="customer[password]" autocomplete="current-password" placeholder="••••••••" required />
      </div>
      <button class="btn btn--primary btn--lg" type="submit">{{ section.settings.submit_label | default: 'Prisijungti' }} <span class="btn__arrow">→</span></button>
    {% endform %}

    <div class="acct-alt">
      <a href="#recover" data-recover-open>{{ section.settings.recover_link | default: 'Pamiršai slaptažodį?' }}</a>
      <a href="{{ routes.account_register_url }}">{{ section.settings.register_link | default: 'Sukurti paskyrą' }}</a>
    </div>
  </div>

  <!-- ──────────── RECOVER ──────────── -->
  <div id="recoverPane" hidden>
    <div class="acct__head">
      <div class="eyebrow-rule">{{ section.settings.recover_eyebrow | default: 'Paskyra · <b>slaptažodžio atkūrimas</b>' }}</div>
      <h1 class="acct__title"><span class="light">{{ section.settings.recover_title_light | default: 'Atkurti' }}</span> {{ section.settings.recover_title | default: 'slaptažodį.' }}</h1>
      <p class="acct__sub">{{ section.settings.recover_sub | default: 'Įvesk el. paštą — atsiųsime nuorodą naujam slaptažodžiui susikurti.' }}</p>
    </div>

    {%- if recover_success -%}
    <p class="acct-notice" role="status">{{ section.settings.recover_success | default: 'Išsiuntėme laišką su atkūrimo nuoroda — patikrink pašto dėžutę.' }}</p>
    {%- else -%}
    {% form 'recover_customer_password', class: 'form' %}
      {%- if form.errors -%}
      <div class="acct-errors" role="alert">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="field">
        <label for="recoverEmail">El. paštas</label>
        <input id="recoverEmail" type="email" name="email" autocomplete="email" placeholder="vardas@pavarde.lt" required />
      </div>
      <button class="btn btn--primary btn--lg" type="submit">{{ section.settings.recover_submit | default: 'Siųsti nuorodą' }} <span class="btn__arrow">→</span></button>
    {% endform %}
    {%- endif -%}

    <div class="acct-alt">
      <a href="#" data-recover-close>{{ section.settings.back_link | default: '← Grįžti į prisijungimą' }}</a>
    </div>
  </div>

</div>

<script>
  (function(){
    var login = document.getElementById('loginPane');
    var recover = document.getElementById('recoverPane');
    function show(rec){
      login.hidden = rec; recover.hidden = !rec;
      var input = document.getElementById(rec ? 'recoverEmail' : 'loginEmail');
      if (input) input.focus({ preventScroll: true });
    }
    document.querySelectorAll('[data-recover-open]').forEach(function(a){
      a.addEventListener('click', function(e){ e.preventDefault(); history.replaceState(null, '', '#recover'); show(true); });
    });
    document.querySelectorAll('[data-recover-close]').forEach(function(a){
      a.addEventListener('click', function(e){ e.preventDefault(); history.replaceState(null, '', location.pathname); show(false); });
    });
    // Deep link (#recover) and the reset-email-sent redirect both open the pane
    if (location.hash === '#recover' || {{ recover_success | default: false | json }}) show(true);
  })();
</script>

{% schema %}
{
  "name": "Login",
  "settings": [
    { "type": "header", "content": "Login" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Paskyra · <b>prisijungimas</b>" },
    { "type": "text", "id": "title_light", "label": "Title (light part)", "default": "Sveiki" },
    { "type": "text", "id": "title", "label": "Title (bold part)", "default": "sugrįžę." },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "Prisijunk, kad matytum užsakymus, adresus ir greitesnį atsiskaitymą." },
    { "type": "text", "id": "submit_label", "label": "Submit button", "default": "Prisijungti" },
    { "type": "text", "id": "recover_link", "label": "Recover link label", "default": "Pamiršai slaptažodį?" },
    { "type": "text", "id": "register_link", "label": "Register link label", "default": "Sukurti paskyrą" },
    { "type": "header", "content": "Password recovery" },
    { "type": "text", "id": "recover_eyebrow", "label": "Eyebrow", "default": "Paskyra · <b>slaptažodžio atkūrimas</b>" },
    { "type": "text", "id": "recover_title_light", "label": "Title (light part)", "default": "Atkurti" },
    { "type": "text", "id": "recover_title", "label": "Title (bold part)", "default": "slaptažodį." },
    { "type": "textarea", "id": "recover_sub", "label": "Sub", "default": "Įvesk el. paštą — atsiųsime nuorodą naujam slaptažodžiui susikurti." },
    { "type": "text", "id": "recover_submit", "label": "Submit button", "default": "Siųsti nuorodą" },
    { "type": "text", "id": "recover_success", "label": "Success notice", "default": "Išsiuntėme laišką su atkūrimo nuoroda — patikrink pašto dėžutę." },
    { "type": "text", "id": "back_link", "label": "Back link label", "default": "← Grįžti į prisijungimą" },
    { "type": "header", "content": "Text" },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ]
}
{% endschema %}
