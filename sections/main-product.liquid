        { "type": "text", "id": "title", "label": "Title", "default": "Apie gamintoją" },
        { "type": "text", "id": "lede", "label": "Lede", "default": "Mūsų žodžiais" }
      ]
    },
    {
      "type": "care", "name": "Doc — Care", "limit": 1,
      "settings": [
        { "type": "text", "id": "num", "label": "Number line", "default": "03 — Priežiūra" },
        { "type": "text", "id": "title", "label": "Title", "default": "Išlaikykite juos kaip naujus." },
        { "type": "text", "id": "lede", "label": "Lede", "default": "Keturi įpročiai, šešiasdešimties dienų ritmas, dvidešimt sezonų dėvėjimo." }
      ]
    },
    {
      "type": "reviews", "name": "Reviews header", "limit": 1,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "04 — Atsiliepimai" },
        { "type": "text", "id": "score", "label": "Score (leave empty until you have real reviews)" },
        { "type": "text", "id": "count_line", "label": "Count line (real data only, e.g. \"12 patvirtinti pirkimai\")" },
        { "type": "textarea", "id": "brief", "label": "Summary", "default": "Dažniausiai giriama: <b>oda prisitaiko per 2–3 sav.</b>, <b>keičiami padai</b>, <b>numeruota partija</b>." },
        { "type": "text", "id": "toggle_label", "label": "Toggle label", "default": "Skaityti atsiliepimus" }
