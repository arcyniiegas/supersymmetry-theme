        { "type": "text", "id": "price_sub", "label": "Price sub-text" },
        { "type": "text", "id": "maker_sub", "label": "Maker sub-text" },
        { "type": "text", "id": "weight_sub", "label": "Weight sub-text" },
        { "type": "text", "id": "origin_sub", "label": "Origin sub-text" }
      ]
    },
    {
      "type": "spec", "name": "Doc — Specification", "limit": 1,
