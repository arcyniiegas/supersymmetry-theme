{{ 'section-product.css' | asset_url | stylesheet_tag }}
{% render 'structured-data-product' %}
{% render 'section-appearance', section: section %}
{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign buybar_price = product.price | money | remove: '€' | remove: ',00'
  assign buybar_compare = ''
  if product.compare_at_price and product.compare_at_price > product.price
    assign buybar_compare = product.compare_at_price | money | remove: '€' | remove: ',00'
  endif
  assign crumb_collection = product.collections.first
-%}

<!-- ──────────── CROSSBAR ──────────── -->
<div class="crossbar">
  <div class="crumb">
    <a href="{{ crumb_collection.url | default: routes.all_products_collection_url }}">{{ crumb_collection.title | default: 'Avalynė' }}</a>
    <span class="sep">/</span>
    {%- if product.type != blank -%}
      <a href="{{ routes.all_products_collection_url }}">{{ product.type }}</a>
      <span class="sep">/</span>
    {%- endif -%}
    <b>{{ product.title }}</b>
  </div>
  <div class="crossbar__right">
    <span></span>
    <span></span>
  </div>
</div>

<!-- ──────────── PRODUCT — sticky split ──────────── -->
<main class="product"
  data-product-title="{{ product.title | escape }}"
  data-price="{{ buybar_price | escape }}"
  data-compare="{{ buybar_compare | escape }}"
  data-current-size="{{ current_variant.title | split: ' (' | first | strip | escape }}">

  <!-- GALLERY -->
  <section class="gallery" aria-label="Produkto galerija">
{%- if product.media.size > 0 -%}
{%- for media in product.media -%}
    <figure class="shot {% cycle 'shot--portrait', 'shot--square', 'shot--landscape' %}">
      <img class="shot__img" src="{{ media | image_url: width: 1400 }}" srcset="{{ media | image_url: width: 700 }} 700w, {{ media | image_url: width: 1400 }} 1400w" sizes="(max-width: 960px) 100vw, 60vw" width="{{ media.preview_image.width | default: 1400 }}" height="{{ media.preview_image.height | default: 1400 }}" alt="{% if media.alt != blank and media.alt != product.title %}{{ media.alt | escape }}{% else %}{{ product.title | escape }} — vaizdas {{ forloop.index }} iš {{ product.media.size }}{% endif %}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"/>
{%- if forloop.first %}
      <button class="shot__zoom" type="button" aria-label="Padidinti">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6"/><path d="M16 16 L21 21"/><path d="M8 11 H14 M11 8 V14"/></svg>
      </button>
{%- endif %}
    </figure>
{%- endfor -%}
{%- else -%}
    <figure class="shot shot--portrait">
      <img class="shot__img" src="{{ 'Nr1-0c6678ce.webp' | asset_url }}" width="1400" height="1400" alt="Šoninis profilis" loading="eager"/>
      <button class="shot__zoom" type="button" aria-label="Padidinti">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6"/><path d="M16 16 L21 21"/><path d="M8 11 H14 M11 8 V14"/></svg>
      </button>
    </figure>

    <figure class="shot shot--square">
      <img class="shot__img" src="{{ 'Nr2-65b64fb1.webp' | asset_url }}" width="1400" height="1400" alt="Pora iš viršaus" loading="lazy"/>
    </figure>

    <figure class="shot shot--landscape">
      <img class="shot__img" src="{{ 'Nr3-0f817725.webp' | asset_url }}" width="1400" height="1400" alt="Trijų ketvirčių kampu" loading="lazy"/>
    </figure>
{%- endif -%}

  </section>

  <div class="gallery-dots" role="group" aria-label="Galerijos nuotraukos">
{%- if product.media.size > 0 -%}
{%- for media in product.media -%}
    <button type="button" aria-current="{% if forloop.first %}true{% else %}false{% endif %}" aria-label="{{ forloop.index }} nuotrauka"></button>
{%- endfor -%}
{%- else -%}
    <button type="button" aria-current="true" aria-label="1 nuotrauka"></button>
    <button type="button" aria-current="false" aria-label="2 nuotrauka"></button>
    <button type="button" aria-current="false" aria-label="3 nuotrauka"></button>
{%- endif -%}
  </div>

  <!-- INFO STICKY -->
  <aside class="info">
    <div class="info__head">
      <h1 class="info__name">
        <span>{{ product.title }}</span>
      </h1>
      <span class="info__sep" aria-hidden="true">·</span>
      {% render 'price', product: product %}
    </div>

    {%- if product.description != blank -%}
    <div class="info__desc">{{ product.description }}</div>
    {%- endif -%}

    <div class="sizeblock">
      <div class="sizes" role="radiogroup" aria-label="Dydis EU">
{%- if product.variants.size > 0 and product.has_only_default_variant == false -%}
{%- for variant in product.variants -%}
{%- assign size_eu = variant.title | split: ' (' | first | strip -%}
{%- assign size_cm = '' -%}
{%- if variant.title contains ' (' -%}
{%- assign size_cm = variant.title | split: ' (' | last | remove: ')' | replace: 'cm', ' cm' | strip -%}
{%- endif -%}
        <button class="size{% if variant.id == current_variant.id %} is-selected{% endif %}" role="radio" aria-checked="{% if variant.id == current_variant.id %}true{% else %}false{% endif %}" data-variant-id="{{ variant.id }}" data-variant-price="{{ variant.price | money | remove: '€' | remove: ',00' }}"{% if variant.compare_at_price > variant.price %} data-variant-compare="{{ variant.compare_at_price | money | remove: '€' | remove: ',00' }}"{% endif %} data-variant-available="{{ variant.available }}"{% if variant.inventory_management != blank %} data-variant-qty="{{ variant.inventory_quantity }}"{% endif %}{% unless variant.available %} disabled aria-label="{{ variant.title | escape }} — išparduota"{% endunless %}><span class="size__eu">{{ size_eu }}</span>{% if size_cm != blank %}<span class="size__cm">{{ size_cm }}</span>{% endif %}</button>
{%- endfor -%}
{%- else -%}
        <button class="size is-selected" role="radio" aria-checked="true"><span class="size__eu">{{ current_variant.title | default: 'Vienas dydis' }}</span></button>
{%- endif -%}
      </div>
      <p class="sizes-note" data-sizes-note aria-live="polite"{% unless current_variant.available and current_variant.inventory_management != blank and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 5 %} hidden{% endunless %}>{%- if current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 5 -%}Liko {{ current_variant.inventory_quantity }} vnt.{%- endif -%}</p>
      {%- if product.metafields.custom.stock_line != blank -%}
      <div class="stock">
        <span class="stock__dot"></span>
        <span>{{ product.metafields.custom.stock_line }}</span>
      </div>
      {%- endif -%}
    </div>

    {%- comment -%} The form carries an explicit id ATTRIBUTE for selection via
      getAttribute('id'). NOTE: the form.id IDL property still resolves to the
      name="id" input below (HTMLFormElement's named getter is
      [LegacyOverrideBuiltIns]) — that clobbering is unavoidable because Shopify's
      /cart/add requires name="id". Never read form.id in JS; use
      form.getAttribute('id') or querySelector('[name="id"]'). {%- endcomment -%}
    {%- assign product_form_id = 'ProductForm-' | append: section.id -%}
    {% form 'product', product, id: product_form_id %}
    <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-id>
    <div class="ctas">
      <button class="btn btn--primary" type="submit" data-atc>
        <span>{{ section.settings.atc_label | default: 'Į krepšelį' }}</span>
        <span class="btn__arrow">→</span>
      </button>
      {%- if section.settings.show_payment_button -%}
      {{ form | payment_button }}
      {%- endif -%}
    </div>
    {% endform %}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
      {%- when 'fit' -%}
    <div class="fit" id="fit-guide" aria-label="Modelio sėdėjimas" {{ block.shopify_attributes }}>
      <div class="fit__head">
        <span class="fit__title"></span>
        <span class="fit__count"></span>
      </div>
      <div class="fit__chart">
        <span class="fit__axis fit__axis--top">Platūs</span>
        <span class="fit__axis fit__axis--left">Mažesni</span>
        <span class="fit__axis fit__axis--right">Didesni</span>
        <span class="fit__axis fit__axis--bottom">Siauri</span>
        <div class="fit__plot">
          <span class="fit__cross fit__cross--h" aria-hidden="true"></span>
          <span class="fit__cross fit__cross--v" aria-hidden="true"></span>
          <span class="fit__anchor" aria-hidden="true"></span>
          <span class="fit__tick fit__tick--x" style="left: {{ product.metafields.fit.dot_x | default: 64 }}%;" aria-hidden="true"></span>
          <span class="fit__tick fit__tick--y" style="top: {{ product.metafields.fit.dot_y | default: 50 }}%;" aria-hidden="true"></span>
          <span class="fit__dot" style="left: {{ product.metafields.fit.dot_x | default: 64 }}%; top: {{ product.metafields.fit.dot_y | default: 50 }}%;" aria-hidden="true"></span>
        </div>
      </div>
      <div class="fit__verdict">
        <b style="text-align: center">{{ product.metafields.fit.verdict | default: 'Šiek tiek didesni · standartinis plotis' }}</b>
        <span class="fit__verdict-sub" style="text-align: center">{% if product.metafields.fit.verdict_sub != blank %}{{ product.metafields.fit.verdict_sub | metafield_tag }}{% else %}Rekomenduojame imti <em>vienu dydžiu mažesnius</em>, jei esate tarp dydžių.{% endif %}</span>
      </div>
      {%- comment -%} Fit stats render only from real metafield data — never
        fabricated defaults (Design Principle 1: faithful over fabricated). {%- endcomment -%}
      {%- if product.metafields.fit.pct_normal != blank or product.metafields.fit.sample_count != blank -%}
      <div class="fit__data">
        {%- if product.metafields.fit.pct_normal != blank -%}
        <span><b>{{ product.metafields.fit.pct_normal }}%</b> ima įprastą dydį</span>
        {%- endif -%}
        {%- if product.metafields.fit.pct_normal != blank and product.metafields.fit.sample_count != blank -%}
        <span class="fit__data-sep" aria-hidden="true"></span>
        {%- endif -%}
        {%- if product.metafields.fit.sample_count != blank -%}
        <span><b>{{ product.metafields.fit.sample_count }}</b> porų grįžtamasis ryšys</span>
        {%- endif -%}
      </div>
      {%- endif -%}
    </div>
      {%- when 'delivery' -%}
    <div class="delivery" {{ block.shopify_attributes }}>
      <div class="delivery__head">
        <span class="delivery__title">{{ block.settings.title }}</span>
      </div>
      <div class="gantt">
{%- if product.metafields.delivery.gantt != blank -%}
{%- for row in product.metafields.delivery.gantt.value -%}
        <div class="gantt__row{% if row.state != blank and row.state != 'future' %} {{ row.state }}{% endif %}">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ row.leg }}</span>
          <span class="gantt__date">{{ row.date }}</span>
        </div>
{%- endfor -%}
{%- else -%}
        <div class="gantt__row done">
          <span class="gantt__node"></span>
          <span class="gantt__leg">Užsakymas pateiktas</span>
          <span class="gantt__date">Pn, 22 geg.</span>
        </div>
        <div class="gantt__row now">
          <span class="gantt__node"></span>
          <span class="gantt__leg">Užsakymas išsiunčiamas</span>
          <span class="gantt__date">Št, 23 geg.</span>
        </div>
        <div class="gantt__row">
          <span class="gantt__node"></span>
          <span class="gantt__leg">Užsakymas kelyje</span>
          <span class="gantt__date">Sk, 24 geg.</span>
        </div>
        <div class="gantt__row">
          <span class="gantt__node"></span>
          <span class="gantt__leg">Pristatymas iki</span>
          <span class="gantt__date">Pr, 25 geg.</span>
        </div>
{%- endif -%}
      </div>
    </div>
      {%- endcase -%}
    {%- endfor -%}

    <div class="promises">
      <span class="promise"></span>
    </div>

  </aside>
</main>

{%- for block in section.blocks -%}
  {%- case block.type -%}
  {%- when 'glance' -%}
<!-- ──────────── TRUMPAI — bento ──────────── -->
<section class="glance" {{ block.shopify_attributes }}>
  <div class="glance__head">
    <div>
      <div class="glance__eyebrow">{{ block.settings.eyebrow }}</div>
    </div>
  </div>

  <div class="bento">

    <div class="bento__cell b-1">
      <div class="bento__label">Medžiaga</div>
      <div>
        <div class="bento__value">{{ product.metafields.glance.material | default: 'Natūrali oda' }}</div>
        {%- if block.settings.material_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.material_sub }}</div>{%- endif -%}
      </div>
      <div class="bento__bg" aria-hidden="true">
        <svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 140 Q20 110 50 100 L120 80 Q160 70 180 100 Q190 130 170 150 L40 152 Z"/></svg>
      </div>
    </div>

    <div class="bento__cell b-2">
      <div class="bento__label">Padas</div>
      <div>
        <div class="bento__value bento__value--mono">{{ product.metafields.glance.sole | default: 'Vulkanizuota guma' }}</div>
        {%- if block.settings.sole_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.sole_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell bento__cell--orange b-3">
      <div class="bento__label">Kaina</div>
      <div>
        <div class="bento__value bento__value--big bento__value--mono">{{ product.price | money | remove: '€' | remove: ',00' }}</div>
        {%- if block.settings.price_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.price_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-4">
      <div class="bento__label">Gamintojas</div>
      <div>
        <div class="bento__value bento__value--mono">{{ product.metafields.glance.maker | default: product.vendor }}</div>
        {%- if block.settings.maker_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.maker_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-5">
      <div class="bento__label">Svoris</div>
      <div>
        <div class="bento__value bento__value--mono">{{ product.metafields.glance.weight | default: '—' }}</div>
        {%- if block.settings.weight_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.weight_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-6">
      <div class="bento__label">Kilmė</div>
      <div>
        <div class="bento__value">{{ product.metafields.glance.origin | default: '—' }}</div>
        {%- if block.settings.origin_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.origin_sub }}</div>{%- endif -%}
      </div>
    </div>

  </div>
</section>
  {%- endcase -%}
{%- endfor -%}

{%- assign doc_types = 'spec,story,care' | split: ',' -%}
{%- assign has_docs = false -%}
{%- for block in section.blocks -%}
  {%- if doc_types contains block.type -%}{%- assign has_docs = true -%}{%- endif -%}
{%- endfor -%}
{%- if has_docs -%}
<!-- ──────────── DOC SECTIONS ──────────── -->
<div class="docs">
{%- for block in section.blocks -%}
  {%- case block.type -%}
  {%- when 'spec' -%}
  <section class="doc" {{ block.shopify_attributes }}>
    <div class="doc__index">
      <span class="doc__num">{{ block.settings.num }}</span>
      <h3 class="doc__title">{{ block.settings.title }}</h3>
      <p class="doc__lede">{{ block.settings.lede }}</p>
    </div>
    <div>
      <div class="quals" aria-label="Konstrukcijos savybės">
{%- if product.metafields.spec.quals != blank -%}
{%- for qual in product.metafields.spec.quals.value -%}
        <div class="qual">
          <span class="k">{{ qual }}</span>
        </div>
{%- endfor -%}
{%- else -%}
        <div class="qual">
          <svg viewBox="0 0 30 30" aria-hidden="true"><path d="M23 5 Q14 7 10 14 Q7 19 7 25 M23 5 Q24 13 19 18 Q14 23 7 25 M11 13 L14 16 M9 18 L12.5 20.5"/></svg>
          <span class="k">Lengvi</span>
        </div>
        <div class="qual">
          <svg viewBox="0 0 30 30" aria-hidden="true"><path d="M4 21 Q8 21 11 19 Q15 16.5 18 12.5 Q20.5 9 24 8.5"/><path d="M4 24.5 Q9 24.5 13 22 Q17.5 19 20.5 14.5 Q22.5 11.5 26 11"/></svg>
          <span class="k">Lankstus padas</span>
        </div>
        <div class="qual">
          <svg viewBox="0 0 30 30" aria-hidden="true"><path d="M8 25 Q7 20 12 17.5 Q17 15 22 16 Q25 16.5 24 20 Q22.5 24 17 25.5 Q11 27 8 25 Z"/><path d="M11 11.5 Q13 9.5 15 11.5 Q17 13.5 19 11.5 M12 6.5 Q14 4.5 16 6.5 Q18 8.5 20 6.5"/></svg>
          <span class="k">Minkštas vidpadis</span>
        </div>
        <div class="qual">
          <svg viewBox="0 0 30 30" aria-hidden="true"><circle cx="10" cy="9" r="0.7"/><circle cx="15" cy="7.5" r="0.7"/><circle cx="20" cy="9" r="0.7"/><circle cx="12.5" cy="12" r="0.7"/><circle cx="17.5" cy="12" r="0.7"/><path d="M8 19 Q12 17 15 19 Q18 21 22 19 M8 23.5 Q12 21.5 15 23.5 Q18 25.5 22 23.5"/></svg>
          <span class="k">Kvėpuoja</span>
        </div>
        <div class="qual">
          <svg viewBox="0 0 30 30" aria-hidden="true"><path d="M6 8 Q6 5 9 5 L21 5 Q24 5 24 8 L24 20 Q24 25 19 25 L11 25 Q6 25 6 20 Z"/><circle cx="11" cy="11" r="0.5"/><circle cx="16" cy="9.5" r="0.5"/><circle cx="20" cy="12" r="0.5"/><circle cx="13" cy="15" r="0.5"/><circle cx="18" cy="17" r="0.5"/><circle cx="11" cy="20" r="0.5"/></svg>
          <span class="k">Natūrali oda</span>
        </div>
        <div class="qual">
          <svg viewBox="0 0 30 30" aria-hidden="true"><path d="M5 22 Q8 8 12 8 Q15 8 14 14 Q13.5 18 16 18 Q19 18 19 12 Q19 8 22 8 Q25 8 25 22"/></svg>
          <span class="k">Minkšta oda</span>
        </div>
{%- endif -%}
      </div>
    </div>
  </section>
  {%- when 'story' -%}
  <section class="doc" {{ block.shopify_attributes }}>
    <div class="doc__index">
      <span class="doc__num">{{ block.settings.num }}</span>
      <h3 class="doc__title">{{ block.settings.title }}</h3>
      <p class="doc__lede">{{ block.settings.lede }}</p>
    </div>
    <div>
      <div class="notes-prose">
{%- if product.metafields.custom.story != blank -%}
        {{ product.metafields.custom.story | metafield_tag }}
{%- else -%}
        <p>Kiekviena pora gaminama ribotomis partijomis ir numeruojama ranka — ne kolekcionavimui, o tam, kad žinotume, kur siųsti padų keitimą, kai juos sugrąžinsite.</p>
{%- endif -%}
      </div>
    </div>
  </section>
  {%- when 'care' -%}
  <section class="doc" {{ block.shopify_attributes }}>
    <div class="doc__index">
      <span class="doc__num">{{ block.settings.num }}</span>
      <h3 class="doc__title">{{ block.settings.title }}</h3>
      <p class="doc__lede">{{ block.settings.lede }}</p>
    </div>
    <div>
      <div class="care">
{%- if product.metafields.care.steps != blank -%}
{%- for step in product.metafields.care.steps.value -%}
        <div class="care__cell">
          <div class="care__label">{{ step }}</div>
        </div>
{%- endfor -%}
{%- else -%}
        <div class="care__cell">
          <div class="care__icon"><svg viewBox="0 0 32 32"><path d="M8 13 L24 13 L22 24 L10 24 Z"/><path d="M12 13 V8 a4 4 0 0 1 8 0 V13"/></svg></div>
          <div class="care__label">Valyti drėgnu skudurėliu.</div>
        </div>
        <div class="care__cell">
          <div class="care__icon"><svg viewBox="0 0 32 32"><circle cx="16" cy="16" r="9"/><line x1="9" y1="9" x2="23" y2="23"/></svg></div>
          <div class="care__label">Neskalbti skalbimo mašinoje.</div>
        </div>
        <div class="care__cell">
          <div class="care__icon"><svg viewBox="0 0 32 32"><circle cx="16" cy="16" r="9"/><path d="M16 10 V16 L21 19"/></svg></div>
          <div class="care__label">Tepti kondicionieriumi kas 60 d.</div>
        </div>
        <div class="care__cell">
          <div class="care__icon"><svg viewBox="0 0 32 32"><path d="M8 15 V24 H24 V15"/><path d="M16 4 V16 M11 11 L16 16 L21 11"/></svg></div>
          <div class="care__label">Džiovinti sausoje, tamsioje vietoje.</div>
        </div>
{%- endif -%}
      </div>
    </div>
  </section>
  {%- endcase -%}
{%- endfor -%}
</div>
{%- endif -%}

{%- for block in section.blocks -%}
  {%- case block.type -%}
  {%- when 'reviews' -%}
<!-- ──────────── ATSILIEPIMAI (compact, expandable) ──────────── -->
<section class="reviews" id="atsiliepimai" {{ block.shopify_attributes }}>
  <div class="reviews__bar">
    <div class="reviews__lead">
      <div class="eyebrow-rule">{{ block.settings.eyebrow }}</div>
      {%- comment -%} Score line renders only when the merchant supplies a real
        score — no fabricated social proof by default. {%- endcomment -%}
      {%- if block.settings.score != blank -%}
      <div class="reviews__scoreline">
        <span class="num">{{ block.settings.score }}<small>/5</small></span>
        <span class="stars" aria-hidden="true">★★★★★</span>
        {%- if block.settings.count_line != blank -%}<span class="cnt">{{ block.settings.count_line }}</span>{%- endif -%}
      </div>
      {%- endif -%}
    </div>
    <p class="reviews__brief">{{ block.settings.brief }}</p>
    <button class="reviews__toggle" type="button" id="revToggle" aria-expanded="false" aria-controls="revList">
      {{ block.settings.toggle_label }}
      <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5 L7 9 L11 5"></path></svg>
    </button>
  </div>

  <div class="reviews__list" id="revList" hidden>
    {%- for rev in section.blocks -%}
      {%- if rev.type == 'review' -%}
      <article class="rev" {{ rev.shopify_attributes }}>
        <div class="rev__meta">
          <span class="rev__stars" aria-label="{{ rev.settings.rating }} iš 5">{% for i in (1..5) %}{% if i <= rev.settings.rating %}★{% else %}<span class="off">★</span>{% endif %}{% endfor %}</span>
          <span class="rev__who"><b>{{ rev.settings.author }}</b> · patvirtintas pirkimas</span>
          <time class="rev__date" datetime="{{ rev.settings.date }}">{{ rev.settings.date }}</time>
        </div>
        <p class="rev__body">{{ rev.settings.body }}</p>
        {%- if rev.settings.fit_note != blank -%}<span class="rev__fit">{{ rev.settings.fit_note }}</span>{%- endif -%}
      </article>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>
  {%- when 'related' -%}
<!-- ──────────── RELATED ──────────── -->
<section class="related" {{ block.shopify_attributes }}>
  <div class="related__head">
    <h3 class="related__title">{{ block.settings.title }}</h3>
    <a href="{{ block.settings.more_link | default: routes.collections_url }}" class="related__more">
      {{ block.settings.more_label }}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7 H11 M7 3 L11 7 L7 11"/></svg>
    </a>
  </div>
  <div class="related__grid" data-product-recommendations>
{%- if recommendations.performed and recommendations.products_count > 0 -%}
{%- for p in recommendations.products limit: 4 -%}
    <a class="card" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
      <div class="card__media">
        <span class="card__price-chip">{{ p.price | money | remove: '€' | remove: ',00' }}</span>
        {%- if p.featured_image -%}
        <img src="{{ p.featured_image | image_url: width: 800 }}" srcset="{{ p.featured_image | image_url: width: 400 }} 400w, {{ p.featured_image | image_url: width: 800 }} 800w" sizes="(max-width: 520px) 50vw, 25vw" width="{{ p.featured_image.width }}" height="{{ p.featured_image.height }}" alt="{{ p.featured_image.alt | escape }}" loading="lazy">
        {%- endif -%}
      </div>
    </a>
{%- endfor -%}
{%- else -%}
{%- for p in collections.all.products limit: 4 -%}
    <a class="card" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
      <div class="card__media">
        <span class="card__price-chip">{{ p.price | money | remove: '€' | remove: ',00' }}</span>
        {%- if p.featured_image -%}
        <img src="{{ p.featured_image | image_url: width: 800 }}" srcset="{{ p.featured_image | image_url: width: 400 }} 400w, {{ p.featured_image | image_url: width: 800 }} 800w" sizes="(max-width: 520px) 50vw, 25vw" width="{{ p.featured_image.width }}" height="{{ p.featured_image.height }}" alt="{{ p.featured_image.alt | escape }}" loading="lazy">
        {%- endif -%}
      </div>
    </a>
{%- endfor -%}
{%- endif -%}
  </div>
</section>
  {%- endcase -%}
{%- endfor -%}

<script src="{{ 'product.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "text", "id": "atc_label", "label": "Add to cart label", "default": "Į krepšelį" },
    { "type": "checkbox", "id": "show_payment_button", "label": "Show dynamic checkout button", "info": "Shop Pay / wallet express-checkout button below the add-to-cart.", "default": true },
    { "type": "header", "content": "Text" },
    { "type": "range", "id": "title_scale", "label": "Product title size", "min": 60, "max": 130, "step": 5, "unit": "%", "default": 100 },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    { "type": "@app" },
    { "type": "fit", "name": "Fit chart", "limit": 1, "settings": [] },
