{{ 'section-product.css' | asset_url | stylesheet_tag }}
{{ 'component-gallery.css' | asset_url | stylesheet_tag }}
{{ 'component-buy.css' | asset_url | stylesheet_tag }}
{{ 'component-delivery.css' | asset_url | stylesheet_tag }}
{{ 'component-glance.css' | asset_url | stylesheet_tag }}
{{ 'component-docs.css' | asset_url | stylesheet_tag }}
{{ 'component-fit.css' | asset_url | stylesheet_tag }}
{{ 'component-reviews.css' | asset_url | stylesheet_tag }}
{{ 'component-related.css' | asset_url | stylesheet_tag }}
{% render 'structured-data-product' %}
{% render 'section-appearance', section: section %}
{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign buybar_price = product.price | money_without_trailing_zeros
  assign buybar_compare = ''
  if product.compare_at_price and product.compare_at_price > product.price
    assign buybar_compare = product.compare_at_price | money_without_trailing_zeros
  endif
  comment
    Pre-order mode — the `netrukus` tag is the single switch (see the spec,
    docs/superpowers/specs/2026-07-21-netrukus-preorder-preview-design.md).
    Swaps the ATC label, adds a note under the CTA and the stage track.
  endcomment
  assign is_preorder = false
  assign po_expected = ''
  assign po_stage = ''
  if product.tags contains 'netrukus'
    assign is_preorder = true
    assign po_expected = product.metafields.preorder.expected.value
    assign po_stage = product.metafields.preorder.stage.value
  endif
  assign atc_label = section.settings.atc_label | default: 'Į krepšelį'
  if is_preorder
    assign atc_label = 'product.preorder.cta' | t
  endif
  comment
    In production → coarse eta (month + third: pradžioje/viduryje/pabaigoje);
    the exact day only once Būsena = Pagaminti · kelyje.
  endcomment
  assign po_coarse = false
  if po_stage == 'Gamyboje'
    assign po_coarse = true
  endif
-%}
{%- capture po_eta -%}{% render 'date-lt', date: po_expected, coarse: po_coarse %}{%- endcapture -%}
{%- assign po_eta = po_eta | strip -%}

<!-- ──────────── PRODUCT — sticky split ──────────── -->
<div class="product"
  data-product-title="{{ product.title | escape }}"
  data-price="{{ buybar_price | escape }}"
  data-compare="{{ buybar_compare | escape }}"
  data-atc-label="{{ atc_label | escape }}"
  data-current-size="{{ current_variant.title | split: ' (' | first | strip | escape }}">

  <!-- GALLERY -->
  {% render 'product-gallery', product: product %}

  <!-- INFO STICKY -->
  <aside class="info">
    <div class="info__head">
      <h1 class="info__name">
        <span>{{ product.title }}</span>
      </h1>
      <span class="info__sep" aria-hidden="true">·</span>
      {% render 'price', product: product %}
      {% render 'promo-badge', product: product, context: 'pdp-chip' %}
    </div>

    {%- capture pr_stars -%}{% render 'product-rating', product: product, href: '#atsiliepimai', show_score: true, show_count: true, count_style: 'words' %}{%- endcapture -%}
    {%- assign pr_stars = pr_stars | strip -%}
    {%- if pr_stars != blank -%}<div class="info__rating">{{ pr_stars }}</div>{%- endif -%}

    {%- if product.description != blank -%}
    <div class="info__desc">{{ product.description }}</div>
    {%- endif -%}

    <div class="sizeblock">
      {% render 'promo-badge', product: product, context: 'pdp-note' %}
      <div class="sizes" role="radiogroup" aria-label="{{ 'accessibility.size_eu' | t }}">
{%- if product.variants.size > 0 and product.has_only_default_variant == false -%}
{%- for variant in product.variants -%}
{%- assign size_eu = variant.title | split: ' (' | first | strip -%}
{%- assign size_cm = '' -%}
{%- if variant.title contains ' (' -%}
{%- assign size_cm = variant.title | split: ' (' | last | remove: ')' | replace: 'cm', ' cm' | strip -%}
{%- endif -%}
        <button class="size{% if variant.id == current_variant.id %} is-selected{% endif %}" role="radio" aria-checked="{% if variant.id == current_variant.id %}true{% else %}false{% endif %}" data-variant-id="{{ variant.id }}" data-variant-price="{{ variant.price | money_without_trailing_zeros }}"{% if variant.compare_at_price > variant.price %} data-variant-compare="{{ variant.compare_at_price | money_without_trailing_zeros }}"{% endif %} data-variant-available="{{ variant.available }}"{% if variant.inventory_management != blank %} data-variant-qty="{{ variant.inventory_quantity }}"{% endif %}{% unless variant.available %} disabled aria-label="{{ variant.title | escape }} — išparduota"{% endunless %}><span class="size__eu">{{ size_eu }}</span>{% if size_cm != blank %}<span class="size__cm">{{ size_cm }}</span>{% endif %}</button>
{%- endfor -%}
{%- else -%}
        <button class="size is-selected" role="radio" aria-checked="true"><span class="size__eu">{{ current_variant.title | default: 'Vienas dydis' }}</span></button>
{%- endif -%}
      </div>
      <a class="sizeguide" href="{{ pages['dydziu-lentele'].url | default: '/pages/dydziu-lentele' }}">{{ 'product.size_guide' | t }} <span class="sizeguide__ar" aria-hidden="true">→</span></a>
      <p class="sizes-note" data-sizes-note aria-live="polite"{% unless current_variant.available and current_variant.inventory_management != blank and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 5 %} hidden{% endunless %}>{%- if current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 5 -%}Liko {{ current_variant.inventory_quantity }} vnt.{%- endif -%}</p>
      {%- if product.metafields.custom.stock_line != blank -%}
      <div class="stock">
        <span class="stock__dot"></span>
        <span>{{ product.metafields.custom.stock_line }}</span>
      </div>
      {%- endif -%}
      {%- if is_preorder -%}
      {%- comment -%} Batch-progress track. po_keys is the DATA CONTRACT with the
        preorder.stage choice list (values are Lithuanian, matched verbatim);
        po_labels is the translatable display list from locales. {%- endcomment -%}
      {%- assign po_keys = 'Gamyboje|Pagaminti · kelyje' | split: '|' -%}
      {%- assign po_labels = 'product.preorder.stages' | t | split: '|' -%}
      {%- assign po_idx = -1 -%}
      {%- for k in po_keys -%}{%- if k == po_stage -%}{%- assign po_idx = forloop.index0 -%}{%- endif -%}{%- endfor -%}
      {%- if po_idx > -1 -%}
      <div class="potrack">
        <div class="potrack__head">
          <span class="potrack__title">{{ 'product.preorder.track_title' | t }}</span>
          {%- if po_eta != blank -%}
          <span class="potrack__eta">{{ 'product.preorder.expected' | t: date: po_eta }}</span>
          {%- endif -%}
        </div>
        <ol class="potrack__list">
          {%- for label in po_labels -%}
          <li class="potrack__step{% if forloop.index0 < po_idx %} done{% elsif forloop.index0 == po_idx %} now{% endif %}"{% if forloop.index0 == po_idx %} aria-current="step"{% endif %}>
            <span class="potrack__node" aria-hidden="true"></span>
            <span class="potrack__lab">{{ label }}</span>
          </li>
          {%- endfor -%}
        </ol>
      </div>
      {%- endif -%}
      {%- endif -%}
    </div>

    {%- comment -%} The form carries an explicit id ATTRIBUTE for selection via
      getAttribute('id'). NOTE: the form.id IDL property still resolves to the
      name="id" input below (HTMLFormElement's named getter is
      [LegacyOverrideBuiltIns]) — that clobbering is unavoidable because Shopify's
      /cart/add requires name="id". Never read form.id in JS; use
      form.getAttribute('id') or querySelector('[name="id"]'). {%- endcomment -%}
    {%- assign product_form_id = 'ProductForm-' | append: section.id -%}
    {% form 'product', product, id: product_form_id %}
    <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-id>
    <div class="ctas">
      <button class="btn btn--primary" type="submit" data-atc>
        <span>{{ atc_label }}</span>
        <span class="btn__arrow">→</span>
      </button>
      {%- if section.settings.show_payment_button -%}
      {{ form | payment_button }}
      {%- endif -%}
    </div>
    {% endform %}
    {%- if is_preorder -%}
    {%- comment -%} Close the eta sentence unless the date pattern already
      ends with a period (the LT exact form ends in „d."). {%- endcomment -%}
    {%- assign po_dot = '.' -%}
    {%- assign po_last = po_eta | slice: -1 -%}
    {%- if po_last == '.' -%}{%- assign po_dot = '' -%}{%- endif -%}
    <p class="po-note">{{ 'product.preorder.note' | t }}{% if po_eta != blank %} <b>{{ 'product.preorder.expected' | t: date: po_eta | capitalize }}{{ po_dot }}</b>{% endif %}</p>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
      {%- when 'fit' -%}
{%- comment -%} Two independent per-product choice metafields drive the dot:
  custom.length_fit → X (runs small ↔ large), custom.width_fit → Y (narrow ↔ wide).
  Opt-in: the graph renders only when length_fit is set (footwear); width falls
  back to standard (centre-Y) if unset. No metaobject, no 25-combo lookup. {%- endcomment -%}
{%- assign length_fit = product.metafields.custom.length_fit.value -%}
{%- assign width_fit = product.metafields.custom.width_fit.value -%}
{%- if length_fit != blank -%}
{%- case length_fit -%}
  {%- when 'gerokai_mazesni' -%}{%- assign fx = 10 -%}{%- assign fit_label = 'product.fit.fit_val.gerokai_mazesni' | t -%}
  {%- when 'kiek_mazesni' -%}{%- assign fx = 30 -%}{%- assign fit_label = 'product.fit.fit_val.kiek_mazesni' | t -%}
  {%- when 'kiek_didesni' -%}{%- assign fx = 70 -%}{%- assign fit_label = 'product.fit.fit_val.kiek_didesni' | t -%}
  {%- when 'gerokai_didesni' -%}{%- assign fx = 90 -%}{%- assign fit_label = 'product.fit.fit_val.gerokai_didesni' | t -%}
  {%- else -%}{%- assign fx = 50 -%}{%- assign fit_label = 'product.fit.fit_val.standartiniai' | t -%}
{%- endcase -%}
{%- case width_fit -%}
  {%- when 'labai_siauri' -%}{%- assign fy = 90 -%}{%- assign width_label = 'product.fit.width_val.labai_siauri' | t -%}
  {%- when 'siauri' -%}{%- assign fy = 70 -%}{%- assign width_label = 'product.fit.width_val.siauri' | t -%}
  {%- when 'platus' -%}{%- assign fy = 30 -%}{%- assign width_label = 'product.fit.width_val.platus' | t -%}
  {%- when 'labai_platus' -%}{%- assign fy = 10 -%}{%- assign width_label = 'product.fit.width_val.labai_platus' | t -%}
  {%- else -%}{%- assign fy = 50 -%}{%- assign width_label = 'product.fit.width_val.standartinis' | t -%}
{%- endcase -%}
    <div class="fit" id="fit-guide" aria-label="{{ 'accessibility.model_fit' | t }}" {{ block.shopify_attributes }}>
      <div class="fit__head">
        <span class="fit__title"></span>
        <span class="fit__count"></span>
      </div>
      <div class="fit__chart">
        <span class="fit__axis fit__axis--top">{{ 'product.fit.wide' | t }}</span>
        <span class="fit__axis fit__axis--left">{{ 'product.fit.smaller' | t }}</span>
        <span class="fit__axis fit__axis--right">{{ 'product.fit.larger' | t }}</span>
        <span class="fit__axis fit__axis--bottom">{{ 'product.fit.narrow' | t }}</span>
        <div class="fit__plot">
          <span class="fit__cross fit__cross--h" aria-hidden="true"></span>
          <span class="fit__cross fit__cross--v" aria-hidden="true"></span>
          <span class="fit__anchor" aria-hidden="true"></span>
          <span class="fit__tick fit__tick--x" style="left: {{ fx }}%;" aria-hidden="true"></span>
          <span class="fit__tick fit__tick--y" style="top: {{ fy }}%;" aria-hidden="true"></span>
          <span class="fit__dot" style="left: {{ fx }}%; top: {{ fy }}%;" aria-hidden="true"></span>
        </div>
      </div>
      <div class="fit__verdict">
        <b>{{ fit_label }} · {{ width_label }}</b>
      </div>
    </div>
{%- endif -%}
      {%- when 'delivery' -%}
    {%- if is_preorder -%}
    {%- comment -%} Pre-order variant: the courier gantt's computed dates would
      contradict the batch timeline, so the same .gantt vocabulary tells the
      batch story instead — states follow Būsena, the delivery row carries the
      (coarse or exact) expected-receipt date. Static Liquid; no
      component-delivery.js, which would overwrite the date cells. {%- endcomment -%}
    <div class="delivery" {{ block.shopify_attributes }}>
      <div class="delivery__head">
        <span class="delivery__title">{{ block.settings.title }}</span>
      </div>
      <div class="gantt">
        <div class="gantt__row done">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ 'product.delivery.placed' | t }}</span>
          <span class="gantt__date">{{ 'product.preorder.today' | t }}</span>
        </div>
        <div class="gantt__row{% if po_stage == 'Gamyboje' %} now{% else %} done{% endif %}">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ 'product.preorder.gantt_production' | t }}</span>
          <span class="gantt__date"></span>
        </div>
        <div class="gantt__row{% if po_stage == 'Pagaminti · kelyje' %} now{% endif %}">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ 'product.delivery.transit' | t }}</span>
          <span class="gantt__date"></span>
        </div>
        <div class="gantt__row">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ 'product.preorder.gantt_delivery' | t }}</span>
          <span class="gantt__date">{%- if po_eta != blank -%}{{ 'product.preorder.expected' | t: date: po_eta }}{%- endif -%}</span>
        </div>
      </div>
    </div>
    {%- else -%}
    <div class="delivery" {{ block.shopify_attributes }}>
      <div class="delivery__head">
        <span class="delivery__title">{{ block.settings.title }}</span>
      </div>
      {%- comment -%} Dates filled by component-delivery.js (Europe/Vilnius, weekends + LT holidays). {%- endcomment -%}
      <div class="gantt">
        <div class="gantt__row done">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ 'product.delivery.placed' | t }}</span>
          <span class="gantt__date"></span>
        </div>
        <div class="gantt__row now">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ 'product.delivery.shipped' | t }}</span>
          <span class="gantt__date"></span>
        </div>
        <div class="gantt__row">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ 'product.delivery.transit' | t }}</span>
          <span class="gantt__date"></span>
        </div>
        <div class="gantt__row">
          <span class="gantt__node"></span>
          <span class="gantt__leg">{{ 'product.delivery.delivered' | t }}</span>
          <span class="gantt__date"></span>
        </div>
      </div>
      <script src="{{ 'component-delivery.js' | asset_url }}" defer></script>
    </div>
    {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}

    <div class="promises">
      <span class="promise"></span>
    </div>

  </aside>
</div>

{%- for block in section.blocks -%}
  {%- case block.type -%}
  {%- when 'glance' -%}
<!-- ──────────── TRUMPAI — bento ──────────── -->
{% render 'product-glance', block: block, product: product %}
  {%- endcase -%}
{%- endfor -%}

{% render 'product-docs', section: section, product: product %}

{%- for block in section.blocks -%}
  {%- case block.type -%}
  {%- when 'reviews' -%}
<!-- ──────────── ATSILIEPIMAI (compact, expandable) ──────────── -->
{% render 'product-reviews', section: section, block: block, product: product %}
  {%- when 'related' -%}
<!-- ──────────── RELATED ──────────── -->
{% render 'product-related', block: block, product: product %}
  {%- endcase -%}
{%- endfor -%}

<script src="{{ 'product.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "text", "id": "atc_label", "label": "Add to cart label", "default": "Į krepšelį" },
    { "type": "checkbox", "id": "show_payment_button", "label": "Show dynamic checkout button", "info": "Shop Pay / wallet express-checkout button below the add-to-cart.", "default": true },
    { "type": "header", "content": "Appearance" },
    { "type": "range", "id": "title_scale", "label": "Product title size", "min": 60, "max": 130, "step": 5, "unit": "%", "default": 100 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    { "type": "@app" },
    { "type": "fit", "name": "Fit chart", "limit": 1, "settings": [] },
    {
      "type": "delivery", "name": "Delivery gantt", "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Kada pristatysime?" }
      ]
    },
    {
      "type": "glance", "name": "At a glance (bento)", "limit": 1,
      "settings": [
        { "type": "text", "id": "num", "label": "Number line", "default": "00 — Apžvalga" },
        { "type": "text", "id": "title", "label": "Title", "default": "Trumpai." },
        { "type": "text", "id": "lede", "label": "Lede", "default": "Svarbiausi faktai apie porą — be žodžių pertekliaus." },
        { "type": "text", "id": "origin", "label": "Kilmė (visiems modeliams)", "info": "Rodoma visų modelių Trumpai bloke. Palikite tuščią, kad nebūtų rodoma — geriau nerodyti nei rodyti neteisingą kilmę." },
        { "type": "text", "id": "material_sub", "label": "Material sub-text" },
        { "type": "text", "id": "sole_sub", "label": "Sole sub-text" },
        { "type": "text", "id": "price_sub", "label": "Price sub-text" },
        { "type": "text", "id": "maker_sub", "label": "Maker sub-text" },
        { "type": "text", "id": "weight_sub", "label": "Weight sub-text" },
        { "type": "text", "id": "origin_sub", "label": "Origin sub-text" }
      ]
    },
    {
      "type": "spec", "name": "Doc — Specification", "limit": 1,
      "settings": [
        { "type": "text", "id": "num", "label": "Number line", "default": "01 — Specifikacija" },
        { "type": "text", "id": "title", "label": "Title", "default": "Konstrukcija." },
        { "type": "text", "id": "lede", "label": "Lede", "default": "Savybės — be žodžių pertekliaus." }
      ]
    },
    {
      "type": "story", "name": "Doc — Story", "limit": 1,
      "settings": [
        { "type": "text", "id": "num", "label": "Number line", "default": "02 — Užrašai" },
        { "type": "text", "id": "title", "label": "Title", "default": "Apie gamintoją" },
        { "type": "text", "id": "lede", "label": "Lede", "default": "Mūsų žodžiais" }
      ]
    },
    {
      "type": "care", "name": "Doc — Care", "limit": 1,
      "settings": [
        { "type": "text", "id": "num", "label": "Number line", "default": "03 — Priežiūra" },
        { "type": "text", "id": "title", "label": "Title", "default": "Išlaikykite juos kaip naujus." },
        { "type": "text", "id": "lede", "label": "Lede", "default": "Keturi įpročiai, šešiasdešimties dienų ritmas, dvidešimt sezonų dėvėjimo." }
      ]
    },
    {
      "type": "reviews", "name": "Reviews", "limit": 1,
      "settings": [
        { "type": "paragraph", "content": "Reviews are powered by the Judge.me app (install it and enable its app embed). This block renders the on-brand heading around the Judge.me widget." },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "04 — Atsiliepimai" },
        { "type": "text", "id": "title_light", "label": "Title (light part)", "default": "Ką sako" },
        { "type": "text", "id": "title", "label": "Title (bold part)", "default": "pirkėjai." }
      ]
    },
    {
      "type": "related", "name": "Related products", "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Nuo to paties podiumo —" },
        { "type": "text", "id": "more_label", "label": "More link label", "default": "Archyvas" },
        { "type": "url", "id": "more_link", "label": "More link" }
      ]
    }
  ]
}
{% endschema %}
