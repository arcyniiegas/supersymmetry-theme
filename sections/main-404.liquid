{{ 'section-404.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}
<!-- ──────────── 404 ──────────── -->
<main class="e404">
  <div>
    <h1 class="e404__code"><b>4</b><span class="dot" aria-hidden="true"></span><b>4</b></h1>
    <div class="e404__stamp">
      <span>{{ section.settings.stamp_1 | default: 'Klaida · <b>404 / ∞</b>' }}</span>
      <span>{{ section.settings.stamp_2 | default: 'Pora, kurios ieškai, <b>nerasta sandėlyje</b>' }}</span>
    </div>
  </div>

  <div class="e404__copy">
    <div class="eyebrow-rule">{{ section.settings.eyebrow | default: 'Puslapis nerastas' }}</div>
    <h2 class="e404__title"><span class="light">{{ section.settings.title_light | default: 'Šitas pėdsakas' }}</span> {{ section.settings.title | default: 'niekur neveda.' }}</h2>
    <p class="e404__lede">{{ section.settings.lede | default: 'Galbūt nuoroda pasenusi, pora jau iškeliavo, arba adresas nukrypo. Pradėk iš naujo — viskas dar čia pat.' }}</p>

    <form class="e404__search" onsubmit="event.preventDefault(); var v=this.querySelector('input').value.trim(); window.location.href='/search?q='+encodeURIComponent(v);">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="9.5" cy="9.5" r="6.5"/><path d="M14.5 14.5l5 5"/></svg>
      <input type="text" placeholder="{{ section.settings.search_placeholder | default: 'Ieškoti kolekcijoje…' | escape }}" aria-label="Paieška" />
      <button type="submit">{{ section.settings.search_button | default: 'Ieškoti' }}</button>
    </form>

    <nav class="routes" aria-label="Greitos nuorodos">
      {%- assign route_blocks = section.blocks | where: 'type', 'route' -%}
      {%- if route_blocks.size > 0 -%}
        {%- for block in route_blocks -%}
      <a class="route" href="{{ block.settings.link | default: routes.root_url }}" {{ block.shopify_attributes }}>
        <span class="route__name">{{ block.settings.name }}</span>
        <span style="display:flex;align-items:baseline;gap:12px"><span class="route__meta">{{ block.settings.meta }}</span><span class="route__arrow">→</span></span>
      </a>
        {%- endfor -%}
      {%- else -%}
      <a class="route" href="{{ routes.root_url }}">
        <span class="route__name">Pradžia</span>
        <span style="display:flex;align-items:baseline;gap:12px"><span class="route__meta">00</span><span class="route__arrow">→</span></span>
      </a>
      <a class="route" href="{{ routes.all_products_collection_url }}">
        <span class="route__name">Visa kolekcija</span>
        <span style="display:flex;align-items:baseline;gap:12px"><span class="route__meta">SS·26</span><span class="route__arrow">→</span></span>
      </a>
      <a class="route" href="{{ routes.collections_url }}">
        <span class="route__name">Kolekcijos</span>
        <span style="display:flex;align-items:baseline;gap:12px"><span class="route__meta">{{ collections.size }}</span><span class="route__arrow">→</span></span>
      </a>
      <a class="route" href="/pages/kontaktai">
        <span class="route__name">Kontaktai</span>
        <span style="display:flex;align-items:baseline;gap:12px"><span class="route__meta">Vilnius</span><span class="route__arrow">→</span></span>
      </a>
      {%- endif -%}
    </nav>
  </div>
</main>
{% schema %}
{
  "name": "404",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "stamp_1", "label": "Stamp line 1", "default": "Klaida · <b>404 / ∞</b>" },
    { "type": "text", "id": "stamp_2", "label": "Stamp line 2", "default": "Pora, kurios ieškai, <b>nerasta sandėlyje</b>" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Puslapis nerastas" },
    { "type": "text", "id": "title_light", "label": "Title (light part)", "default": "Šitas pėdsakas" },
    { "type": "text", "id": "title", "label": "Title (bold part)", "default": "niekur neveda." },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "Galbūt nuoroda pasenusi, pora jau iškeliavo, arba adresas nukrypo. Pradėk iš naujo — viskas dar čia pat." },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Ieškoti kolekcijoje…" },
    { "type": "text", "id": "search_button", "label": "Search button", "default": "Ieškoti" },
    { "type": "header", "content": "Text" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    {
      "type": "route",
      "name": "Quick link",
      "settings": [
        { "type": "text", "id": "name", "label": "Label" },
        { "type": "text", "id": "meta", "label": "Meta (right)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ]
}
{% endschema %}
