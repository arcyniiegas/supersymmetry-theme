{{ 'section-home.css' | asset_url | stylesheet_tag }}
{{ 'section-home-visit.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}
<!-- ──────────── STORE VISIT ──────────── -->
<section class="homevisit" style="background-color: #FFFFFF; --title-scale: {{ section.settings.title_scale | default: 100 | divided_by: 100.0 }};">
  <div class="homevisit__wrap">
    <div>
      <div class="homevisit__eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.text }}</p>
      <div class="homevisit__hours">
        {% content_for "blocks" %}
      </div>
      {% render 'button', label: section.settings.cta_label, href: section.settings.cta_link | default: pages.kontaktai.url | default: routes.root_url, style: 'primary', arrow: true, class: 'homevisit__cta' %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Home — Visit",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Užsukite" },
    { "type": "text", "id": "title", "label": "Title", "default": "Ateljė — Vilniaus senamiestyje." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Trakų g. 16, pačiame Vilniaus senamiestyje. Užsukite pasimatuoti arba atsiimti užsakymo." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Adresas ir maršrutas" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "header", "content": "Text size" },
    { "type": "range", "id": "title_scale", "label": "Heading size", "min": 60, "max": 130, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Text colour" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    { "type": "hours" }
  ],
  "presets": [
    {
      "name": "Home — Visit",
      "blocks": [
        { "type": "hours", "settings": { "day": "Pirmadienis", "time": "Uždaryta", "closed": true } },
        { "type": "hours", "settings": { "day": "Antradienis — Penktadienis", "time": "11:00 — 19:00" } },
        { "type": "hours", "settings": { "day": "Šeštadienis", "time": "11:00 — 17:00", "highlight": true } },
        { "type": "hours", "settings": { "day": "Sekmadienis", "time": "Uždaryta", "closed": true } }
      ]
    }
  ]
}
{% endschema %}
