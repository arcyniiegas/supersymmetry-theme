        { "type": "text", "id": "n", "label": "Number" },
        { "type": "text", "id": "t", "label": "Title" },
        { "type": "textarea", "id": "b", "label": "Body" },
        { "type": "text", "id": "tip_k", "label": "Tip kicker" },
        { "type": "textarea", "id": "tip_b", "label": "Tip body (empty hides the tip)" },
        { "type": "checkbox", "id": "tip_warn", "label": "Warning style", "default": false }
