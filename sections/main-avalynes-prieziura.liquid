{{ 'section-avalynes-prieziura.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}
<!-- ──────────── BREADCRUMBS ──────────── -->
<nav class="crumbs" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Pradžia</a>
  <span class="sep">/</span>
  <a href="{{ pages.duk.url | default: routes.root_url }}">{{ section.settings.crumb_parent | default: 'Paslaugos' }}</a>
  <span class="sep">/</span>
  <b>{{ section.settings.crumb_current | default: 'Avalynės priežiūra' }}</b>
</nav>

<!-- ──────────── PAGE HEAD ──────────── -->
<section class="phead">
  <div>
    <div class="eyebrow-rule">{{ section.settings.eyebrow | default: 'Priežiūra · oda ir zomša' }}</div>
    <h1 class="phead__title">
      <span class="light">{{ section.settings.title_light | default: 'Avalynės' }}</span>
      {{ section.settings.title | default: 'priežiūra.' }}
    </h1>
  </div>
  <div class="phead__aside">
    <p class="phead__intro">{{ section.settings.intro | default: 'Pora, pagaminta vieną kartą, tarnauja dešimtmetį — jei ja rūpinatės. Keli teisingi įpročiai svarbesni nei brangios priemonės. Štai <b>viskas, ką reikia žinoti</b> apie odą ir zomšą.' }}</p>
    {%- assign stat_blocks = section.blocks | where: 'type', 'stat' -%}
    {%- if stat_blocks.size > 0 -%}
    <div class="phead__stats">
      {%- for block in stat_blocks -%}
      {% render 'stat', k: block.settings.k, v: block.settings.v, tabular: block.settings.tabular, attrs: block.shopify_attributes %}
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>
</section>

<!-- ──────────── SUBNAV ──────────── -->
{%- assign chip_blocks = section.blocks | where: 'type', 'chip' -%}
{%- if chip_blocks.size > 0 -%}
<scroll-spy class="subnav" role="navigation" aria-label="Skyriai">
  <div class="subnav__wrap">
    {%- for block in chip_blocks -%}
    <a class="subnav__chip" href="#{{ block.settings.anchor }}"{% if forloop.first %} aria-current="true"{% endif %} {{ block.shopify_attributes }}><span class="n">{{ block.settings.n }}</span> {{ block.settings.label }}</a>
    {%- endfor -%}
  </div>
</scroll-spy>
{%- endif -%}

<!-- ──────────── 00 · DAILY ──────────── -->
{% render 'care-daily', section: section %}

<!-- ──────────── 01 · LEATHER ──────────── -->
{% render 'care-leather', section: section %}

<!-- ──────────── 02 · SUEDE ──────────── -->
{% render 'care-suede', section: section %}

<!-- ──────────── 03 · STORAGE ──────────── -->
{% render 'care-storage', section: section %}

<!-- ──────────── 04 · TROUBLESHOOTING ──────────── -->
{% render 'care-fixes', section: section %}

<!-- ──────────── 05 · KIT ──────────── -->
{% render 'care-kit', section: section %}

<!-- ──────────── CLOSING ──────────── -->
<section class="sec close">
  <div class="close__wrap">
    <div>
      <div class="eyebrow-rule">{{ section.settings.close_eyebrow | default: 'Reikia daugiau?' }}</div>
      <h2>{{ section.settings.close_title | default: 'Kai kurie darbai — meistrui.' }}</h2>
      <p>{{ section.settings.close_text | default: 'Padų keitimas, persiuvimas ir gilus atnaujinimas atliekami ateljė. Parašykite ar užsukite — pasakysime, ką dar galima išgelbėti.' }}</p>
    </div>
    <div class="close__cta">
      {% render 'button', label: section.settings.close_cta_label | default: 'Susisiekti', href: section.settings.close_cta_link | default: pages.kontaktai.url | default: '/pages/kontaktai', style: 'primary', arrow: true %}
      {% render 'button', label: section.settings.close_cta2_label | default: 'DUK', href: section.settings.close_cta2_link | default: pages.duk.url | default: '/pages/duk', style: 'secondary' %}
    </div>
  </div>
</section>
<script src="{{ 'component-scroll-spy.js' | asset_url }}" defer></script>
{% schema %}
