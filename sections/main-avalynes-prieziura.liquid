    { "type": "text", "id": "daily_title", "label": "Title (bold)", "default": "kurios keičia viską." },
    { "type": "textarea", "id": "daily_sub", "label": "Sub", "default": "Didžiausią skirtumą daro ne priemonės, o pastovumas. Keturi įpročiai, kuriuos verta paversti automatiškais." },
    { "type": "header", "content": "Leather tutorial" },
    { "type": "text", "id": "oda_eyebrow", "label": "Eyebrow", "default": "01 · Lygi oda" },
    { "type": "text", "id": "oda_title_light", "label": "Title (light)", "default": "Odos priežiūra" },
    { "type": "text", "id": "oda_title", "label": "Title (bold)", "default": "— penki žingsniai." },
    { "type": "textarea", "id": "oda_sub", "label": "Sub", "default": "Nuo dulkių iki apsaugos. Visą ciklą kartokite kartą per mėnesį, poliravimą — kada tik norite blizgesio." },
    { "type": "text", "id": "oda_word", "label": "Big word", "default": "Oda" },
    { "type": "image_picker", "id": "oda_image", "label": "Photo" },
