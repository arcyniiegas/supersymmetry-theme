    { "type": "textarea", "id": "fix_sub", "label": "Sub", "default": "Greiti, patikrinti sprendimai. Jei abejojate ar pažeidimas gilus — parašykite mums prieš imdamiesi patys." },
    { "type": "header", "content": "Kit section" },
    { "type": "text", "id": "kit_eyebrow", "label": "Eyebrow", "default": "05 · Priemonės" },
    { "type": "text", "id": "kit_title_light", "label": "Title (light)", "default": "Viskas telpa" },
