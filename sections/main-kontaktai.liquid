{{ 'section-kontaktai.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}
<!-- ──────────── HERO ──────────── -->
<section class="khero">
  <span class="khero__eyebrow">{{ section.settings.eyebrow }}</span>
  <h1>{{ section.settings.title }}</h1>
  <p class="khero__sub">{{ section.settings.sub }}</p>
  <a class="khero__mail" href="mailto:{{ section.settings.email }}">{{ section.settings.email }} <span class="ar">→</span></a>
  <div class="khero__facts">
    <span>{{ section.settings.fact_1 }}</span>
    <span class="sep">·</span>
    <span>{{ section.settings.fact_2 }}</span>
    <span class="sep">·</span>
    <span>{{ section.settings.fact_3 }}</span>
  </div>
</section>

<div class="seam"></div>

<!-- ──────────── FORM ──────────── -->
<section class="kform">
  <div class="kform__head">
    <h2>{{ section.settings.form_title }}</h2>
    <p>{{ section.settings.form_sub }}</p>
  </div>

  {%- assign topics = section.settings.topics | split: ',' -%}
  <div class="topics" role="group" aria-label="{{ 'accessibility.topic' | t }}">
    {%- for topic in topics -%}
      <button class="topic" type="button" aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}">{{ topic | strip }}</button>
    {%- endfor -%}
  </div>

  {% form 'contact', class: 'form' %}
    {% if form.posted_successfully? %}<p class="contact-success" style="margin:0 0 var(--sp-4);color:var(--orange);font:500 15px/1.5 var(--font-sans)">{{ 'contact.sent' | t }}</p>{% endif %}
    <input type="hidden" name="contact[Tema]" id="c-topic" value="{{ topics.first | strip }}" />
    <div class="form__row">
      <div class="field">
        <label for="c-name">{{ 'contact.name' | t }}</label>
        <input id="c-name" name="contact[name]" type="text" placeholder="{{ 'contact.name_placeholder' | t }}" />
      </div>
      <div class="field">
        <label for="c-email">{{ 'contact.email' | t }}</label>
        <input id="c-email" name="contact[email]" type="email" placeholder="vardas@pavarde.lt" />
      </div>
    </div>

    <div class="form__row">
      <div class="field">
        <label for="c-order">{{ 'contact.order_number' | t }} <span class="opt">{{ 'contact.order_optional' | t }}</span></label>
        <input id="c-order" name="contact[Užsakymo numeris]" type="text" placeholder="SS-2026-####" />
      </div>
      <div class="field">
        <label for="c-country">{{ 'contact.country' | t }}</label>
        <select id="c-country" name="contact[Šalis]">
          <option>Lietuva</option>
          <option>Latvija</option>
          <option>Estija</option>
          <option>Lenkija</option>
          <option>Vokietija</option>
          <option>Kita ES šalis</option>
          <option>Už ES ribų</option>
        </select>
      </div>
    </div>

    <div class="field">
      <label for="c-msg">{{ 'contact.message' | t }}</label>
      <textarea id="c-msg" name="contact[body]" maxlength="1000" placeholder="{{ 'contact.message_placeholder' | t }}"></textarea>
      <span class="field__count"><span id="cc">0</span> / 1000</span>
    </div>

    <label class="consent">
      <input type="checkbox" name="contact[Sutikimas]" value="Taip" />
      {%- capture privacy_link -%}<a href="{{ shop.privacy_policy.url | default: '/policies/privacy-policy' }}">{{ 'contact.privacy_policy' | t }}</a>{%- endcapture -%}
      <span>{{ 'contact.consent_html' | t: policy: privacy_link }}</span>
    </label>

    <button class="btn btn--primary btn--lg" type="submit">
      {{ 'contact.send' | t }}
      <span class="btn__arrow">→</span>
    </button>
  {% endform %}
</section>

<!-- ──────────── VISIT ──────────── -->
<section class="visit">
  <div class="visit__wrap">
    <div>
      <span class="visit__eyebrow">{{ section.settings.visit_eyebrow }}</span>
      <h2>{{ section.settings.visit_title }}</h2>
      <p>{{ section.settings.visit_text }}</p>
      <div class="hours">
        {% content_for "blocks" %}
      </div>
      {%- assign map_href = settings.atelier_map_url -%}
      {%- if map_href == blank -%}
        {%- assign map_query = settings.atelier_address | append: ', ' | append: settings.atelier_city | url_encode -%}
        {%- assign map_href = 'https://maps.google.com/?q=' | append: map_query -%}
      {%- endif -%}
      <a href="{{ map_href }}" target="_blank" rel="noopener" class="btn btn--primary" style="margin-top: var(--sp-8)">
        Maršrutas žemėlapyje
        <span class="btn__arrow">→</span>
      </a>
    </div>
    <div class="minimap">
      <svg viewBox="0 0 400 275" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <rect width="400" height="275" fill="#E7E4DD"></rect>
        <g stroke="#D5D0C5" stroke-width="10" fill="none">
          <path d="M-20 100 L420 70"></path>
          <path d="M-20 190 L420 165"></path>
          <path d="M80 -20 L120 295"></path>
          <path d="M250 -20 L290 295"></path>
        </g>
        <g stroke="#CFC9BD" stroke-width="4" fill="none">
          <path d="M-20 45 L420 22"></path>
          <path d="M-20 145 L420 120"></path>
          <path d="M-20 240 L420 225"></path>
          <path d="M170 -20 L200 295"></path>
          <path d="M340 -20 L370 295"></path>
        </g>
        <g fill="#DAD5CA">
          <rect x="130" y="80" width="100" height="75" rx="3"></rect>
          <rect x="300" y="175" width="70" height="65" rx="3"></rect>
          <rect x="30" y="175" width="60" height="55" rx="3"></rect>
        </g>
        <path d="M120 130 L210 275" stroke="#0A0A0A" stroke-width="3" stroke-dasharray="2 5" fill="none" opacity="0.6"></path>
      </svg>
      <div class="minimap__pin">
        <span class="lbl">{{ settings.atelier_address | default: 'Trakų g. 16' }}</span>
        <span class="dot"></span>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'kontaktai.js' | asset_url }}" defer></script>
{% schema %}
{
  "name": "Contact",
  "max_blocks": 7,
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Kontaktai" },
    { "type": "text", "id": "title", "label": "Title", "default": "Parašykite žmonėms." },
    { "type": "textarea", "id": "sub", "label": "Subtitle", "default": "Jokios tikietų sistemos, jokių botų. Laiškus priima <b>Saulius ir Aistė</b> — tie patys, kurie kerpa odą ir pakuoja jūsų porą." },
    { "type": "text", "id": "email", "label": "Email", "default": "info@supersymmetry.lt" },
    { "type": "header", "content": "Facts" },
    { "type": "text", "id": "fact_1", "label": "Fact 1", "default": "< 24 h" },
    { "type": "text", "id": "fact_2", "label": "Fact 2", "default": "II–VI" },
    { "type": "text", "id": "fact_3", "label": "Fact 3", "default": "LT · EN" },
    { "type": "header", "content": "Form" },
    { "type": "text", "id": "form_title", "label": "Form title", "default": "Arba — tiesiog iš čia." },
    { "type": "text", "id": "form_sub", "label": "Form subtitle", "default": "Pasirinkite temą, kad laiškas iškart atsidurtų pas tinkamą žmogų." },
    { "type": "text", "id": "topics", "label": "Topics (comma-separated)", "default": "Dydis ir tinkamumas, Užsakymas, Grąžinimas, Taisymas, Didmena, Spauda, Kita" },
    { "type": "header", "content": "Visit" },
    { "type": "text", "id": "visit_eyebrow", "label": "Visit eyebrow", "default": "Užsukite" },
    { "type": "text", "id": "visit_title", "label": "Visit title", "default": "Ateljė — Vilniaus senamiestyje." },
    { "type": "textarea", "id": "visit_text", "label": "Visit text", "default": "Trakų g. 16, pačiame Vilniaus senamiestyje. Užsukite pasimatuoti arba atsiimti užsakymo." },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    { "type": "hours" }
  ],
  "presets": [{ "name": "Contact" }]
}
{% endschema %}
