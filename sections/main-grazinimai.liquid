        { "type": "text", "id": "t_light", "label": "Title (light)" },
        { "type": "text", "id": "title", "label": "Title (bold)" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "text", "id": "li1_k", "label": "Row 1 label" },
        { "type": "text", "id": "li1_v", "label": "Row 1 value" },
        { "type": "text", "id": "li2_k", "label": "Row 2 label" },
        { "type": "text", "id": "li2_v", "label": "Row 2 value" },
        { "type": "text", "id": "li3_k", "label": "Row 3 label" },
        { "type": "text", "id": "li3_v", "label": "Row 3 value" },
        { "type": "text", "id": "cta_label", "label": "Button label" },
        { "type": "url", "id": "cta_link", "label": "Button link", "info": "In-store: a maps link. Parcel: leave empty to jump to the recipient block." },
        { "type": "checkbox", "id": "dark", "label": "Dark card", "default": false }
      ]
    },
    {
      "type": "accordion_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "index", "label": "Number" },
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "Grąžinimai" }]
}
{% endschema %}
