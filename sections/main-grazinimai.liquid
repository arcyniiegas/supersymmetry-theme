  "blocks": [
    {
      "type": "stat",
      "name": "Head stat",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "value", "label": "Value" },
        { "type": "checkbox", "id": "tabular", "label": "Tabular numerals", "default": false },
        { "type": "checkbox", "id": "accent", "label": "Ink accent", "default": false }
      ]
    },
    {
      "type": "chip",
      "name": "Subnav chip",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "anchor", "label": "Anchor (parduotuve / forma / gavejas / duk)" }
      ]
    },
    {
      "type": "method",
      "name": "Return method",
      "settings": [
