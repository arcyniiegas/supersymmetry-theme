{{ 'section-cart.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}

{%- comment -%} Free-shipping threshold: global setting is in EUR major units (e.g. 100 = €100); cart money is minor units. {%- endcomment -%}
{%- assign free_threshold = settings.free_shipping_threshold | default: 100 | times: 100 -%}

<div id="cart-root" data-section-id="{{ section.id }}">

<form action="{{ routes.cart_url }}" method="post" id="cart">

<!-- ──────────── BREADCRUMBS ──────────── -->
{%- assign crumb_current = 'cart.title' | t -%}
{% render 'breadcrumbs', current: crumb_current %}

<!-- ──────────── CART HEAD ──────────── -->
<div class="carthead">
  <div>
    <h1 class="carthead__title"><span class="light">{{ section.settings.title_light | default: 'Tavo' }}</span> {{ section.settings.title | default: 'krepšelis.' }}</h1>
  </div>
  {%- unless cart.item_count == 0 -%}
  <div class="carthead__meta">
    <button type="button" class="uline" id="clearBtn">{{ section.settings.clear_label | default: 'Išvalyti krepšelį' }}</button>
  </div>
  {%- endunless -%}
</div>

{%- if cart.item_count == 0 -%}

<!-- ══════════════ EMPTY STATE ══════════════ -->
{% render 'cart-empty', section: section %}

{%- else -%}

<!-- ════════════════════════════════════════════════════════════
     SHELL
     ════════════════════════════════════════════════════════════ -->
<section class="shell">

  <!-- ITEMS -->
  <div>
    {% render 'free-shipping-bar' %}
    <!-- shipping note · honest static statement (shipping speed, not a fabricated per-country ETA) -->
    <div class="estimator">
      <span class="estimator__ico" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 4.5h9v9h-9zM10.5 7.5h3.2l2.8 3v3h-6"/><circle cx="5" cy="15" r="1.6"/><circle cx="13.5" cy="15" r="1.6"/></svg>
      </span>
      <div class="estimator__body">
        <span class="estimator__label">{{ section.settings.ship_note | default: 'Išsiunčiame per 1—2 darbo dienas iš Vilniaus.' }}</span>
      </div>
    </div>

    <div class="items" id="items">

      {%- for item in cart.items -%}
      {% render 'cart-line', item: item, index: forloop.index %}
      {%- endfor -%}
    </div>
  </div>

  <!-- SUMMARY -->
  <aside class="summary">
    <div class="summary__card">
      <div class="summary__h">{{ section.settings.summary_title | default: 'Suvestinė' }}</div>
      <div class="srow"><span class="k">{{ section.settings.label_subtotal | default: 'Tarpinė suma' }}</span><span class="v" id="sumSubtotal">{{ cart.items_subtotal_price | money_without_trailing_zeros }}</span></div>
      {%- for d in cart.cart_level_discount_applications -%}
      <div class="srow"><span class="k">{{ d.title }}</span><span class="v" id="sumDiscount">−{{ d.total_allocated_amount | money_without_trailing_zeros }}</span></div>
      {%- endfor -%}
      {%- if cart.total_price >= free_threshold -%}
      <div class="srow srow--free"><span class="k">{{ section.settings.label_shipping | default: 'Pristatymas' }}</span><span class="v" id="sumShipping">{{ section.settings.label_shipping_free | default: 'Nemokamas' }}</span></div>
      {%- else -%}
      <div class="srow"><span class="k">{{ section.settings.label_shipping | default: 'Pristatymas' }}</span><span class="v" id="sumShipping">{{ section.settings.label_shipping_calc | default: 'Skaičiuojama apmokant' }}</span></div>
      {%- endif -%}

      <!-- promo -->
      <div class="promo" id="promo">
        <input type="text" id="promoInput" placeholder="{{ section.settings.promo_placeholder | default: 'Nuolaidos kodas' | escape }}" aria-label="{{ 'cart.promo_code' | t }}" />
        <button type="button" id="promoBtn">{{ section.settings.promo_apply | default: 'Taikyti' }}</button>
      </div>
      {%- for d in cart.cart_level_discount_applications -%}
      <div class="promo__applied is-on" id="promoApplied">
        <span>{{ d.title }} · −{{ d.total_allocated_amount | money_without_trailing_zeros }}</span>
        {%- comment -%} Discount codes are managed at checkout; removal isn't supported via Cart AJAX. {# TODO: promo removal #} {%- endcomment -%}
        <button type="button" id="promoRemove">{{ 'cart.remove' | t }}</button>
      </div>
      {%- endfor -%}

      <div class="srow srow--total">
        <span class="k">{{ section.settings.label_total | default: 'Iš viso' }}</span>
        <span>
          <span class="v" id="sumTotal">{{ cart.total_price | money_without_trailing_zeros }}</span>
          {%- comment -%} PVM shown as the 21% VAT included in the tax-inclusive total. {%- endcomment -%}
          <span class="vat">{{ section.settings.vat_prefix | default: 'su PVM' }} · {{ cart.total_price | times: 21 | divided_by: 121 | money_without_trailing_zeros }}</span>
        </span>
      </div>

      <button type="submit" name="checkout" class="btn btn--orange btn--lg checkout">
        {{ section.settings.checkout_label | default: 'Apmokėti' }} <span class="btn__arrow">→</span>
      </button>

      <div class="summary__pays">
        {%- assign pays = section.settings.pay_methods | default: 'VISA, MC, AMEX, APPLE PAY, PAYPAL' | split: ',' -%}
        {%- for pay in pays -%}
        <span class="pay">{{ pay | strip }}</span>
        {%- endfor -%}
      </div>
    </div>

    <div class="summary__trust">
      <div class="trust">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M8 1.5l5.5 2.2v3.6c0 3.4-2.3 5.7-5.5 7.2-3.2-1.5-5.5-3.8-5.5-7.2V3.7L8 1.5z"/><path d="M5.8 8l1.6 1.6L10.4 6.6"/></svg>
        <span>{{ section.settings.trust_1 | default: '<b>14 dienų grąžinimas <span style="color: rgb(107, 107, 107); letter-spacing: -0.065px;">· nemokamas keitimas.</span></b>' }}</span>
      </div>
      <div class="trust">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="1.5" y="4" width="13" height="8.5" rx="1.5"/><path d="M1.5 6.8h13"/></svg>
        <span>{{ section.settings.trust_2 | default: 'Saugus mokėjimas · šifruota <b>SSL</b> jungtimi.' }}</span>
      </div>
      <div class="trust">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M1.5 11V5.5h9V11M10.5 7.5h2.2l1.8 2V11h-4M4.2 13a1.3 1.3 0 100-2.6 1.3 1.3 0 000 2.6zM11.6 13a1.3 1.3 0 100-2.6 1.3 1.3 0 000 2.6z"/></svg>
        <span>{{ section.settings.trust_3 | default: 'Išsiunčiame per <b>1–2 darbo dienas</b> iš Vilniaus.' }}</span>
      </div>
    </div>
  </aside>
</section>

{%- endif -%}

</form>

</div>

{% schema %}
{
  "name": "Cart",
  "settings": [
    { "type": "header", "content": "Head" },
    { "type": "text", "id": "title_light", "label": "Title (light part)", "default": "Tavo" },
    { "type": "text", "id": "title", "label": "Title (bold part)", "default": "krepšelis." },
    { "type": "text", "id": "clear_label", "label": "Clear-cart label", "default": "Išvalyti krepšelį" },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_eyebrow", "label": "Eyebrow", "default": "Krepšelis · <b>0 prekių</b>" },
    { "type": "text", "id": "empty_title", "label": "Title", "default": "Krepšelis kol kas <b>tuščias.</b>" },
    { "type": "textarea", "id": "empty_lede", "label": "Lede", "default": "Kiekviena pora gaminama ranka, ribota partija. Pradėk nuo šio sezono — arba grįžk ten, kur buvai." },
    { "type": "text", "id": "empty_cta_label", "label": "Primary button label", "default": "Į kolekciją" },
    { "type": "url", "id": "empty_cta_link", "label": "Primary button link" },
    { "type": "text", "id": "empty_ghost_label", "label": "Secondary button label", "info": "Leave empty to hide.", "default": "Kolekcijos" },
    { "type": "url", "id": "empty_ghost_link", "label": "Secondary button link" },
    { "type": "header", "content": "Shipping note" },
    { "type": "text", "id": "ship_note", "label": "Note", "default": "Išsiunčiame per 1—2 darbo dienas iš Vilniaus." },
    { "type": "text", "id": "ship_cost_note", "label": "Cost note", "default": "Pristatymas skaičiuojamas apmokant" },
    { "type": "header", "content": "Gift line" },
    { "type": "text", "id": "gift_prefix", "label": "Prefix", "default": "Dovana?" },
    { "type": "text", "id": "gift_link_label", "label": "Link label", "default": "Pridėk ranka rašytą kortelę" },
    { "type": "url", "id": "gift_link", "label": "Link" },
    { "type": "text", "id": "gift_suffix", "label": "Suffix", "default": "ir įvyniojimą — nemokamai." },
    { "type": "header", "content": "Summary" },
    { "type": "text", "id": "summary_title", "label": "Title", "default": "Suvestinė" },
    { "type": "text", "id": "label_subtotal", "label": "Subtotal label", "default": "Tarpinė suma" },
    { "type": "text", "id": "label_shipping", "label": "Shipping label", "default": "Pristatymas" },
    { "type": "text", "id": "label_shipping_free", "label": "Shipping — free", "default": "Nemokamas" },
    { "type": "text", "id": "label_shipping_calc", "label": "Shipping — calculated", "default": "Skaičiuojama apmokant" },
    { "type": "text", "id": "promo_placeholder", "label": "Promo placeholder", "default": "Nuolaidos kodas" },
    { "type": "text", "id": "promo_apply", "label": "Promo apply label", "default": "Taikyti" },
    { "type": "text", "id": "label_total", "label": "Total label", "default": "Iš viso" },
    { "type": "text", "id": "vat_prefix", "label": "VAT prefix", "default": "su PVM" },
    { "type": "text", "id": "checkout_label", "label": "Checkout button", "default": "Apmokėti" },
    { "type": "text", "id": "pay_methods", "label": "Payment badges (comma-separated)", "default": "VISA, MC, AMEX, APPLE PAY, PAYPAL" },
    { "type": "header", "content": "Trust rows" },
    { "type": "text", "id": "trust_1", "label": "Row 1", "default": "<b>14 dienų grąžinimas <span style=\"color: rgb(107, 107, 107); letter-spacing: -0.065px;\">· nemokamas keitimas.</span></b>" },
    { "type": "text", "id": "trust_2", "label": "Row 2", "default": "Saugus mokėjimas · šifruota <b>SSL</b> jungtimi." },
    { "type": "text", "id": "trust_3", "label": "Row 3", "default": "Išsiunčiame per <b>1–2 darbo dienas</b> iš Vilniaus." },
    { "type": "header", "content": "Text size & colour" },
    { "type": "range", "id": "title_scale", "label": "Heading size", "min": 60, "max": 130, "step": 5, "unit": "%", "default": 100 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}
