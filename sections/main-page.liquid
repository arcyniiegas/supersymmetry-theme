{% style %}
  .page-default {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(48px, 8vw, 120px) var(--sp-6, 24px) clamp(64px, 10vw, 160px);
  }
  .page-default__eyebrow {
    font: 500 12px/1 var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-50, rgba(10,10,10,0.5));
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--sp-5, 20px);
  }
  .page-default__eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--ink, #0A0A0A);
  }
  .page-default__title {
    font: 300 clamp(38px, 6vw, 72px)/0.98 var(--font-sans);
    letter-spacing: -0.04em;
    margin: 0 0 clamp(28px, 5vw, 56px);
    text-wrap: balance;
  }
  .page-default__body {
    font: 400 17px/1.7 var(--font-sans);
    letter-spacing: -0.005em;
    color: var(--ink-80, rgba(10,10,10,0.8));
  }
  .page-default__body > * + * { margin-top: 1.1em; }
  .page-default__body h2 { font: 500 26px/1.2 var(--font-sans); letter-spacing: -0.02em; margin-top: 1.8em; color: var(--ink, #0A0A0A); }
  .page-default__body h3 { font: 500 20px/1.3 var(--font-sans); letter-spacing: -0.015em; margin-top: 1.6em; color: var(--ink, #0A0A0A); }
  .page-default__body a { color: var(--ink, #0A0A0A); text-decoration: underline; text-underline-offset: 3px; }
  .page-default__body ul, .page-default__body ol { padding-left: 1.4em; }
  .page-default__body li + li { margin-top: 0.4em; }
  .page-default__body img { max-width: 100%; height: auto; border-radius: var(--r-md, 14px); }
{% endstyle %}

<section class="page-default">
  {% if section.settings.show_eyebrow %}
    <div class="page-default__eyebrow">{{ section.settings.eyebrow | default: 'Supersymmetry' }}</div>
  {% endif %}
  <h1 class="page-default__title">{{ page.title }}</h1>
  <div class="page-default__body rte">{{ page.content }}</div>
</section>

{% schema %}
{
  "name": "Page",
  "settings": [
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show eyebrow label", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Supersymmetry" }
  ]
}
{% endschema %}
