{{ 'section-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-filter-drawer.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}

<!-- ──────────── BREADCRUMBS ──────────── -->
<nav class="crumbs" aria-label="{{ 'accessibility.breadcrumb' | t }}">
  <a href="{{ routes.root_url }}">{{ 'nav.home' | t }}</a>
  <span class="sep">/</span>
  <b>{{ collection.title | default: 'Visa kolekcija' }}</b>
  {%- if section.settings.meta_label != blank -%}
  <span class="sep">/</span>
  <span>{{ section.settings.meta_label }}</span>
  {%- endif -%}
</nav>

<!-- ──────────── PAGE HEAD (a11y/SEO heading only; the visible title is the breadcrumb) ──────────── -->
<h1 class="visually-hidden">{{ collection.title | default: 'Visa kolekcija' }}</h1>

{%- comment -%} Active-filter count — needed by both the toolbar button and the drawer. {%- endcomment -%}
{%- assign active_count = 0 -%}
{%- for f in collection.filters -%}
  {%- assign active_count = active_count | plus: f.active_values.size -%}
  {%- if f.type == 'price_range' and f.min_value.value != blank -%}{%- assign active_count = active_count | plus: 1 -%}{%- endif -%}
{%- endfor -%}

<form method="get" action="{{ collection.url | default: routes.root_url }}">

<!-- ──────────── TOOLBAR (filter · sort · view) ──────────── -->
<div class="subbar">
  <div class="subbar__wrap">
    <button type="button" class="filterbtn" id="filterOpen" data-drawer-open="filterDrawer" aria-haspopup="dialog" aria-controls="filterDrawer" aria-expanded="false">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="2" y1="4.5" x2="14" y2="4.5"/><line x1="2" y1="11.5" x2="14" y2="11.5"/><circle cx="6" cy="4.5" r="1.8" fill="var(--bg)"/><circle cx="10.5" cy="11.5" r="1.8" fill="var(--bg)"/></svg>
      <span>{{ 'collection.filters' | t }}</span>
      {%- if active_count > 0 -%}<span class="filterbtn__n">{{ active_count }}</span>{%- endif -%}
    </button>

    <div class="subbar__spacer"></div>

    <div class="tools">
      <label class="tool sort">
        <span class="sort__label">{{ 'collection.sort' | t }}</span>
        <span class="sort__control">
          <select id="sortSel" name="sort_by" class="sort__select" aria-label="{{ 'collection.sort' | t }}">
            {%- if collection.sort_options != blank -%}
            {%- for opt in collection.sort_options -%}
            <option value="{{ opt.value }}"{% if opt.value == collection.sort_by %} selected{% endif %}>{{ opt.name }}</option>
            {%- endfor -%}
            {%- else -%}
            <option value="rec">{{ 'collection.sort_recommended' | t }}</option>
            <option value="price-asc">{{ 'collection.sort_price_asc' | t }}</option>
            <option value="price-desc">{{ 'collection.sort_price_desc' | t }}</option>
            <option value="name">{{ 'collection.sort_name' | t }}</option>
            {%- endif -%}
          </select>
          <svg class="sort__chev" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 5 L7 9 L11 5"></path></svg>
        </span>
      </label>
      <div class="viewtog" role="group" aria-label="{{ 'accessibility.view' | t }}">
        <button type="button" aria-pressed="false" aria-label="{{ 'accessibility.grid' | t }}">
          <svg viewBox="0 0 14 14"><rect x="2" y="2" width="4" height="4"></rect><rect x="8" y="2" width="4" height="4"></rect><rect x="2" y="8" width="4" height="4"></rect><rect x="8" y="8" width="4" height="4"></rect></svg>
        </button>
        <button type="button" aria-pressed="true" aria-label="{{ 'accessibility.grid_dense' | t }}">
          <svg viewBox="0 0 14 14"><rect x="1.5" y="1.5" width="3" height="3"></rect><rect x="5.5" y="1.5" width="3" height="3"></rect><rect x="9.5" y="1.5" width="3" height="3"></rect><rect x="1.5" y="5.5" width="3" height="3"></rect><rect x="5.5" y="5.5" width="3" height="3"></rect><rect x="9.5" y="5.5" width="3" height="3"></rect><rect x="1.5" y="9.5" width="3" height="3"></rect><rect x="5.5" y="9.5" width="3" height="3"></rect><rect x="9.5" y="9.5" width="3" height="3"></rect></svg>
        </button>
        <button type="button" aria-pressed="false" aria-label="{{ 'accessibility.list' | t }}">
          <svg viewBox="0 0 14 14"><line x1="2" y1="3" x2="12" y2="3"></line><line x1="2" y1="7" x2="12" y2="7"></line><line x1="2" y1="11" x2="12" y2="11"></line></svg>
        </button>
      </div>
    </div>
  </div>
</div>

{% paginate collection.products by section.settings.products_per_page %}
<!-- ──────────── SHELL (full-width grid; filters live in the drawer) ──────────── -->
<section class="shell" style="--card-name-scale: {{ section.settings.card_name_scale | default: 100 | divided_by: 100.0 }};">

  <!-- Active filters (Shopify Search & Discovery active values) -->
  <div class="active" id="activeRow"{% if active_count == 0 %} hidden{% endif %}>
    <span class="active__label">{{ 'collection.active_filters' | t }}</span>
    {%- for f in collection.filters -%}
      {%- for v in f.active_values -%}
        <a class="active__chip" href="{{ v.url_to_remove }}">{{ v.label }} ✕</a>
      {%- endfor -%}
    {%- endfor -%}
    <a class="active__clear" id="clearAll" href="{{ collection.url }}">{{ 'collection.clear_all' | t }}</a>
  </div>

  <!-- ─────── FILTER DRAWER (off-canvas) ─────── -->
  {% render 'collection-filter-drawer', section: section, collection: collection, paginate: paginate %}

  <!-- ─────── PRODUCT GRID (defaults to the dense/middle view) ─────── -->
  <div class="grid grid--dense">
  {%- if collection.products.size > 0 -%}
    {%- comment -%} Sold-out models always trail the in-stock ones: two passes over
      the same paginated page — available first, then unavailable. {%- endcomment -%}
    {%- for product in collection.products -%}
      {%- if product.available -%}{% render 'product-card', product: product, show_name: true %}{%- endif -%}
    {%- endfor -%}
    {%- for product in collection.products -%}
      {%- unless product.available -%}{% render 'product-card', product: product, show_name: true %}{%- endunless -%}
    {%- endfor -%}
  {%- else -%}
    <div class="card--break">
      <div>
        <div class="eyebrow">{{ section.settings.empty_eyebrow | default: 'Kolekcija ruošiama' }}</div>
        <h3><span class="light">{{ section.settings.empty_title_light | default: 'Poros' }}</span> {{ section.settings.empty_title | default: 'grįžta netrukus.' }}</h3>
        <p>{{ section.settings.empty_text | default: 'Ši kolekcija dar pildoma — užsukite po kelių dienų arba peržiūrėkite visą asortimentą.' }}</p>
      </div>
      <a class="arrow" href="{{ routes.all_products_collection_url }}" aria-label="{{ 'accessibility.full_collection' | t }}">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 8 H13 M8 3 L13 8 L8 13"></path></svg>
      </a>
    </div>
  {%- endif -%}

    <!-- Load more (only when the collection actually has products) -->
    {%- if collection.products.size > 0 -%}
    <div class="loadmore">
      <div class="loadmore__progress">
        <div>{{ 'collection.showing_html' | t: shown: collection.products.size, total: paginate.items }}</div>
        {%- assign lm_pct = 100 -%}
        {%- if paginate.items > 0 -%}{%- assign lm_pct = collection.products.size | times: 100 | divided_by: paginate.items -%}{%- endif -%}
        <div class="loadmore__bar"><i style="width: {{ lm_pct }}%;"></i></div>
      </div>
      {%- if paginate.pages > 1 -%}<div class="loadmore__pagination">{{ paginate | default_pagination }}</div>{%- endif -%}
    </div>
    {%- endif -%}

  </div><!-- /.grid -->
</section>
{% endpaginate %}

</form>

<script src="{{ 'collection.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "header", "content": "Breadcrumb" },
    { "type": "text", "id": "meta_label", "label": "Breadcrumb season/meta label", "info": "Optional trailing segment after the collection name in the breadcrumb. Leave empty to hide." },
    { "type": "header", "content": "Products" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 12, "max": 48, "step": 4, "default": 24 },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_eyebrow", "label": "Eyebrow", "default": "Kolekcija ruošiama" },
    { "type": "text", "id": "empty_title_light", "label": "Title (light part)", "default": "Poros" },
    { "type": "text", "id": "empty_title", "label": "Title (bold part)", "default": "grįžta netrukus." },
    { "type": "textarea", "id": "empty_text", "label": "Body text", "default": "Ši kolekcija dar pildoma — užsukite po kelių dienų arba peržiūrėkite visą asortimentą." },
    { "type": "header", "content": "Text size & colour" },
    { "type": "range", "id": "card_name_scale", "label": "Product card text size", "min": 70, "max": 150, "step": 5, "unit": "%", "default": 100, "info": "Scales the product name and price on each card in the grid below." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Colour scheme", "default": "scheme-1", "info": "Recolours this whole section. The default matches the rest of the site." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
