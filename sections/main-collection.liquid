{{ 'section-collection.css' | asset_url | stylesheet_tag }}
{% render 'section-appearance', section: section %}

<!-- ──────────── BREADCRUMBS ──────────── -->
<nav class="crumbs" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Pradžia</a>
  <span class="sep">/</span>
  <b>{{ collection.title | default: 'Visa kolekcija' }}</b>
  {%- if section.settings.meta_label != blank -%}
  <span class="sep">/</span>
  <span>{{ section.settings.meta_label }}</span>
  {%- endif -%}
</nav>

<!-- ──────────── PAGE HEAD ──────────── -->
<section class="phead">
  <div>
    {%- if section.settings.show_eyebrow -%}
    <div class="phead__eyebrow">{{ section.settings.eyebrow_prefix | default: 'Kolekcija' }} · <b>{{ collection.products_count }}</b> modelių</div>
    {%- endif -%}
    <h1 class="phead__title">
      {%- if collection.title != blank -%}
      {{ collection.title }}
      {%- else -%}
      <span class="light">{{ section.settings.default_title_light | default: 'Visa' }}</span>
      {{ section.settings.default_title | default: 'kolekcija.' }}
      {%- endif -%}
    </h1>
  </div>

</section>

{%- comment -%} Active-filter count — needed by both the toolbar button and the drawer. {%- endcomment -%}
{%- assign active_count = 0 -%}
{%- for f in collection.filters -%}
  {%- assign active_count = active_count | plus: f.active_values.size -%}
  {%- if f.type == 'price_range' and f.min_value.value != blank -%}{%- assign active_count = active_count | plus: 1 -%}{%- endif -%}
{%- endfor -%}

<form method="get" action="{{ collection.url | default: routes.root_url }}">

<!-- ──────────── TOOLBAR (filter · sort · view) ──────────── -->
<div class="subbar">
  <div class="subbar__wrap">
    <button type="button" class="filterbtn" id="filterOpen" aria-haspopup="dialog" aria-controls="filterDrawer" aria-expanded="false">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="2" y1="4.5" x2="14" y2="4.5"/><line x1="2" y1="11.5" x2="14" y2="11.5"/><circle cx="6" cy="4.5" r="1.8" fill="var(--bg)"/><circle cx="10.5" cy="11.5" r="1.8" fill="var(--bg)"/></svg>
      <span>Filtrai</span>
      {%- if active_count > 0 -%}<span class="filterbtn__n">{{ active_count }}</span>{%- endif -%}
    </button>

    <div class="subbar__spacer"></div>

    <div class="tools">
      <label class="tool sort">
        <span class="sort__label">Rūšiuoti</span>
        <span class="sort__control">
          <select id="sortSel" name="sort_by" class="sort__select" aria-label="Rūšiuoti">
            {%- if collection.sort_options != blank -%}
            {%- for opt in collection.sort_options -%}
            <option value="{{ opt.value }}"{% if opt.value == collection.sort_by %} selected{% endif %}>{{ opt.name }}</option>
            {%- endfor -%}
            {%- else -%}
            <option value="rec">Rekomenduojama</option>
            <option value="price-asc">Kaina ↑</option>
            <option value="price-desc">Kaina ↓</option>
            <option value="name">Pagal pavadinimą</option>
            {%- endif -%}
          </select>
          <svg class="sort__chev" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 5 L7 9 L11 5"></path></svg>
        </span>
      </label>
      <div class="viewtog" role="group" aria-label="Vaizdas">
        <button type="button" aria-pressed="true" aria-label="Tinklelis">
          <svg viewBox="0 0 14 14"><rect x="2" y="2" width="4" height="4"></rect><rect x="8" y="2" width="4" height="4"></rect><rect x="2" y="8" width="4" height="4"></rect><rect x="8" y="8" width="4" height="4"></rect></svg>
        </button>
        <button type="button" aria-pressed="false" aria-label="Tankus tinklelis">
          <svg viewBox="0 0 14 14"><rect x="1.5" y="1.5" width="3" height="3"></rect><rect x="5.5" y="1.5" width="3" height="3"></rect><rect x="9.5" y="1.5" width="3" height="3"></rect><rect x="1.5" y="5.5" width="3" height="3"></rect><rect x="5.5" y="5.5" width="3" height="3"></rect><rect x="9.5" y="5.5" width="3" height="3"></rect><rect x="1.5" y="9.5" width="3" height="3"></rect><rect x="5.5" y="9.5" width="3" height="3"></rect><rect x="9.5" y="9.5" width="3" height="3"></rect></svg>
        </button>
        <button type="button" aria-pressed="false" aria-label="Sąrašas">
          <svg viewBox="0 0 14 14"><line x1="2" y1="3" x2="12" y2="3"></line><line x1="2" y1="7" x2="12" y2="7"></line><line x1="2" y1="11" x2="12" y2="11"></line></svg>
        </button>
      </div>
    </div>
  </div>
</div>

{% paginate collection.products by section.settings.products_per_page %}
<!-- ──────────── SHELL (full-width grid; filters live in the drawer) ──────────── -->
<section class="shell" style="--card-name-scale: {{ section.settings.card_name_scale | default: 100 | divided_by: 100.0 }};">

  <!-- Active filters (Shopify Search & Discovery active values) -->
  <div class="active" id="activeRow"{% if active_count == 0 %} hidden{% endif %}>
    <span class="active__label">Aktyvūs filtrai</span>
    {%- for f in collection.filters -%}
      {%- for v in f.active_values -%}
        <a class="active__chip" href="{{ v.url_to_remove }}">{{ v.label }} ✕</a>
      {%- endfor -%}
    {%- endfor -%}
    <a class="active__clear" id="clearAll" href="{{ collection.url }}">Išvalyti viską</a>
  </div>

  <!-- ─────── FILTER DRAWER (off-canvas) ─────── -->
  <div class="fdrawer" id="filterDrawer" role="dialog" aria-modal="true" aria-label="Filtrai">
    <div class="fdrawer__scrim" data-drawer-close></div>
    <aside class="fdrawer__panel">
      <div class="fdrawer__head">
        <span class="fdrawer__title">Filtrai{% if active_count > 0 %} <span class="n">{{ active_count }}</span>{% endif %}</span>
        <button class="fdrawer__close" type="button" data-drawer-close aria-label="Uždaryti">
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M3 3l8 8M11 3l-8 8"/></svg>
        </button>
      </div>
      <div class="fdrawer__body">

    {%- assign rendered_filter = false -%}
    {%- for f in collection.filters -%}
      {%- assign flabel = f.label | downcase -%}
      {%- if f.type == 'list' and flabel contains 'spalva' -%}
        {%- assign rendered_filter = true -%}
    <details class="facet" open>
      <summary>{{ f.label }} <span class="meta">{{ f.active_values.size }} / {{ f.values.size }}</span></summary>
      <div class="facet__body">
        <div class="swatches" role="group" aria-label="{{ f.label | escape }}">
          {%- for v in f.values -%}
            {%- assign sw = 'var(--surface)' -%}
            {%- if v.swatch.color != blank -%}
              {%- assign sw = v.swatch.color -%}
            {%- else -%}
              {%- assign vname = v.label | downcase -%}
              {%- case vname -%}
                {%- when 'noir', 'juoda' -%}{%- assign sw = '#0A0A0A' -%}
                {%- when 'écru', 'kreminė' -%}{%- assign sw = '#E9DFCB' -%}
                {%- when 'marron', 'ruda' -%}{%- assign sw = '#5C3A28' -%}
                {%- when 'cognac', 'konjako' -%}{%- assign sw = '#9A5A2E' -%}
                {%- when 'cordovan', 'bordo' -%}{%- assign sw = '#4A1E1E' -%}
                {%- when 'blanc', 'balta' -%}{%- assign sw = '#F4F1EA' -%}
                {%- when 'velours', 'smėlio' -%}{%- assign sw = '#C7A57B' -%}
                {%- when 'bleu nuit', 'mėlyna' -%}{%- assign sw = '#1B2536' -%}
              {%- endcase -%}
            {%- endif -%}
            <button class="swatch" data-name="{{ v.label | escape }}" aria-pressed="{{ v.active }}" type="button" style="background:{{ sw }};"
              data-filter-url="{% if v.active %}{{ v.url_to_remove }}{% else %}{{ v.url_to_add }}{% endif %}"{% if v.count == 0 and v.active == false %} data-disabled="true" disabled{% endif %} title="{{ v.label | escape }} ({{ v.count }})"></button>
          {%- endfor -%}
        </div>
      </div>
    </details>
      {%- elsif f.type == 'list' and flabel contains 'dydis' -%}
        {%- assign rendered_filter = true -%}
    <details class="facet" open>
      <summary>{{ f.label }} <span class="meta">{{ f.active_values.size }} / {{ f.values.size }}</span></summary>
      <div class="facet__body">
        <div class="sizes" role="group" aria-label="{{ f.label | escape }}">
          {%- for v in f.values -%}
          <button class="size" type="button" aria-pressed="{{ v.active }}"
            data-filter-url="{% if v.active %}{{ v.url_to_remove }}{% else %}{{ v.url_to_add }}{% endif %}"{% if v.count == 0 and v.active == false %} data-disabled="true" disabled{% endif %}>{{ v.label }}</button>
          {%- endfor -%}
        </div>
      </div>
    </details>
      {%- elsif f.type == 'price_range' -%}
        {%- assign rendered_filter = true -%}
        {%- assign pmax = f.range_max | divided_by: 100.0 | ceil -%}
    <details class="facet">
      <summary>Kaina · EUR <span class="meta">0 — {{ pmax }}</span></summary>
      <div class="facet__body">
        <div class="price">
          <div class="price__bar" aria-hidden="true">
            <span class="fill"></span>
            <span class="knob lo"></span>
            <span class="knob hi"></span>
          </div>
          <div class="price__row">
            <div class="price__field">
              <label>Min</label>
              <input type="text" value="{% if f.min_value.value %}{{ f.min_value.value | divided_by: 100.0 | floor }}{% endif %}" placeholder="0" inputmode="numeric" data-price-min data-param="{{ f.min_value.param_name }}">
            </div>
            <div class="price__field">
              <label>Max</label>
              <input type="text" value="{% if f.max_value.value %}{{ f.max_value.value | divided_by: 100.0 | ceil }}{% endif %}" placeholder="{{ pmax }}" inputmode="numeric" data-price-max data-param="{{ f.max_value.param_name }}">
            </div>
          </div>
        </div>
      </div>
    </details>
      {%- endif -%}
    {%- endfor -%}

    {%- unless rendered_filter -%}
    {%- comment -%} No Search & Discovery filters configured — prototype visual shells (non-filtering). {%- endcomment -%}
    <details class="facet" open>
      <summary>Spalva <span class="meta">0 / 8</span></summary>
      <div class="facet__body">
        <div class="swatches" role="group" aria-label="Spalvos">
          <button class="swatch" data-name="noir" aria-pressed="false" type="button" style="background:#0A0A0A;"></button>
          <button class="swatch" data-name="écru" aria-pressed="false" type="button" style="background:#E9DFCB;"></button>
          <button class="swatch" data-name="marron" aria-pressed="false" type="button" style="background:#5C3A28;"></button>
          <button class="swatch" data-name="cognac" aria-pressed="false" type="button" style="background:#9A5A2E;"></button>
          <button class="swatch" data-name="cordovan" aria-pressed="false" type="button" style="background:#4A1E1E;"></button>
          <button class="swatch" data-name="blanc" aria-pressed="false" type="button" style="background:#F4F1EA;"></button>
          <button class="swatch" data-name="velours" aria-pressed="false" type="button" style="background:#C7A57B;"></button>
          <button class="swatch" data-name="bleu nuit" aria-pressed="false" type="button" style="background:#1B2536;"></button>
        </div>
      </div>
    </details>
    {%- endunless -%}

      </div><!-- /.fdrawer__body -->
      <div class="fdrawer__foot">
        <a class="fdrawer__reset" href="{{ collection.url }}">Išvalyti viską</a>
        <button class="btn btn--primary" type="button" data-drawer-close>Rodyti ({{ paginate.items }})</button>
      </div>
    </aside>
  </div><!-- /.fdrawer -->

  <!-- ─────── PRODUCT GRID ─────── -->
  <div class="grid">
  {%- if collection.products.size > 0 -%}
    {%- for product in collection.products -%}
    {% render 'product-card', product: product, show_name: true %}
    {%- endfor -%}
  {%- else -%}
    <div class="card--break" style="text-decoration:none;">
      <div>
        <div class="eyebrow">{{ section.settings.empty_eyebrow | default: 'Kolekcija ruošiama' }}</div>
        <h3 style="margin-top:14px;"><span class="light">{{ section.settings.empty_title_light | default: 'Poros' }}</span> {{ section.settings.empty_title | default: 'grįžta netrukus.' }}</h3>
        <p>{{ section.settings.empty_text | default: 'Ši kolekcija dar pildoma — užsukite po kelių dienų arba peržiūrėkite visą asortimentą.' }}</p>
      </div>
      <a class="arrow" href="{{ routes.all_products_collection_url }}" aria-label="Visa kolekcija">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 8 H13 M8 3 L13 8 L8 13"></path></svg>
      </a>
    </div>
  {%- endif -%}

    <!-- Load more (only when the collection actually has products) -->
    {%- if collection.products.size > 0 -%}
    <div class="loadmore">
      <div class="loadmore__progress">
        <div>Rodoma <b>{{ collection.products.size }}</b> iš <b>{{ paginate.items }}</b> modelių</div>
        <div class="loadmore__bar"><i></i></div>
      </div>
      {%- if paginate.pages > 1 -%}<div class="loadmore__pagination">{{ paginate | default_pagination }}</div>{%- endif -%}
    </div>
    {%- endif -%}

  </div><!-- /.grid -->
</section>
{% endpaginate %}

</form>

{%- if section.settings.show_notes -%}
<!-- ──────────── APIE KOLEKCIJĄ ──────────── -->
<section class="notes">
  <div class="notes__wrap">
    <div class="notes__lede">
      <div class="notes__eyebrow">{{ section.settings.notes_eyebrow | default: 'Apie kolekciją' }}</div>
      <h2 class="notes__title">{{ section.settings.notes_title | default: 'Kaip mąstome' }} <span class="light">{{ section.settings.notes_title_light | default: 'apie partijas.' }}</span></h2>
      <p>{{ section.settings.notes_text | default: 'Kiekvienas modelis pagaminamas tik vieną kartą — 500 porų partija, sunumeruota nuo 001 iki 500. Kai partija baigiasi, modelio nebeatkartojame. Tai vieninteliai mūsų „naujienos“ — todėl ir patikrinkite šį puslapį prieš sezoną.' }}</p>
      {%- if section.settings.notes_cta_label != blank -%}
      <a href="{{ section.settings.notes_cta_link | default: pages['apie-mus'].url | default: routes.root_url }}" class="btn btn--primary" style="justify-self:start;">
        {{ section.settings.notes_cta_label }}
        <span class="btn__arrow">→</span>
      </a>
      {%- endif -%}
    </div>
    <div class="notes__list" aria-label="Kolekcijos paaiškinimai">
      {%- assign note_blocks = section.blocks | where: 'type', 'note_row' -%}
      {%- if note_blocks.size > 0 -%}
        {%- for block in note_blocks -%}
      <div class="notes__row" {{ block.shopify_attributes }}>
        <span class="idx">{{ block.settings.index | default: '01' }}</span>
        <span class="lbl">{{ block.settings.label }}
          <span>{{ block.settings.sub }}</span>
        </span>
        <span class="val">{{ block.settings.value }}</span>
      </div>
        {%- endfor -%}
      {%- else -%}
      <div class="notes__row">
        <span class="idx">01</span>
        <span class="lbl">Sezoninės partijos
          <span>Du kartus per metus — pavasaris ir ruduo. Pre-order atsidaro likus mėnesiui iki gamybos pabaigos.</span>
        </span>
        <span class="val">04 · 25</span>
      </div>
      <div class="notes__row">
        <span class="idx">02</span>
        <span class="lbl">Numeruota
          <span>Kiekviena pora turi savo numerį tarp 001 ir 500 — pažymėta lieto cinko plokštele ant liežuvėlio.</span>
        </span>
        <span class="val">001 — 500</span>
      </div>
      <div class="notes__row">
        <span class="idx">03</span>
        <span class="lbl">Niekada nepakartojama
          <span>Išparduotos partijos negrįžta į gamybą. Kitas sezonas — kita partija, kitas kurpalis.</span>
        </span>
        <span class="val">∅ restock</span>
      </div>
      <div class="notes__row">
        <span class="idx">04</span>
        <span class="lbl">Padų keitimas
          <span>Bet kuriai porai — net iš 2019-ųjų — pakeisime padus už fiksuotą kainą Vilniuje arba Felgueiras.</span>
        </span>
        <span class="val">€85 · per amžinybę</span>
      </div>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

<script src="{{ 'collection.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "header", "content": "Page head" },
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show \"Kolekcija · N modelių\" eyebrow", "default": true },
    { "type": "text", "id": "eyebrow_prefix", "label": "Eyebrow prefix", "default": "Kolekcija", "info": "Shown as \"[prefix] · N modelių\". The count is always live." },
    { "type": "text", "id": "meta_label", "label": "Breadcrumb season/meta label", "default": "Pavasaris–Vasara 2026", "info": "Leave empty to hide. Only shown for the all-products page (real collections show their own title)." },
    { "type": "text", "id": "default_title_light", "label": "Fallback title (light part)", "default": "Visa", "info": "Used only when this page has no collection title (the all-products page)." },
    { "type": "text", "id": "default_title", "label": "Fallback title (bold part)", "default": "kolekcija." },
    { "type": "header", "content": "Products" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 12, "max": 48, "step": 4, "default": 24 },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_eyebrow", "label": "Eyebrow", "default": "Kolekcija ruošiama" },
    { "type": "text", "id": "empty_title_light", "label": "Title (light part)", "default": "Poros" },
    { "type": "text", "id": "empty_title", "label": "Title (bold part)", "default": "grįžta netrukus." },
    { "type": "textarea", "id": "empty_text", "label": "Body text", "default": "Ši kolekcija dar pildoma — užsukite po kelių dienų arba peržiūrėkite visą asortimentą." },
    { "type": "header", "content": "\"About the collection\" section" },
    { "type": "checkbox", "id": "show_notes", "label": "Show this section", "default": true },
    { "type": "text", "id": "notes_eyebrow", "label": "Eyebrow", "default": "Apie kolekciją" },
    { "type": "text", "id": "notes_title", "label": "Title (bold part)", "default": "Kaip mąstome" },
    { "type": "text", "id": "notes_title_light", "label": "Title (light part)", "default": "apie partijas." },
    { "type": "textarea", "id": "notes_text", "label": "Body text", "default": "Kiekvienas modelis pagaminamas tik vieną kartą — 500 porų partija, sunumeruota nuo 001 iki 500. Kai partija baigiasi, modelio nebeatkartojame. Tai vieninteliai mūsų „naujienos“ — todėl ir patikrinkite šį puslapį prieš sezoną." },
    { "type": "text", "id": "notes_cta_label", "label": "Button label", "default": "Mūsų istorija", "info": "Leave empty to hide the button." },
    { "type": "url", "id": "notes_cta_link", "label": "Button link" },
    { "type": "header", "content": "Text size & colour" },
    { "type": "range", "id": "title_scale", "label": "Heading size", "min": 60, "max": 130, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "card_name_scale", "label": "Product card text size", "min": 70, "max": 150, "step": 5, "unit": "%", "default": 100, "info": "Scales the product name and price on each card in the grid below." },
    { "type": "color", "id": "text_color", "label": "Text colour", "info": "Recolours this section's text. Leave empty for the default near-black." }
  ],
  "blocks": [
    { "type": "@app" },
    {
      "type": "note_row",
      "name": "About · row",
      "settings": [
        { "type": "text", "id": "index", "label": "Row number", "default": "01" },
        { "type": "text", "id": "label", "label": "Label", "default": "Row title" },
        { "type": "textarea", "id": "sub", "label": "Description" },
        { "type": "text", "id": "value", "label": "Value (right-aligned)" }
      ]
    }
  ]
}
{% endschema %}
