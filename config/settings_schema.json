[
  {
    "name": "theme_info",
    "theme_name": "Supersymmetry",
    "theme_version": "2.0.0",
    "theme_author": "Supersymmetry",
    "theme_documentation_url": "https://supersymmetry.lt",
    "theme_support_url": "https://supersymmetry.lt"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          { "type": "color", "id": "background",   "default": "#FFFFFF", "label": "Background" },
          { "type": "color_background", "id": "background_gradient", "label": "Background gradient", "info": "Optional. Overlays the solid background where supported." },
          { "type": "color", "id": "text",         "default": "#0A0A0A", "label": "Text" },
          { "type": "color", "id": "surface",      "default": "#F5F5F5", "label": "Surface" },
          { "type": "color", "id": "line",         "default": "#EEEEEE", "label": "Lines & borders" },
          { "type": "color", "id": "button",       "default": "#0A0A0A", "label": "Button" },
          { "type": "color", "id": "button_label", "default": "#FFFFFF", "label": "Button label" }
        ],
        "role": {
          "background": { "solid": "background", "gradient": "background_gradient" },
          "text": "text",
          "primary_button": "button",
          "on_primary_button": "button_label",
          "primary_button_border": "button",
          "secondary_button": "surface",
          "on_secondary_button": "text",
          "secondary_button_border": "line",
          "links": "text",
          "icons": "text"
        }
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "paragraph", "content": "Sizes the editorial heading ramp site-wide. The brand face (Geist) is fixed. Individual sections can still fine-tune their own heading size under each section's Appearance settings." },
      { "type": "range", "id": "type_scale", "label": "Heading type scale", "min": 85, "max": 120, "step": 5, "unit": "%", "default": 100, "info": "Scales every heading and display title together. 100% = the current design." }
    ]
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand wordmark",
        "info": "Header, mobile menu, footer and password page.",
        "default": "Supersymmetry"
      },
      {
        "type": "text",
        "id": "utility_right_message",
        "label": "Utility bar — right message",
        "info": "Also shown in the mobile-menu footer.",
        "default": "LT · EN"
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold (€)",
        "default": 100
      },
      {
        "type": "text",
        "id": "phone",
        "label": "Phone",
        "info": "Shown in the search page's no-results tips.",
        "default": "+370 5 250 7700"
      }
    ]
  },
  {
    "name": "Dock (mobile navigation)",
    "settings": [
      { "type": "text", "id": "dock_label_home", "label": "Home label", "default": "Pradžia" },
      { "type": "text", "id": "dock_label_products", "label": "Products label", "default": "Gaminiai" },
      { "type": "text", "id": "dock_label_search", "label": "Search label", "default": "Paieška" },
      { "type": "text", "id": "dock_label_cart", "label": "Cart label", "default": "Krepšelis" },
      { "type": "text", "id": "dock_label_menu", "label": "Menu label", "default": "Meniu" }
    ]
  },
  {
    "name": "Search overlay",
    "settings": [
      { "type": "text", "id": "search_eyebrow", "label": "Eyebrow", "default": "Paieška · <b>visa kolekcija</b>" },
      { "type": "text", "id": "search_placeholder", "label": "Input placeholder", "default": "Ko ieškai?" },
      { "type": "text", "id": "search_popular_label", "label": "Suggestions label", "default": "Populiaru" },
      { "type": "textarea", "id": "search_empty_lede", "label": "No-results text", "default": "Galbūt ši pora dar archyve arba ruošiama kitai partijai. Pabandyk plačiau — pagal spalvą ar modelį." }
    ]
  },
  {
    "name": "Cookie consent",
    "settings": [
      {
        "type": "paragraph",
        "content": "On-brand GDPR banner driven by Shopify's Customer Privacy API. The store currently uses Shopify's built-in banner (Settings → Customer privacy in admin) — enable this one ONLY after turning that one off, or visitors will see two banners."
      },
      { "type": "checkbox", "id": "consent_enabled", "label": "Show theme consent banner", "default": false },
      { "type": "textarea", "id": "consent_text", "label": "Banner text (privacy-policy link is appended)", "default": "Naudojame slapukus parduotuvės veikimui ir anoniminei statistikai. Rinktis gali pats —" },
      { "type": "text", "id": "consent_policy_label", "label": "Privacy link label", "default": "privatumo politika" },
      { "type": "text", "id": "consent_accept_label", "label": "Accept button", "default": "Sutinku" },
      { "type": "text", "id": "consent_decline_label", "label": "Decline button", "default": "Tik būtini" }
    ]
  },
  {
    "name": "Navigation",
    "settings": [
      {
        "type": "link_list",
        "id": "menu_main",
        "label": "Main menu",
        "info": "Header nav + mobile menu primary links."
      },
      {
        "type": "link_list",
        "id": "menu_secondary",
        "label": "Secondary menu",
        "info": "Mobile menu link cloud (sizes, returns, FAQ…)."
      },
      {
        "type": "text",
        "id": "search_chips",
        "label": "Search quick terms",
        "info": "Comma-separated. Optional count after | (e.g. penny|12).",
        "default": "bateliai, basutės, aulinukai, rankinės, šalikai, kepurės"
      }
    ]
  },
  {
    "name": "Atelier",
    "settings": [
      {
        "type": "paragraph",
        "content": "Single source for the atelier identity — used by the visit sections, contact page, mobile menu footer and structured data."
      },
      {
        "type": "text",
        "id": "atelier_address",
        "label": "Street address",
        "default": "Trakų g. 16"
      },
      {
        "type": "text",
        "id": "atelier_city",
        "label": "City line",
        "default": "Vilnius"
      },
      {
        "type": "url",
        "id": "atelier_map_url",
        "label": "Map link"
      }
    ]
  },
  {
    "name": "Liquid glass",
    "settings": [
      {
        "type": "checkbox",
        "id": "glass_enabled",
        "label": "Enable liquid-glass surfaces",
        "info": "Header, dock, menu and panels render with translucent blur. Off = solid fallbacks.",
        "default": true
      },
      {
        "type": "range",
        "id": "glass_blur",
        "label": "Glass panel blur",
        "min": 4,
        "max": 30,
        "step": 1,
        "unit": "px",
        "default": 12
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      }
    ]
  },
  {
    "name": "Mobile menu",
    "settings": [
      {
        "type": "header",
        "content": "Featured tiles"
      },
      {
        "type": "paragraph",
        "content": "Two image tiles shown in the mobile menu. Each tile needs an image and link to appear."
      },
      {
        "type": "image_picker",
        "id": "menu_tile_1_image",
        "label": "Tile 1 image"
      },
      {
        "type": "text",
        "id": "menu_tile_1_label",
        "label": "Tile 1 label"
      },
      {
        "type": "url",
        "id": "menu_tile_1_link",
        "label": "Tile 1 link"
      },
      {
        "type": "image_picker",
        "id": "menu_tile_2_image",
        "label": "Tile 2 image"
      },
      {
        "type": "text",
        "id": "menu_tile_2_label",
        "label": "Tile 2 label"
      },
      {
        "type": "url",
        "id": "menu_tile_2_link",
        "label": "Tile 2 link"
      }
    ]
  }
]
