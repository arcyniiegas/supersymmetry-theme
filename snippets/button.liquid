{%- comment -%}
  button — the theme's single button / CTA primitive.
  Renders the .btn markup used across every section, so the button exists once.

  Usage:
    {% render 'button', label: 'Apžiūrėti', href: product.url %}
    {% render 'button', label: 'Apžiūrėti', href: url, style: 'primary', arrow: true %}
    {% render 'button', label: 'Mūsų istorija', href: url, style: 'secondary' %}

  Params:
    label      (string, required) — visible text.
    href       (string)  — link target. Defaults to '#'.
    style      (string)  — 'primary' | 'secondary' | 'ghost' | 'orange' | 'link'. Default 'primary'.
    size       (string)  — e.g. 'lg' → adds btn--lg. Optional.
    arrow      (boolean) — append the trailing → glyph. Default false.
    aria_label (string)  — accessible name when the label alone isn't enough.
    target     (string)  — e.g. '_blank' (adds rel="noopener" automatically).
    id         (string)  — optional element id.
    class      (string)  — extra classes appended after the .btn base.
{%- endcomment -%}
{%- liquid
  assign btn_style = style | default: 'primary'
  assign btn_href = href | default: '#'
-%}
<a href="{{ btn_href }}" class="btn btn--{{ btn_style }}{% if size %} btn--{{ size }}{% endif %}{% if class %} {{ class }}{% endif %}"{% if id %} id="{{ id }}"{% endif %}{% if aria_label %} aria-label="{{ aria_label | escape }}"{% endif %}{% if target %} target="{{ target }}" rel="noopener"{% endif %}>{{ label }}{% if arrow %} <span class="btn__arrow">→</span>{% endif %}</a>
