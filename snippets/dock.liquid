{%- liquid
  assign is_home = false
  assign is_coll = false
  if request.page_type == 'index'
    assign is_home = true
  endif
  if request.page_type == 'collection' or request.page_type == 'collections' or request.page_type == 'product' or request.page_type == 'list-collections'
    assign is_coll = true
  endif
-%}
<div class="dockwrap">
  <nav class="dock" aria-label="{{ 'accessibility.navigation' | t }}">
    {%- assign l_home = settings.dock_label_home | default: 'Pradžia' -%}
    {%- assign l_products = settings.dock_label_products | default: 'Gaminiai' -%}
    {%- assign l_search = settings.dock_label_search | default: 'Paieška' -%}
    {%- assign l_cart = settings.dock_label_cart | default: 'Krepšelis' -%}
    {%- assign l_menu = settings.dock_label_menu | default: 'Meniu' -%}
    <a class="dock__item" href="{{ routes.root_url }}"{% if is_home %} aria-current="page"{% endif %} aria-label="{{ l_home | escape }}">
      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3.2 9.4 L10 3.6 L16.8 9.4 M5 8 V15.6 A0.8 0.8 0 0 0 5.8 16.4 H14.2 A0.8 0.8 0 0 0 15 15.6 V8 M8.4 16.4 V11.9 A0.4 0.4 0 0 1 8.8 11.5 H11.2 A0.4 0.4 0 0 1 11.6 11.9 V16.4"/></svg>
      <span class="dock__label">{{ l_home }}</span></a>
    <a class="dock__item" href="{{ routes.collections_url }}"{% if is_coll %} aria-current="page"{% endif %} aria-label="{{ l_products | escape }}">
      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M2.8 13.4 C2.8 11.6 3.5 10.4 4.7 10.4 C5.5 10.4 6 11 6.6 11.8 C7.5 13 8.5 13.4 10.3 13.4 L15.8 13.4 C16.9 13.4 17.4 13.9 17.4 14.6 C17.4 15.3 16.9 15.6 16.2 15.6 L4.2 15.6 C3.3 15.6 2.8 14.7 2.8 13.4 Z"/><path d="M8.6 12.3 C9.8 11.6 11.4 11.7 12.6 12.5"/></svg>
      <span class="dock__label">{{ l_products }}</span></a>
    <a class="dock__item" href="{{ routes.search_url }}"{% if request.page_type == 'search' %} aria-current="page"{% endif %} aria-label="{{ l_search | escape }}" data-search-open>
      <svg viewBox="0 0 20 20" aria-hidden="true"><circle cx="9" cy="9" r="5.2"/><path d="M12.8 12.8 L16.6 16.6"/></svg>
      <span class="dock__label">{{ l_search }}</span></a>
    <a class="dock__item" href="{{ routes.cart_url }}"{% if request.page_type == 'cart' %} aria-current="page"{% else %} data-drawer-open="cartDrawer"{% endif %} aria-label="{{ l_cart | escape }}">
      <span class="dock__badge" data-bag-count{% if cart.item_count == 0 %} style="display:none"{% endif %}>{{ cart.item_count }}</span>
      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M6 6.4 H14 L14.8 15.8 A0.7 0.7 0 0 1 14.1 16.6 H5.9 A0.7 0.7 0 0 1 5.2 15.8 Z M7.8 6.4 V5.6 A2.2 2.2 0 0 1 12.2 5.6 V6.4"/></svg>
      <span class="dock__label">{{ l_cart }}</span></a>
    <button type="button" class="dock__item" data-drawer-open="ssMenu" aria-label="{{ l_menu | escape }}" aria-haspopup="dialog">
      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3.4 6.2 H16.6 M3.4 10 H16.6 M3.4 13.8 H12.2"/></svg>
      <span class="dock__label">{{ l_menu }}</span></button>
  </nav>
</div>
