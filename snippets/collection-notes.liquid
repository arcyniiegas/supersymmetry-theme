{%- comment -%} Collection — notes section (note_row blocks). Rendered by main-collection. {%- endcomment -%}
<section class="notes">
  <div class="notes__wrap">
    <div class="notes__lede">
      <div class="eyebrow eyebrow--rule">{{ section.settings.notes_eyebrow | default: 'Apie kolekciją' }}</div>
      <h2 class="notes__title">{{ section.settings.notes_title | default: 'Kaip mąstome' }} <span class="light">{{ section.settings.notes_title_light | default: 'apie partijas.' }}</span></h2>
      <p>{{ section.settings.notes_text | default: 'Kiekvienas modelis pagaminamas tik vieną kartą — 500 porų partija, sunumeruota nuo 001 iki 500. Kai partija baigiasi, modelio nebeatkartojame. Tai vieninteliai mūsų „naujienos“ — todėl ir patikrinkite šį puslapį prieš sezoną.' }}</p>
      {%- if section.settings.notes_cta_label != blank -%}
      <a href="{{ section.settings.notes_cta_link | default: pages['apie-mus'].url | default: routes.root_url }}" class="btn btn--primary" style="justify-self:start;">
        {{ section.settings.notes_cta_label }}
        <span class="btn__arrow">→</span>
      </a>
      {%- endif -%}
    </div>
    <div class="notes__list" aria-label="Kolekcijos paaiškinimai">
      {%- assign note_blocks = section.blocks | where: 'type', 'note_row' -%}
      {%- if note_blocks.size > 0 -%}
        {%- for block in note_blocks -%}
      <div class="notes__row" {{ block.shopify_attributes }}>
        <span class="idx">{{ block.settings.index | default: '01' }}</span>
        <span class="lbl">{{ block.settings.label }}
          <span>{{ block.settings.sub }}</span>
        </span>
        <span class="val">{{ block.settings.value }}</span>
      </div>
        {%- endfor -%}
      {%- else -%}
      <div class="notes__row">
        <span class="idx">01</span>
        <span class="lbl">Sezoninės partijos
          <span>Du kartus per metus — pavasaris ir ruduo. Pre-order atsidaro likus mėnesiui iki gamybos pabaigos.</span>
        </span>
        <span class="val">04 · 25</span>
      </div>
      <div class="notes__row">
        <span class="idx">02</span>
        <span class="lbl">Numeruota
          <span>Kiekviena pora turi savo numerį tarp 001 ir 500 — pažymėta lieto cinko plokštele ant liežuvėlio.</span>
        </span>
        <span class="val">001 — 500</span>
      </div>
      <div class="notes__row">
        <span class="idx">03</span>
        <span class="lbl">Niekada nepakartojama
          <span>Išparduotos partijos negrįžta į gamybą. Kitas sezonas — kita partija, kitas kurpalis.</span>
        </span>
        <span class="val">∅ restock</span>
      </div>
      <div class="notes__row">
        <span class="idx">04</span>
        <span class="lbl">Padų keitimas
          <span>Bet kuriai porai — net iš 2019-ųjų — pakeisime padus už fiksuotą kainą Vilniuje arba Felgueiras.</span>
        </span>
        <span class="val">€85 · per amžinybę</span>
      </div>
      {%- endif -%}
    </div>
  </div>
</section>
