{%- comment -%}
  Free-shipping progress meter. Shared by the cart drawer and the cart page.
  All amounts are Liquid-computed against settings.free_shipping_threshold
  (EUR major units; cart money is minor units) — authoritative, never faked in
  JS. Renders nothing when the threshold is unset/zero, so disabling free
  shipping is a single setting change with no dangling UI.
{%- endcomment -%}
{%- assign threshold = settings.free_shipping_threshold | default: 100 | times: 100 -%}
{%- if threshold > 0 -%}
  {%- assign remaining = threshold | minus: cart.total_price -%}
  {%- if remaining <= 0 -%}
    {%- assign pct = 100 -%}
  {%- else -%}
    {%- assign pct = cart.total_price | times: 100 | divided_by: threshold -%}
    {%- assign remaining_display = remaining | money -%}
  {%- endif -%}
  <div class="free-ship{% if remaining <= 0 %} free-ship--done{% endif %}" data-free-ship>
    <div class="free-ship__label">
      {%- if remaining <= 0 -%}
        {{ 'cart.free_ship_reached' | t }}
      {%- else -%}
        {{ 'cart.free_ship_remaining_html' | t: amount: remaining_display }}
      {%- endif -%}
    </div>
    <div class="free-ship__track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ pct }}">
      <span class="free-ship__fill" style="--free-ship-pct: {{ pct }};"></span>
    </div>
  </div>
{%- endif -%}
