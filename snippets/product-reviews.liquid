{%- comment -%}
  Product — reviews. Our on-brand frame (eyebrow + heading) wrapping the
  Judge.me review widget, which is hydrated by the Judge.me app embed and
  reskinned to the theme in component-reviews.css. Judge.me caches the per-
  product widget HTML into the judgeme.widget metafield; we render that so the
  reviews are present on first paint, then Judge.me's JS enhances it (write-a-
  review form, photo upload + lightbox, pagination, verified-buyer, moderation).
{%- endcomment -%}
<section class="reviews" id="atsiliepimai" {{ block.shopify_attributes }}>
  <div class="reviews__head">
    <div class="eyebrow-rule">{{ block.settings.eyebrow | default: '04 — Atsiliepimai' }}</div>
    <h2 class="reviews__title"><span class="light">{{ block.settings.title_light | default: 'Ką sako' }}</span> {{ block.settings.title | default: 'pirkėjai.' }}</h2>
  </div>

  <div class="reviews__widget jdgm-widget jdgm-review-widget" data-id="{{ product.id }}" data-product-title="{{ product.title | escape }}">
    {{ product.metafields.judgeme.widget }}
  </div>
</section>
