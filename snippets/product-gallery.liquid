{%- comment -%} Product — media gallery + dots. Rendered by main-product. {%- endcomment -%}
  <section class="gallery" aria-label="{{ 'accessibility.product_gallery' | t }}">
{%- if product.media.size > 0 -%}
{%- for media in product.media -%}
    <figure class="shot {% cycle 'shot--portrait', 'shot--square', 'shot--landscape' %}">
      <img class="shot__img" src="{{ media | image_url: width: 1400 }}" srcset="{{ media | image_url: width: 700 }} 700w, {{ media | image_url: width: 1400 }} 1400w" sizes="(max-width: 960px) 100vw, 60vw" width="{{ media.preview_image.width | default: 1400 }}" height="{{ media.preview_image.height | default: 1400 }}" alt="{% if media.alt != blank and media.alt != product.title %}{{ media.alt | escape }}{% else %}{{ product.title | escape }} — vaizdas {{ forloop.index }} iš {{ product.media.size }}{% endif %}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"{% if forloop.first %} fetchpriority="high"{% endif %}/>
{%- if forloop.first %}
      <button class="shot__zoom" type="button" aria-label="{{ 'accessibility.zoom' | t }}">
        {% render 'icon', name: 'zoom' %}
      </button>
{%- endif %}
    </figure>
{%- endfor -%}
{%- else -%}
    <figure class="shot shot--portrait">
      <img class="shot__img" src="{{ 'Nr1.webp' | asset_url }}" width="1400" height="1400" alt="Šoninis profilis" loading="eager" fetchpriority="high"/>
      <button class="shot__zoom" type="button" aria-label="{{ 'accessibility.zoom' | t }}">
        {% render 'icon', name: 'zoom' %}
      </button>
    </figure>

    <figure class="shot shot--square">
      <img class="shot__img" src="{{ 'Nr2.webp' | asset_url }}" width="1400" height="1400" alt="Pora iš viršaus" loading="lazy"/>
    </figure>

    <figure class="shot shot--landscape">
      <img class="shot__img" src="{{ 'Nr3.webp' | asset_url }}" width="1400" height="1400" alt="Trijų ketvirčių kampu" loading="lazy"/>
    </figure>
{%- endif -%}

  </section>

  <div class="gallery-dots" role="group" aria-label="{{ 'accessibility.gallery_photos' | t }}">
{%- if product.media.size > 0 -%}
{%- for media in product.media -%}
    <button type="button" aria-current="{% if forloop.first %}true{% else %}false{% endif %}" aria-label="{{ forloop.index }} nuotrauka"></button>
{%- endfor -%}
{%- else -%}
    <button type="button" aria-current="true" aria-label="{{ 'accessibility.photo' | t: number: 1 }}"></button>
    <button type="button" aria-current="false" aria-label="{{ 'accessibility.photo' | t: number: 2 }}"></button>
    <button type="button" aria-current="false" aria-label="{{ 'accessibility.photo' | t: number: 3 }}"></button>
{%- endif -%}
  </div>
