{%- comment -%}
  product-card — one collection grid card, matching the prototype .card markup.
  Usage: {% render 'product-card', product: product %}
        {% render 'product-card', product: product, show_name: true %}
  show_name: renders the product title + type on the card (collection grid).
  Omitted/false: price-only card (search, related, arrivals) — the title
  still reaches an aria-label so the link's accessible name is never bare.
  image_focus: vertical crop anchor for the square media — 'top' | 'center' |
  'bottom' (default 'center'). Drives object-position via a [data-focus] hook.
{%- endcomment -%}
{%- assign card_focus = image_focus | default: 'center' -%}
<a class="card" href="{{ product.url | default: '#' }}"{% unless show_name %} aria-label="{{ product.title | escape }}"{% endunless %}>
  <div class="card__media"{% if card_focus != 'center' %} data-focus="{{ card_focus }}"{% endif %}>
    {%- unless product.available -%}
    <div class="card__sold"><span>{{ 'product.sold_out' | t }}</span></div>
    {%- endunless -%}
    {%- if product.featured_image -%}
    <img
      src="{{ product.featured_image | image_url: width: 800 }}"
      srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
      sizes="(max-width: 520px) 100vw, (max-width: 960px) 50vw, 33vw"
      width="{{ product.featured_image.width }}"
      height="{{ product.featured_image.height }}"
      alt="{{ product.featured_image.alt | escape }}"
      loading="lazy">
    {%- endif -%}
    {%- if product.compare_at_price > product.price -%}
    <span class="card__tag card__tag--orange">–{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%</span>
    {%- elsif product.tags contains 'naujiena' or product.tags contains 'Naujiena' or product.tags contains 'new' or product.tags contains 'New' -%}
    <span class="card__tag card__tag--white">{{ 'product.new' | t }}</span>
    {%- endif -%}
  </div>
  <div class="card__body{% if show_name %} card__body--named{% endif %}">
    {%- if show_name -%}
    <span class="card__name">{{ product.title }}</span>
    <span class="card__dot" aria-hidden="true">·</span>
    {%- endif -%}
    {% render 'price', product: product, layout: 'card' %}
    {%- if show_name -%}
      {%- capture card_stars -%}{% render 'product-rating', product: product, size: 'sm', show_count: true %}{%- endcapture -%}
      {%- assign card_stars = card_stars | strip -%}
      {%- if card_stars != blank -%}<span class="card__rating">{{ card_stars }}</span>{%- endif -%}
    {%- endif -%}
    {%- if show_name and product.type != blank -%}<span class="card__sub">{{ product.type }}</span>{%- endif -%}
  </div>
</a>
