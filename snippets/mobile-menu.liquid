{%- liquid
  assign is_home = false
  assign is_coll = false
  assign is_journal = false
  if request.page_type == 'index'
    assign is_home = true
  endif
  if request.page_type == 'collection' or request.page_type == 'collections' or request.page_type == 'product' or request.page_type == 'list-collections'
    assign is_coll = true
  endif
  if request.page_type == 'blog' or request.page_type == 'article'
    assign is_journal = true
  endif
  assign nav_menu = menu
  if nav_menu.links == blank
    assign nav_menu = settings.menu_main
  endif
-%}
<theme-drawer class="mobilemenu" id="ssMenu" data-body-class="menu-open" data-open-class="is-open" data-portal data-focus=".mobilemenu__close">
  <div class="mobilemenu__scrim" data-drawer-close></div>
  <aside class="mobilemenu__panel" role="dialog" aria-modal="true" aria-label="{{ 'nav.menu' | t }}">
  <div class="mobilemenu__inner">
  <div class="mobilemenu__top">
    <a href="{{ routes.root_url }}" class="mobilemenu__brand">{{ settings.brand_name | default: 'Supersymmetry' }}<span class="brand-dot" aria-hidden="true"></span></a>
    <button type="button" class="mobilemenu__close" data-drawer-close aria-label="{{ 'accessibility.close_menu' | t }}">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8"/></svg>
    </button>
  </div>

  <nav class="mobilemenu__nav" aria-label="{{ 'accessibility.main_nav' | t }}">
    <a href="{{ routes.root_url }}"{% if is_home %} aria-current="page"{% endif %}>{{ 'nav.home' | t }}<span aria-hidden="true">→</span></a>
    {%- if nav_menu.links != blank -%}
      {%- for link in nav_menu.links -%}
        {%- if link.links != blank -%}
          {%- comment -%} A top-level link with children becomes a native <details> accordion. {%- endcomment -%}
          <details class="mobilemenu__acc"{% if link.active or link.child_active %} open{% endif %}>
            <summary>{{ link.title }}<svg class="mobilemenu__acc-caret" viewBox="0 0 12 8" aria-hidden="true"><path d="M1 1.5 L6 6.5 L11 1.5"/></svg></summary>
            <ul class="mobilemenu__acc-list">
              {%- for child in link.links -%}
                {%- if child.links != blank -%}
                  {%- comment -%} A child that itself has children becomes a nested accordion. {%- endcomment -%}
                  <li>
                    <details class="mobilemenu__acc mobilemenu__acc--sub"{% if child.child_active %} open{% endif %}>
                      <summary>{{ child.title }}<svg class="mobilemenu__acc-caret" viewBox="0 0 12 8" aria-hidden="true"><path d="M1 1.5 L6 6.5 L11 1.5"/></svg></summary>
                      <ul class="mobilemenu__acc-list mobilemenu__acc-list--sub">
                        {%- for grandchild in child.links -%}
                          <li><a href="{{ grandchild.url }}"{% if grandchild.active %} aria-current="page"{% endif %}>{{ grandchild.title }}</a></li>
                        {%- endfor -%}
                      </ul>
                    </details>
                  </li>
                {%- else -%}
                  <li><a href="{{ child.url }}"{% if child.active %} aria-current="page"{% endif %}>{{ child.title }}</a></li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </details>
        {%- else -%}
          <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}<span aria-hidden="true">→</span></a>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      <a href="{{ collections.all.url | default: routes.collections_url }}"{% if is_coll %} aria-current="page"{% endif %}>{{ 'nav.shoes' | t }}<span aria-hidden="true">→</span></a>
      <a href="{{ collections.aksesuarai.url | default: routes.collections_url }}">{{ 'nav.accessories' | t }}<span aria-hidden="true">→</span></a>
      <a href="{{ blog.url | default: routes.root_url }}"{% if is_journal %} aria-current="page"{% endif %}>{{ 'nav.journal' | t }}<span aria-hidden="true">→</span></a>
    {%- endif -%}
  </nav>

  {%- if settings.menu_tile_1_image != blank or settings.menu_tile_2_image != blank -%}
    <div class="mobilemenu__tiles">
      {%- for i in (1..2) -%}
        {%- liquid
          assign img_key = 'menu_tile_' | append: i | append: '_image'
          assign heading_key = 'menu_tile_' | append: i | append: '_heading'
          assign link_key = 'menu_tile_' | append: i | append: '_link'
          assign img = settings[img_key]
          assign heading = settings[heading_key]
          assign link = settings[link_key]
        -%}
        {% render 'featured-tile', image: img, heading: heading, link: link, sizes: '45vw' %}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="mobilemenu__sec">
    {%- if settings.menu_secondary.links != blank -%}
      {%- for link in settings.menu_secondary.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    {%- else -%}
      <a href="{{ routes.collections_url }}">{{ 'nav.all_collections' | t }}</a>
      <a href="{{ pages['dydziu-lentele'].url | default: '#' }}">{{ 'nav.size_chart' | t }}</a>
      <a href="{{ pages.grazinimai.url | default: '#' }}">{{ 'nav.returns' | t }}</a>
      <a href="{{ pages['apie-mus'].url | default: '#' }}">{{ 'nav.about' | t }}</a>
      <a href="{{ pages.duk.url | default: '#' }}">{{ 'nav.faq' | t }}</a>
      <a href="{{ pages.kontaktai.url | default: '#' }}">{{ 'nav.contact' | t }}</a>
    {%- endif -%}
    <a href="{{ routes.account_url }}">{{ 'nav.account' | t }}</a>
  </div>

  <div class="mobilemenu__meta">
    {%- if settings.social_instagram != blank or settings.social_tiktok != blank or settings.social_youtube != blank or settings.social_facebook != blank -%}
      <div class="mobilemenu__social">
        {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" rel="noopener" target="_blank">Instagram</a>{%- endif -%}
        {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}" rel="noopener" target="_blank">TikTok</a>{%- endif -%}
        {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" rel="noopener" target="_blank">YouTube</a>{%- endif -%}
        {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" rel="noopener" target="_blank">Facebook</a>{%- endif -%}
      </div>
    {%- endif -%}
    <div class="mobilemenu__foot">
      <span>{{ settings.atelier_address }} · {{ settings.atelier_city }}</span>
      <span>{{ settings.utility_right_message | default: 'LT · EN' }}</span>
    </div>
  </div>
  </div>
  </aside>
</theme-drawer>
