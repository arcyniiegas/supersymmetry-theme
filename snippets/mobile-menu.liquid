{%- liquid
  assign is_home = false
  assign is_coll = false
  assign is_journal = false
  if request.page_type == 'index'
    assign is_home = true
  endif
  if request.page_type == 'collection' or request.page_type == 'collections' or request.page_type == 'product' or request.page_type == 'list-collections'
    assign is_coll = true
  endif
  if request.page_type == 'blog' or request.page_type == 'article'
    assign is_journal = true
  endif
-%}
<div class="mobilemenu" id="ssMenu" role="dialog" aria-modal="true" aria-label="{{ 'nav.menu' | t }}">
  <div class="mobilemenu__top">
    <a href="{{ routes.root_url }}" class="mobilemenu__brand">{{ settings.brand_name | default: 'Supersymmetry' }}<span class="brand-dot" aria-hidden="true"></span></a>
    <button type="button" class="mobilemenu__close" data-menu-close aria-label="{{ 'accessibility.close_menu' | t }}">✕</button>
  </div>
  {%- liquid
    assign nav_menu = settings.menu_main
    if nav_menu.links == blank
      assign nav_menu = linklists['supersymmetry-main']
    endif
  -%}
  <nav class="mobilemenu__nav" aria-label="{{ 'accessibility.main_nav' | t }}">
    <a href="{{ routes.root_url }}"{% if is_home %} aria-current="page"{% endif %}>{{ 'nav.home' | t }}<span aria-hidden="true">→</span></a>
    {%- if nav_menu.links != blank -%}
      {%- for link in nav_menu.links -%}
        <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}<span aria-hidden="true">→</span></a>
      {%- endfor -%}
    {%- else -%}
      <a href="{{ collections.all.url | default: routes.collections_url }}"{% if is_coll %} aria-current="page"{% endif %}>{{ 'nav.shoes' | t }}<span aria-hidden="true">→</span></a>
      <a href="{{ collections.aksesuarai.url | default: routes.collections_url }}">{{ 'nav.accessories' | t }}<span aria-hidden="true">→</span></a>
      <a href="{{ blog.url | default: routes.root_url }}"{% if is_journal %} aria-current="page"{% endif %}>{{ 'nav.journal' | t }}<span aria-hidden="true">→</span></a>
    {%- endif -%}
  </nav>
  <div class="mobilemenu__sec">
    {%- if settings.menu_secondary.links != blank -%}
      {%- for link in settings.menu_secondary.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    {%- else -%}
      <a href="{{ routes.collections_url }}">{{ 'nav.all_collections' | t }}</a>
      <a href="/products/dovanu-kuponas">{{ 'nav.gift_cards' | t }}</a>
      <a href="{{ pages['dydziu-lentele'].url | default: '#' }}">{{ 'nav.size_chart' | t }}</a>
      <a href="{{ pages.grazinimai.url | default: '#' }}">{{ 'nav.returns' | t }}</a>
      <a href="{{ pages['apie-mus'].url | default: '#' }}">{{ 'nav.about' | t }}</a>
      <a href="{{ pages.duk.url | default: '#' }}">{{ 'nav.faq' | t }}</a>
      <a href="{{ pages.kontaktai.url | default: '#' }}">{{ 'nav.contact' | t }}</a>
    {%- endif -%}
    <a href="{{ routes.account_url }}">{{ 'nav.account' | t }}</a>
  </div>
  <div class="mobilemenu__foot">
    <span>{{ settings.atelier_address }} · {{ settings.atelier_city }}</span>
    <span>{{ settings.utility_right_message | default: 'LT · EN' }}</span>
  </div>
</div>
