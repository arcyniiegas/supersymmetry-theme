{%- comment -%} Avalynės priežiūra — leather section. Rendered by main-avalynes-prieziura. {%- endcomment -%}
<section class="sec" id="oda">
  <div class="sec__head">
    <div>
      <div class="eyebrow-rule">{{ section.settings.oda_eyebrow | default: '01 · Lygi oda' }}</div>
      <h2 class="sec__title"><span class="light">{{ section.settings.oda_title_light | default: 'Odos priežiūra' }}</span> {{ section.settings.oda_title | default: '— penki žingsniai.' }}</h2>
    </div>
    <p class="sec__sub">{{ section.settings.oda_sub | default: 'Nuo dulkių iki apsaugos. Visą ciklą kartokite kartą per mėnesį, poliravimą — kada tik norite blizgesio.' }}</p>
  </div>

  <div class="tut">
    <div class="tut__media">
      <span class="tut__word">{{ section.settings.oda_word | default: 'Oda' }}</span>
      <div class="tut__photo">
        {%- if section.settings.oda_image -%}
        <img loading="lazy" src="{{ section.settings.oda_image | image_url: width: 1400 }}" srcset="{{ section.settings.oda_image | image_url: width: 700 }} 700w, {{ section.settings.oda_image | image_url: width: 1400 }} 1400w" sizes="(max-width: 960px) 100vw, 50vw" width="{{ section.settings.oda_image.width }}" height="{{ section.settings.oda_image.height }}" alt="{{ section.settings.oda_image.alt | default: section.settings.oda_alt | escape }}" />
        {%- else -%}
        <img loading="lazy" src="{{ 'Nr1.webp' | asset_url }}" width="1400" height="1400" alt="{{ section.settings.oda_alt | default: 'Juoda lygios odos moka' }}" />
        {%- endif -%}
      </div>
      <div class="tut__cap">
        <span>{{ section.settings.oda_cap_1 | default: 'Lygi veršio oda' }}</span>
        <span class="sep">·</span>
        <span>{{ section.settings.oda_cap_2 | default: 'Bespalvis balzamas' }}</span>
      </div>
    </div>

    {% render 'care-steps', section: section, group: 'oda' %}
  </div>
</section>
