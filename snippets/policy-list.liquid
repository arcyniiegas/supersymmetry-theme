{%- comment -%}
  policy-list — the accepted/rejected condition list inside a returns policy panel.
  Params:
  · items — pipe-separated ("a|b|c") conditions. HTML like <b> is allowed.
  · kind  — 'ok' (check icon) or 'no' (cross icon).
{%- endcomment -%}
{%- assign policy_rows = items | split: '|' -%}
<ul class="policy__list">
  {%- for row in policy_rows -%}
    {%- assign row_clean = row | strip -%}
    {%- if row_clean != blank -%}
    <li class="policy__item">
      <span class="policy__ico policy__ico--{{ kind }}" aria-hidden="true">
        {%- if kind == 'ok' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.2 4.2L19 7"/></svg>
        {%- else -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M7 7l10 10M17 7L7 17"/></svg>
        {%- endif -%}
      </span>
      <span class="policy__t">{{ row_clean }}</span>
    </li>
    {%- endif -%}
  {%- endfor -%}
</ul>
