{%- comment -%} Product — at-a-glance bento. Rendered by main-product for the `glance` block. {%- endcomment -%}
<section class="glance" {{ block.shopify_attributes }}>
  <div class="glance__head">
    <div>
      <div class="glance__eyebrow">{{ block.settings.eyebrow }}</div>
    </div>
  </div>

  <div class="bento">

    <div class="bento__cell b-1">
      <div class="bento__label">Medžiaga</div>
      <div>
        <div class="bento__value">{{ product.metafields.glance.material | default: 'Natūrali oda' }}</div>
        {%- if block.settings.material_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.material_sub }}</div>{%- endif -%}
      </div>
      <div class="bento__bg" aria-hidden="true">
        <svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 140 Q20 110 50 100 L120 80 Q160 70 180 100 Q190 130 170 150 L40 152 Z"/></svg>
      </div>
    </div>

    <div class="bento__cell b-2">
      <div class="bento__label">Padas</div>
      <div>
        <div class="bento__value bento__value--mono">{{ product.metafields.glance.sole | default: 'Vulkanizuota guma' }}</div>
        {%- if block.settings.sole_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.sole_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell bento__cell--orange b-3">
      <div class="bento__label">Kaina</div>
      <div>
        <div class="bento__value bento__value--big bento__value--mono">{{ product.price | money | remove: '€' | remove: ',00' }}</div>
        {%- if block.settings.price_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.price_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-4">
      <div class="bento__label">Gamintojas</div>
      <div>
        <div class="bento__value bento__value--mono">{{ product.metafields.glance.maker | default: product.vendor }}</div>
        {%- if block.settings.maker_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.maker_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-5">
      <div class="bento__label">Svoris</div>
      <div>
        <div class="bento__value bento__value--mono">{{ product.metafields.glance.weight | default: '—' }}</div>
        {%- if block.settings.weight_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.weight_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-6">
      <div class="bento__label">Kilmė</div>
      <div>
        <div class="bento__value">{{ product.metafields.glance.origin | default: '—' }}</div>
        {%- if block.settings.origin_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.origin_sub }}</div>{%- endif -%}
      </div>
    </div>

  </div>
</section>
