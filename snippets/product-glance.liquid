{%- comment -%} Product — at-a-glance bento (Trumpai). Rendered by main-product for the `glance` block.
  · Medžiaga / Padas — product metafield dropdowns (custom.material / custom.sole)
  · Svoris — free-text product metafield (custom.weight)
  · Gamintojas — the shared manufacturer metaobject selector (custom.manufacturer),
    which also feeds the Apie gamintoją description
  · Kilmė — constant, from the block setting (default "Turkija")
  · Kaina — the product's own price
  Legacy model_info metaobject is kept as a fallback for older products.
  Real value or an honest em-dash — never a fabricated default. {%- endcomment -%}
{%- assign model = product.metafields.custom.model_info.value -%}
{%- assign maker = product.metafields.custom.manufacturer.value -%}
{%- assign v_material = product.metafields.custom.material.value | default: model.material -%}
{%- assign v_sole = product.metafields.custom.sole.value | default: model.sole -%}
{%- assign v_weight = product.metafields.custom.weight.value | default: model.weight -%}
{%- assign v_maker = maker.name | default: product.vendor -%}
{%- assign v_origin = block.settings.origin | default: 'Turkija' -%}
<section class="glance" {{ block.shopify_attributes }}>
  <div class="glance__head">
    <div>
      <div class="eyebrow eyebrow--rule">{{ block.settings.eyebrow }}</div>
    </div>
  </div>

  <div class="bento">

    <div class="bento__cell b-1">
      <div class="bento__label">{{ 'product.glance.material' | t }}</div>
      <div>
        <div class="bento__value">{{ v_material | default: '—' }}</div>
        {%- if block.settings.material_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.material_sub }}</div>{%- endif -%}
      </div>
      <div class="bento__bg" aria-hidden="true">
        <svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 140 Q20 110 50 100 L120 80 Q160 70 180 100 Q190 130 170 150 L40 152 Z"/></svg>
      </div>
    </div>

    <div class="bento__cell b-2">
      <div class="bento__label">{{ 'product.glance.sole' | t }}</div>
      <div>
        <div class="bento__value bento__value--mono">{{ v_sole | default: '—' }}</div>
        {%- if block.settings.sole_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.sole_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell bento__cell--orange b-3">
      <div class="bento__label">{{ 'product.glance.price' | t }}</div>
      <div>
        <div class="bento__value bento__value--big bento__value--mono">{{ product.price | money_without_trailing_zeros }}</div>
        {%- if block.settings.price_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.price_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-4">
      <div class="bento__label">{{ 'product.glance.maker' | t }}</div>
      <div>
        <div class="bento__value bento__value--mono">{{ v_maker | default: '—' }}</div>
        {%- if block.settings.maker_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.maker_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-5">
      <div class="bento__label">{{ 'product.glance.weight' | t }}</div>
      <div>
        <div class="bento__value bento__value--mono">{{ v_weight | default: '—' }}</div>
        {%- if block.settings.weight_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.weight_sub }}</div>{%- endif -%}
      </div>
    </div>

    <div class="bento__cell b-6">
      <div class="bento__label">{{ 'product.glance.origin' | t }}</div>
      <div>
        <div class="bento__value">{{ v_origin | default: '—' }}</div>
        {%- if block.settings.origin_sub != blank -%}<div class="bento__sub" style="margin-top: 8px;">{{ block.settings.origin_sub }}</div>{%- endif -%}
      </div>
    </div>

  </div>
</section>
