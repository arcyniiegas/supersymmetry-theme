{%- comment -%}
  meta-social — canonical, Open Graph / Twitter cards, and Organization
  JSON-LD (home page only). Rendered from layout/theme.liquid, which owns
  the <title> + meta description next to this render call. `page_image`
  is Shopify's per-page social image (product/article/collection image,
  falling back to the store's social-sharing image).
{%- endcomment -%}
{%- liquid
  assign ms_brand = settings.brand_name | default: shop.name
  assign ms_title = page_title | default: ms_brand
  assign ms_description = meta_description | default: page_description | default: shop.description | default: ms_brand

  assign ms_type = 'website'
  if request.page_type == 'product'
    assign ms_type = 'product'
  elsif request.page_type == 'article'
    assign ms_type = 'article'
  endif
-%}
<link rel="canonical" href="{{ canonical_url }}">
<meta property="og:site_name" content="{{ ms_brand | escape }}">
<meta property="og:type" content="{{ ms_type }}">
<meta property="og:title" content="{{ ms_title | escape }}">
<meta property="og:description" content="{{ ms_description | strip_html | truncate: 300 | escape }}">
<meta property="og:url" content="{{ canonical_url }}">
{%- if page_image %}
<meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
<meta property="og:image:width" content="{{ page_image.width | at_most: 1200 }}">
{%- if page_image.width > 0 %}
<meta property="og:image:height" content="{{ 1200 | at_most: page_image.width | times: 1.0 | divided_by: page_image.aspect_ratio | round }}">
{%- endif %}
{%- if page_image.alt != blank %}
<meta property="og:image:alt" content="{{ page_image.alt | escape }}">
{%- endif %}
{%- endif %}
{%- if request.page_type == 'product' %}
<meta property="og:price:amount" content="{{ product.price | divided_by: 100.0 }}">
<meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ms_title | escape }}">
<meta name="twitter:description" content="{{ ms_description | strip_html | truncate: 200 | escape }}">
{%- if request.page_type == 'index' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ ms_brand | json }},
  "url": {{ shop.url | json }}
  {%- if settings.social_instagram != blank -%},
  "sameAs": [{{ settings.social_instagram | json }}]
  {%- endif -%}
  {%- if settings.atelier_address != blank -%},
  "address": {
    "@type": "PostalAddress",
    "streetAddress": {{ settings.atelier_address | json }},
    "addressLocality": {{ settings.atelier_city | default: 'Vilnius' | json }},
    "addressCountry": "LT"
  }
  {%- endif -%}
}
</script>
{%- endif %}
