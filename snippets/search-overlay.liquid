<div class="ss-search" id="ssSearch" role="dialog" aria-modal="true" aria-label="Paieška">
  <div class="ss-search__inner">
    <div class="ss-search__bar">
      <span class="ss-search__eyebrow">{{ settings.search_eyebrow | default: 'Paieška · <b>visa kolekcija</b>' }}</span>
      <button type="button" class="ss-search__close" data-search-close aria-label="Uždaryti paiešką"><span class="x" aria-hidden="true">✕</span> Uždaryti</button>
    </div>
    <form class="ss-search__box" action="{{ routes.search_url }}" method="get" role="search">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="8"/><path d="M18 18l6 6"/></svg>
      <input type="text" id="ssSearchInput" name="q" placeholder="{{ settings.search_placeholder | default: 'Ko ieškai?' | escape }}" autocomplete="off" aria-label="Paieška" />
      <input type="hidden" name="options[prefix]" value="last">
      <button type="button" class="ss-search__clear" id="ssSearchClear" aria-label="Išvalyti">✕</button>
    </form>
    <div class="ss-search__suggest"><span class="lbl">{{ settings.search_popular_label | default: 'Populiaru' }}</span>
      {%- assign chip_src = settings.search_chips | default: 'bateliai, basutės, aulinukai, rankinės, šalikai, kepurės' -%}
      {%- assign chips = chip_src | split: ',' -%}
      {%- for chip in chips -%}
        {%- assign parts = chip | strip | split: '|' -%}
        {%- assign term = parts[0] | strip -%}
        {%- if term != blank -%}
          <button type="button" class="ss-search__chip" data-term="{{ term | escape }}">{{ term }}{% if parts[1] %} <span class="n">·{{ parts[1] | strip }}</span>{% endif %}</button>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="ss-search__resbar" id="ssSearchCount"></div>
    <div class="ss-search__grid" id="ssSearchGrid"></div>
    <div class="ss-search__empty">
      <span class="ss-search__eyebrow">Nieko nerasta</span>
      <h2 class="ss-search__empty-big">Pagal <span class="q" id="ssSearchEmptyQ">„…“</span> kol kas <b>nieko.</b></h2>
      <p class="ss-search__empty-lede">{{ settings.search_empty_lede | default: 'Galbūt ši pora dar archyve arba ruošiama kitai partijai. Pabandyk plačiau — pagal spalvą ar modelį.' }}</p>
    </div>
  </div>
</div>
