{%- comment -%} Product — doc sections (spec / story / care blocks). Rendered by main-product. {%- endcomment -%}
{%- assign doc_types = 'spec,story,care' | split: ',' -%}
{%- assign has_docs = false -%}
{%- for block in section.blocks -%}
  {%- if doc_types contains block.type -%}{%- assign has_docs = true -%}{%- endif -%}
{%- endfor -%}
{%- if has_docs -%}
<!-- ──────────── DOC SECTIONS ──────────── -->
<div class="docs">
{%- for block in section.blocks -%}
  {%- case block.type -%}
  {%- when 'spec' -%}
  <section class="doc" {{ block.shopify_attributes }}>
    <div class="doc__index">
      <span class="doc__num">{{ block.settings.num }}</span>
      <h2 class="doc__title">{{ block.settings.title }}</h2>
      <p class="doc__lede">{{ block.settings.lede }}</p>
    </div>
    <div>
      <div class="quals" aria-label="{{ 'accessibility.construction_features' | t }}">
{%- assign features = product.metafields.custom.features.value -%}
{%- for f in features -%}
        {%- comment -%} description keyed by the feature's icon (stable enum), copy in locales {%- endcomment -%}
        {%- assign feat_key = f.icon | replace: '-', '_' -%}
        {%- capture feat_desc -%}{{ feat_key | prepend: 'product.feat.' | t }}{%- endcapture -%}
        <div class="qual">
          {% render 'icon-feature', icon: f.icon %}
          <div class="qual__text">
            <span class="k">{{ f.label }}</span>
            {%- unless feat_desc contains 'translation missing' or f.icon == blank -%}<span class="v">{{ feat_desc }}</span>{%- endunless -%}
          </div>
        </div>
{%- endfor -%}
      </div>
    </div>
  </section>
  {%- when 'story' -%}
  <section class="doc" {{ block.shopify_attributes }}>
    <div class="doc__index">
      <span class="doc__num">{{ block.settings.num }}</span>
      <h2 class="doc__title">{{ block.settings.title }}</h2>
      <p class="doc__lede">{{ block.settings.lede }}</p>
    </div>
    <div>
      <div class="notes-prose">
{%- assign maker = product.metafields.custom.manufacturer.value -%}
{%- if maker != blank -%}
{%- if maker.description != blank -%}<p>{{ maker.description | newline_to_br }}</p>{%- endif -%}
        <p class="notes-prose__maker">{{ maker.name }}{% if maker.country_of_origin != blank %} · {{ maker.country_of_origin }}{% endif %}</p>
{%- endif -%}
      </div>
    </div>
  </section>
  {%- when 'care' -%}
  <section class="doc" {{ block.shopify_attributes }}>
    <div class="doc__index">
      <span class="doc__num">{{ block.settings.num }}</span>
      <h2 class="doc__title">{{ block.settings.title }}</h2>
      <p class="doc__lede">{{ block.settings.lede }}</p>
    </div>
    <div>
      <div class="care">
{%- if product.metafields.care.steps != blank -%}
{%- for step in product.metafields.care.steps.value -%}
        <div class="care__cell">
          <div class="care__text"><div class="care__label">{{ step }}</div></div>
        </div>
{%- endfor -%}
{%- else -%}
        <div class="care__cell">
          <div class="care__icon"><svg viewBox="0 0 32 32"><path d="M8 13 L24 13 L22 24 L10 24 Z"/><path d="M12 13 V8 a4 4 0 0 1 8 0 V13"/></svg></div>
          <div class="care__text">
            <div class="care__label">{{ 'product.care.clean_label' | t }}</div>
            <div class="care__desc">{{ 'product.care.clean_desc' | t }}</div>
          </div>
        </div>
        <div class="care__cell">
          <div class="care__icon"><svg viewBox="0 0 32 32"><circle cx="16" cy="16" r="9"/><line x1="9" y1="9" x2="23" y2="23"/></svg></div>
          <div class="care__text">
            <div class="care__label">{{ 'product.care.nowash_label' | t }}</div>
            <div class="care__desc">{{ 'product.care.nowash_desc' | t }}</div>
          </div>
        </div>
        <div class="care__cell">
          <div class="care__icon"><svg viewBox="0 0 32 32"><circle cx="16" cy="16" r="9"/><path d="M16 10 V16 L21 19"/></svg></div>
          <div class="care__text">
            <div class="care__label">{{ 'product.care.condition_label' | t }}</div>
            <div class="care__desc">{{ 'product.care.condition_desc' | t }}</div>
          </div>
        </div>
        <div class="care__cell">
          <div class="care__icon"><svg viewBox="0 0 32 32"><path d="M8 15 V24 H24 V15"/><path d="M16 4 V16 M11 11 L16 16 L21 11"/></svg></div>
          <div class="care__text">
            <div class="care__label">{{ 'product.care.dry_label' | t }}</div>
            <div class="care__desc">{{ 'product.care.dry_desc' | t }}</div>
          </div>
        </div>
{%- endif -%}
      </div>
    </div>
  </section>
  {%- endcase -%}
{%- endfor -%}
</div>
{%- endif -%}
