<!doctype html>
<html lang="{{ request.locale.iso_code }}"{% unless settings.glass_enabled %} data-glass="off"{% endunless %} style="--glass-blur: {{ settings.glass_blur | default: 12 }}px; --type-scale: {{ settings.type_scale | default: 100 | divided_by: 100.0 }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#FFFFFF">
  {{ 'geist-latin.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2' }}
  {{ 'geistmono-latin.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2' }}
  {{ 'tokens.css' | asset_url | stylesheet_tag }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'component-button.css' | asset_url | stylesheet_tag }}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-mobile-menu.css' | asset_url | stylesheet_tag }}
  {{ 'component-dock.css' | asset_url | stylesheet_tag }}
  {{ 'component-search.css' | asset_url | stylesheet_tag }}
  {{ 'component-header.css' | asset_url | stylesheet_tag }}
  {{ 'component-mega-menu.css' | asset_url | stylesheet_tag }}
  {{ 'component-footer.css' | asset_url | stylesheet_tag }}
  {{ 'component-form.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
  <style>{% render 'color-schemes' %}</style>
  {{ content_for_header }}
  {%- assign brand = settings.brand_name | default: shop.name -%}
  <title>{% if page_title contains brand or page_title == blank %}{{ page_title | default: brand }}{% else %}{{ page_title }} · {{ brand }}{% endif %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  {% render 'meta-social' %}
</head>
<body class="template-{{ request.page_type }} color-scheme-1">
  {% sections 'header-group' %}
  <main id="MainContent">{{ content_for_layout }}</main>
  {% sections 'footer-group' %}
  {% render 'dock' %}
  {% render 'mobile-menu' %}
  {% render 'search-overlay' %}
  {% section 'cart-drawer' %}
  {% render 'cookie-banner' %}
  {%- comment -%} JS string registry: customer-facing copy used by scripts, sourced
    from locales so translators reach it. theme.t(key, {var}) fills {var} tokens. {%- endcomment -%}
  <script>
    window.theme = window.theme || {};
    window.theme.strings = {
      'product.add_to_cart': {{ 'product.add_to_cart' | t | json }},
      'product.added_short': {{ 'product.added_short' | t | json }},
      'product.added_to_cart': {{ 'product.added_to_cart' | t | json }},
      'product.add_error': {{ 'product.add_error' | t | json }},
      'product.stock_left': {{ 'product.stock_left' | t | json }},
      'product.reviews_show': {{ 'product.reviews_show' | t | json }},
      'product.reviews_hide': {{ 'product.reviews_hide' | t | json }},
      'cart.removed': {{ 'cart.removed' | t | json }},
      'cart.update_error': {{ 'cart.update_error' | t | json }},
      'faq.summary': {{ 'faq.summary' | t | json }},
      'faq.results': {{ 'faq.results' | t | json }},
      'faq.result_one': {{ 'faq.result_one' | t | json }},
      'faq.result_other': {{ 'faq.result_other' | t | json }},
      'faq.no_results': {{ 'faq.no_results' | t | json }},
      'faq.quoted_term': {{ 'faq.quoted_term' | t | json }},
      'search.found': {{ 'search.found' | t | json }},
      'search.result_one': {{ 'search.result_one' | t | json }},
      'search.result_few': {{ 'search.result_few' | t | json }},
      'search.result_many': {{ 'search.result_many' | t | json }},
      'search.all_results': {{ 'search.all_results' | t | json }},
      'search.result_collection': {{ 'search.result_collection' | t | json }},
      'search.result_article': {{ 'search.result_article' | t | json }}
    };
    window.theme.t = function (key, vars) {
      var s = (window.theme.strings && window.theme.strings[key]) || '';
      if (vars) { Object.keys(vars).forEach(function (k) { s = s.split('{' + k + '}').join(vars[k]); }); }
      return s;
    };
  </script>
  <script src="{{ 'cart-store.js' | asset_url }}" defer></script>
  <script src="{{ 'component-drawer.js' | asset_url }}" defer></script>
  <script src="{{ 'component-cart.js' | asset_url }}" defer></script>
  <script src="{{ 'chrome.js' | asset_url }}" defer></script>
  <script src="{{ 'component-mega-menu.js' | asset_url }}" defer></script>
  <script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
</body>
</html>
