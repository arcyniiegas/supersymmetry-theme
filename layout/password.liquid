<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#0A0A0A">
  {{ 'geist-latin.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2' }}
  {{ 'geistmono-latin.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2' }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'section-password.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  <title>{{ page_title }}</title>
</head>
<body>
  {{ content_for_layout }}
  <script src="{{ 'password.js' | asset_url }}" defer></script>
</body>
</html>
